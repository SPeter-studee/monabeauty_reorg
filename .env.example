# Másold `.env.example` → `.dev.vars` (Wrangler) vagy állítsd be a Cloudflare Pages → Settings → Variables.
# Soha ne commitolj valós értéket.

# Admin / legacy API
# ADMIN_SECRET=

# Google OAuth (ügyfél + admin session)
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=

# Setmore (ha használod)
# SETMORE_REFRESH_TOKEN=

# DeepL (fordítás)
# DEEPL_API_KEY=

# Egyéb — igény szerint bővítsd a régi projekt env listájából
