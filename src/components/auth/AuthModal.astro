---
// src/components/auth/AuthModal.astro
// Sprint 4.2 — Login / Register modal popup
//
// Single-instance modal (a BaseLayout-ban egyszer beillesztve), két nézettel:
//   - login: email + jelszó + "Bejelentkezés" + "Még nincs fiókod? Regisztráció"
//   - register: email + jelszó + first/last name + ÁSZF + marketing + Turnstile widget
//
// Open/close events (auth-state.ts):
//   - openAuthModal("login")  → megnyit login-on
//   - openAuthModal("register") → megnyit register-en
//   - closeAuthModal() → bezár
//
// Sikeres login/register esetén:
//   - setAuthenticated(customer) — kliens state frissítés
//   - closeAuthModal() — bezárás
//   - A header automatikusan frissül a subscribeAuthState miatt
//
// Turnstile widget — lazy load: csak amikor a register tab aktívvá válik.
// A site key a wrangler.toml `[vars]`-ból érkezik (publikus).

const turnstileSiteKey = (Astro.locals as any).runtime?.env?.TURNSTILE_SITE_KEY
  || import.meta.env.TURNSTILE_SITE_KEY
  || "";
---

<div
  class="auth-modal"
  data-auth-modal
  aria-hidden="true"
  aria-modal="true"
  role="dialog"
  aria-labelledby="auth-modal-title"
>
  <div class="auth-modal__overlay" data-auth-modal-overlay></div>

  <div class="auth-modal__panel">
    <button
      type="button"
      class="auth-modal__close"
      data-auth-modal-close
      aria-label="Bezárás"
    >
      <svg viewBox="0 0 24 24" width="20" height="20" stroke="currentColor" stroke-width="1.5" fill="none">
        <path d="M6 6L18 18M6 18L18 6"/>
      </svg>
    </button>

    {/* TAB SWITCH (login / register) */}
    <div class="auth-modal__tabs" role="tablist">
      <button
        type="button"
        class="auth-modal__tab auth-modal__tab--active"
        data-auth-tab="login"
        role="tab"
        aria-selected="true"
      >
        Bejelentkezés
      </button>
      <button
        type="button"
        class="auth-modal__tab"
        data-auth-tab="register"
        role="tab"
        aria-selected="false"
      >
        Regisztráció
      </button>
    </div>

    <h2 id="auth-modal-title" class="visually-hidden">Belépés vagy regisztráció</h2>

    {/* ─── LOGIN VIEW ─── */}
    <div class="auth-modal__view auth-modal__view--login" data-auth-view="login">
      <p class="auth-modal__intro">
        Üdv újra! Jelentkezz be a folytatáshoz.
      </p>

      <form class="auth-modal__form" data-auth-form="login" novalidate>
        <div class="auth-modal__field">
          <label class="auth-modal__label" for="login-email">Email cím</label>
          <input
            type="email"
            id="login-email"
            name="email"
            class="auth-modal__input"
            autocomplete="email"
            required
            placeholder="te@example.hu"
          />
        </div>

        <div class="auth-modal__field">
          <label class="auth-modal__label" for="login-password">Jelszó</label>
          <div class="auth-modal__password-wrap">
            <input
              type="password"
              id="login-password"
              name="password"
              class="auth-modal__input auth-modal__input--password"
              autocomplete="current-password"
              required
              minlength="8"
              placeholder="••••••••"
            />
            <button
              type="button"
              class="auth-modal__password-toggle"
              data-password-toggle="login-password"
              aria-label="Jelszó megjelenítése"
            >
              <svg class="auth-modal__eye-icon" viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/>
                <circle cx="12" cy="12" r="3"/>
              </svg>
              <svg class="auth-modal__eye-off-icon" viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" hidden>
                <path d="M17.94 17.94A10.07 10.07 0 0112 20c-7 0-11-8-11-8a18.45 18.45 0 015.06-5.94M9.9 4.24A9.12 9.12 0 0112 4c7 0 11 8 11 8a18.5 18.5 0 01-2.16 3.19m-6.72-1.07a3 3 0 11-4.24-4.24"/>
                <line x1="1" y1="1" x2="23" y2="23"/>
              </svg>
            </button>
          </div>
        </div>

        <p class="auth-modal__error" data-auth-error="login" hidden></p>

        <button type="submit" class="auth-modal__submit btn btn-primary" data-auth-submit="login">
          <span class="auth-modal__submit-text">Bejelentkezés</span>
          <span class="auth-modal__submit-loading" hidden>Egy pillanat...</span>
        </button>

        <p class="auth-modal__alt">
          <a href="#" class="auth-modal__link" data-forgot-password>Elfelejtetted a jelszót?</a>
        </p>

        <p class="auth-modal__switch">
          Még nincs fiókod?
          <button type="button" class="auth-modal__link" data-switch-to="register">
            Regisztrálj
          </button>
        </p>
      </form>
    </div>

    {/* ─── REGISTER VIEW ─── */}
    <div class="auth-modal__view auth-modal__view--register" data-auth-view="register" hidden>
      <p class="auth-modal__intro">
        Csatlakozz a Mona Studio közösséghez. Néhány adat, és kész is.
      </p>

      <form class="auth-modal__form" data-auth-form="register" novalidate>
        <div class="auth-modal__field-row">
          <div class="auth-modal__field">
            <label class="auth-modal__label" for="register-firstname">Keresztnév</label>
            <input
              type="text"
              id="register-firstname"
              name="firstName"
              class="auth-modal__input"
              autocomplete="given-name"
              placeholder="Anna"
              maxlength="50"
            />
          </div>
          <div class="auth-modal__field">
            <label class="auth-modal__label" for="register-lastname">Vezetéknév</label>
            <input
              type="text"
              id="register-lastname"
              name="lastName"
              class="auth-modal__input"
              autocomplete="family-name"
              placeholder="Kovács"
              maxlength="50"
            />
          </div>
        </div>

        <div class="auth-modal__field">
          <label class="auth-modal__label" for="register-email">Email cím</label>
          <input
            type="email"
            id="register-email"
            name="email"
            class="auth-modal__input"
            autocomplete="email"
            required
            placeholder="te@example.hu"
          />
        </div>

        <div class="auth-modal__field">
          <label class="auth-modal__label" for="register-password">Jelszó</label>
          <div class="auth-modal__password-wrap">
            <input
              type="password"
              id="register-password"
              name="password"
              class="auth-modal__input auth-modal__input--password"
              autocomplete="new-password"
              required
              minlength="8"
              placeholder="Legalább 8 karakter"
            />
            <button
              type="button"
              class="auth-modal__password-toggle"
              data-password-toggle="register-password"
              aria-label="Jelszó megjelenítése"
            >
              <svg class="auth-modal__eye-icon" viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/>
                <circle cx="12" cy="12" r="3"/>
              </svg>
              <svg class="auth-modal__eye-off-icon" viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" hidden>
                <path d="M17.94 17.94A10.07 10.07 0 0112 20c-7 0-11-8-11-8a18.45 18.45 0 015.06-5.94M9.9 4.24A9.12 9.12 0 0112 4c7 0 11 8 11 8a18.5 18.5 0 01-2.16 3.19m-6.72-1.07a3 3 0 11-4.24-4.24"/>
                <line x1="1" y1="1" x2="23" y2="23"/>
              </svg>
            </button>
          </div>
          <p class="auth-modal__hint">A jelszó legalább 8 karakter hosszú legyen.</p>
        </div>

        <label class="auth-modal__checkbox">
          <input
            type="checkbox"
            name="acceptsTerms"
            data-accepts-terms
            required
          />
          <span>
            Elolvastam és elfogadom az
            <a href="/aszf" target="_blank" rel="noopener">ÁSZF-et</a> és az
            <a href="/adatvedelem" target="_blank" rel="noopener">adatvédelmi tájékoztatót</a>.
          </span>
        </label>

        <label class="auth-modal__checkbox">
          <input
            type="checkbox"
            name="acceptsMarketing"
            data-accepts-marketing
          />
          <span>
            Szeretnék értesülni új termékekről és akciókról
            <em>(opcionális)</em>
          </span>
        </label>

        {/* Turnstile widget container — lazy load JS-ből */}
        <div class="auth-modal__captcha" data-turnstile-container>
          <div class="auth-modal__captcha-placeholder">
            <span class="auth-modal__captcha-spinner" aria-hidden="true"></span>
            Robotvédelem betöltése...
          </div>
        </div>

        <p class="auth-modal__error" data-auth-error="register" hidden></p>

        <button type="submit" class="auth-modal__submit btn btn-primary" data-auth-submit="register">
          <span class="auth-modal__submit-text">Regisztrálok</span>
          <span class="auth-modal__submit-loading" hidden>Egy pillanat...</span>
        </button>

        <p class="auth-modal__switch">
          Már van fiókod?
          <button type="button" class="auth-modal__link" data-switch-to="login">
            Jelentkezz be
          </button>
        </p>
      </form>
    </div>
  </div>
</div>

<!-- Inline script — csak a publikus Site Key-t teszi a window-ra (Astro define:vars
     nem támogat ES import-ot, ezért ez a kis "bridge" inline) -->
<script is:inline define:vars={{ turnstileSiteKey }}>
  window.__MONA_TURNSTILE_SITE_KEY__ = turnstileSiteKey || "";
</script>

<script>
  // Sprint 4.2 — AuthModal logika
  // (Ez a script bundle-ölődik Vite-tel, működik az import + path alias)

  import {
    setAuthenticated,
    getAuthState,
    AUTH_MODAL_OPEN_EVENT,
    AUTH_MODAL_CLOSE_EVENT,
  } from "@/lib/auth-state";

  // Globálba kitett változó az inline script-ből
  const turnstileSiteKey: string = (window as any).__MONA_TURNSTILE_SITE_KEY__ || "";

  initAuthModal();

  function initAuthModal() {
    const modal = document.querySelector<HTMLElement>("[data-auth-modal]");
    const overlay = document.querySelector<HTMLElement>("[data-auth-modal-overlay]");
    const closeBtn = document.querySelector<HTMLButtonElement>("[data-auth-modal-close]");
    const loginView = document.querySelector<HTMLElement>('[data-auth-view="login"]');
    const registerView = document.querySelector<HTMLElement>('[data-auth-view="register"]');
    const tabs = document.querySelectorAll<HTMLButtonElement>("[data-auth-tab]");
    const switchBtns = document.querySelectorAll<HTMLButtonElement>("[data-switch-to]");
    const loginForm = document.querySelector<HTMLFormElement>('[data-auth-form="login"]');
    const registerForm = document.querySelector<HTMLFormElement>('[data-auth-form="register"]');
    const turnstileContainer = document.querySelector<HTMLElement>("[data-turnstile-container]");

    if (!modal || !overlay || !loginForm || !registerForm) {
      console.error("[auth-modal] markup missing");
      return;
    }

    let turnstileLoaded = false;
    let turnstileWidgetId: string | null = null;
    let lastTurnstileToken = "";

    // ── Open / close event listeners ─────────────────────────────────────────
    window.addEventListener(AUTH_MODAL_OPEN_EVENT, ((e: Event) => {
      const ce = e as CustomEvent<{ view?: "login" | "register" }>;
      const view = ce.detail?.view || "login";
      openModal(view);
    }) as EventListener);

    window.addEventListener(AUTH_MODAL_CLOSE_EVENT, closeModal);

    overlay.addEventListener("click", closeModal);
    closeBtn?.addEventListener("click", closeModal);

    // Esc-re bezárás
    document.addEventListener("keydown", (e) => {
      if (e.key === "Escape" && modal.getAttribute("aria-hidden") === "false") {
        closeModal();
      }
    });

    function openModal(view: "login" | "register") {
      modal!.setAttribute("aria-hidden", "false");
      document.body.style.overflow = "hidden";
      switchView(view);

      requestAnimationFrame(() => {
        const firstInput = view === "login"
          ? document.getElementById("login-email")
          : document.getElementById("register-firstname");
        firstInput?.focus();
      });
    }

    function closeModal() {
      modal!.setAttribute("aria-hidden", "true");
      document.body.style.overflow = "";
      document.querySelectorAll<HTMLElement>("[data-auth-error]").forEach((el) => {
        el.hidden = true;
        el.textContent = "";
      });
    }

    // ── Tab váltás ──────────────────────────────────────────────────────────
    tabs.forEach((tab) => {
      tab.addEventListener("click", () => {
        const view = tab.dataset.authTab as "login" | "register";
        switchView(view);
      });
    });

    switchBtns.forEach((btn) => {
      btn.addEventListener("click", () => {
        switchView(btn.dataset.switchTo as "login" | "register");
      });
    });

    function switchView(view: "login" | "register") {
      tabs.forEach((t) => {
        const isActive = t.dataset.authTab === view;
        t.classList.toggle("auth-modal__tab--active", isActive);
        t.setAttribute("aria-selected", String(isActive));
      });
      loginView!.hidden = view !== "login";
      registerView!.hidden = view !== "register";

      if (view === "register" && !turnstileLoaded) {
        loadTurnstile();
      }
    }

    // ── Turnstile lazy loader ───────────────────────────────────────────────
    function loadTurnstile() {
      if (!turnstileSiteKey) {
        console.warn("[auth-modal] TURNSTILE_SITE_KEY not configured — captcha skipped");
        if (turnstileContainer) {
          turnstileContainer.innerHTML =
            '<p style="font-size: 12px; color: var(--mona-text-3); margin: 0;">Robotvédelem nem aktív (fejlesztői mód).</p>';
        }
        turnstileLoaded = true;
        return;
      }

      (window as any).onTurnstileLoad = () => {
        const ts = (window as any).turnstile;
        if (!ts || !turnstileContainer) return;
        turnstileContainer.innerHTML = "";
        turnstileWidgetId = ts.render(turnstileContainer, {
          sitekey: turnstileSiteKey,
          theme: "light",
          callback: (token: string) => { lastTurnstileToken = token; },
          "expired-callback": () => { lastTurnstileToken = ""; },
          "error-callback": () => { lastTurnstileToken = ""; },
        });
      };

      const script = document.createElement("script");
      script.src = "https://challenges.cloudflare.com/turnstile/v0/api.js?onload=onTurnstileLoad";
      script.async = true;
      script.defer = true;
      document.head.appendChild(script);
      turnstileLoaded = true;
    }

    // ── LOGIN form submit ───────────────────────────────────────────────────
    loginForm.addEventListener("submit", async (e) => {
      e.preventDefault();
      await submitLogin();
    });

    async function submitLogin() {
      const submitBtn = document.querySelector<HTMLButtonElement>('[data-auth-submit="login"]');
      const errorEl = document.querySelector<HTMLElement>('[data-auth-error="login"]');
      const formData = new FormData(loginForm!);

      setLoading(submitBtn, true);
      hideError(errorEl);

      try {
        const res = await fetch("/api/auth/login", {
          method: "POST",
          headers: { "Content-Type": "application/json" },
          credentials: "include",
          body: JSON.stringify({
            email: formData.get("email"),
            password: formData.get("password"),
          }),
        });

        let data: any;
        try {
          data = await res.json();
        } catch (parseErr) {
          const text = await res.text().catch(() => "");
          console.error("[auth-modal] login: non-JSON response", {
            status: res.status,
            statusText: res.statusText,
            body: text.slice(0, 500),
          });
          showError(errorEl, `Szerver hiba (HTTP ${res.status}). Próbáld újra később.`);
          setLoading(submitBtn, false);
          return;
        }

        if (!res.ok || !data.success) {
          console.error("[auth-modal] login failed:", { status: res.status, data });
          showError(errorEl, data.message || `Bejelentkezés sikertelen (HTTP ${res.status}).`);
          setLoading(submitBtn, false);
          return;
        }

        setAuthenticated(data.customer);
        closeModal();
      } catch (err) {
        console.error("[auth-modal] login network error:", err);
        showError(errorEl, "Hálózati hiba. Próbáld újra.");
        setLoading(submitBtn, false);
      }
    }

    // ── REGISTER form submit ────────────────────────────────────────────────
    registerForm.addEventListener("submit", async (e) => {
      e.preventDefault();
      await submitRegister();
    });

    async function submitRegister() {
      const submitBtn = document.querySelector<HTMLButtonElement>('[data-auth-submit="register"]');
      const errorEl = document.querySelector<HTMLElement>('[data-auth-error="register"]');
      const formData = new FormData(registerForm!);

      const acceptsTerms = formData.get("acceptsTerms") === "on";
      const acceptsMarketing = formData.get("acceptsMarketing") === "on";

      if (!acceptsTerms) {
        showError(errorEl, "Az ÁSZF és az adatvédelmi tájékoztató elfogadása kötelező.");
        return;
      }

      const password = formData.get("password");
      if (typeof password !== "string" || password.length < 8) {
        showError(errorEl, "A jelszó legalább 8 karakter hosszú legyen.");
        return;
      }

      let turnstileToken = lastTurnstileToken;
      if (turnstileSiteKey && !turnstileToken) {
        showError(errorEl, "Kérlek várd meg a robotvédelem ellenőrzését.");
        return;
      }
      if (!turnstileSiteKey) {
        turnstileToken = "DEV_NO_CAPTCHA";
      }

      setLoading(submitBtn, true);
      hideError(errorEl);

      try {
        const res = await fetch("/api/auth/register", {
          method: "POST",
          headers: { "Content-Type": "application/json" },
          credentials: "include",
          body: JSON.stringify({
            email: formData.get("email"),
            password,
            firstName: formData.get("firstName") || undefined,
            lastName: formData.get("lastName") || undefined,
            acceptsTerms: true,
            acceptsMarketing,
            turnstileToken,
          }),
        });

        // JSON parse külön try — ha a backend nem JSON-t adott vissza (pl. 500 HTML),
        // ne dobjunk egy zavaró "Hálózati hiba"-t, hanem érdemi üzenetet.
        let data: any;
        try {
          data = await res.json();
        } catch (parseErr) {
          const text = await res.text().catch(() => "");
          console.error("[auth-modal] register: non-JSON response", {
            status: res.status,
            statusText: res.statusText,
            body: text.slice(0, 500),
          });
          showError(
            errorEl,
            `Szerver hiba (HTTP ${res.status}). Próbáld újra később.`
          );
          setLoading(submitBtn, false);
          return;
        }

        if (!res.ok || !data.success) {
          console.error("[auth-modal] register failed:", { status: res.status, data });
          // Debug info-t is megjelenítjük (Sprint 4.x-ben kivesszük)
          let displayMsg = data.message || `Regisztráció sikertelen (HTTP ${res.status}).`;
          if (data.debug) {
            displayMsg += ` [debug: ${data.debug}]`;
          }
          showError(errorEl, displayMsg);
          setLoading(submitBtn, false);
          const ts = (window as any).turnstile;
          if (ts && turnstileWidgetId) {
            ts.reset(turnstileWidgetId);
            lastTurnstileToken = "";
          }
          return;
        }

        setAuthenticated(data.customer);
        closeModal();
        console.log("[auth-modal] register success:", data.message);
      } catch (err) {
        console.error("[auth-modal] register network error:", err);
        showError(errorEl, "Hálózati hiba. Próbáld újra.");
        setLoading(submitBtn, false);
      }
    }

    // ── Show password toggle ───────────────────────────────────────────────
    document.querySelectorAll<HTMLButtonElement>("[data-password-toggle]").forEach((btn) => {
      btn.addEventListener("click", () => {
        const targetId = btn.dataset.passwordToggle;
        if (!targetId) return;
        const input = document.getElementById(targetId) as HTMLInputElement | null;
        if (!input) return;

        const isHidden = input.type === "password";
        input.type = isHidden ? "text" : "password";
        btn.setAttribute("aria-label", isHidden ? "Jelszó elrejtése" : "Jelszó megjelenítése");

        // Ikon váltás
        const eyeIcon = btn.querySelector<SVGElement>(".auth-modal__eye-icon");
        const eyeOffIcon = btn.querySelector<SVGElement>(".auth-modal__eye-off-icon");
        if (eyeIcon) eyeIcon.hidden = isHidden;
        if (eyeOffIcon) eyeOffIcon.hidden = !isHidden;
      });
    });

    // ── Helpers ─────────────────────────────────────────────────────────────
    function setLoading(btn: HTMLButtonElement | null, loading: boolean) {
      if (!btn) return;
      const text = btn.querySelector<HTMLElement>(".auth-modal__submit-text");
      const loadingEl = btn.querySelector<HTMLElement>(".auth-modal__submit-loading");
      if (text) text.hidden = loading;
      if (loadingEl) loadingEl.hidden = !loading;
      btn.disabled = loading;
    }

    function showError(el: HTMLElement | null, message: string) {
      if (!el) return;
      el.textContent = message;
      el.hidden = false;
    }

    function hideError(el: HTMLElement | null) {
      if (!el) return;
      el.textContent = "";
      el.hidden = true;
    }
  }
</script>

<style is:global>
  /* ─── AuthModal — overlay és panel ─────────────────────────────────────── */
  .auth-modal {
    position: fixed;
    inset: 0;
    z-index: 1000;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: var(--space-4);
    pointer-events: none;
    visibility: hidden;
  }

  .auth-modal[aria-hidden="false"] {
    pointer-events: auto;
    visibility: visible;
  }

  .auth-modal__overlay {
    position: absolute;
    inset: 0;
    background: rgb(0 0 0 / 0.5);
    opacity: 0;
    transition: opacity var(--motion-base) var(--ease);
  }

  .auth-modal[aria-hidden="false"] .auth-modal__overlay {
    opacity: 1;
  }

  .auth-modal__panel {
    position: relative;
    width: 100%;
    max-width: 480px;
    max-height: calc(100vh - 2 * var(--space-4));
    background: var(--mona-bg);
    border: 0.5px solid var(--mona-border);
    box-shadow: 0 12px 48px rgb(44 41 38 / 0.18);
    overflow-y: auto;
    overflow-x: hidden;
    transform: translateY(20px);
    opacity: 0;
    transition: transform var(--motion-base) var(--ease),
                opacity var(--motion-base) var(--ease);
  }

  .auth-modal[aria-hidden="false"] .auth-modal__panel {
    transform: translateY(0);
    opacity: 1;
  }

  /* ─── Close button ─────────────────────────────────────────────────────── */
  .auth-modal__close {
    position: absolute;
    top: var(--space-3);
    right: var(--space-3);
    z-index: 10;
    width: 36px;
    height: 36px;
    min-height: 0;
    padding: 0;
    border: none;
    background: transparent;
    color: var(--mona-text-2);
