---
// src/components/common/NewsletterForm.astro
// Hírlevél feliratkozás — Mailchimp double opt-in flow
---

<section class="newsletter section-sm" id="newsletter">
  <div class="container">
    <div class="newsletter__inner">

      <div class="newsletter__content">
        <p class="eyebrow newsletter__kicker">Mónika havi naplója</p>
        <h2 class="newsletter__title">Bőrápolás, közvetlenül tőlem</h2>
        <p class="newsletter__blurb">
          Havonta egyszer beszélek arról ami épp aktuális: bőrtípusra
          szabott tanácsok, kezelés ajánlások, egy-egy új termék amit
          kipróbáltam. Alkalmanként próbatermékkel vagy kedvezménnyel.
        </p>
        <p class="newsletter__blurb newsletter__blurb--small">
          Csak email cím kell — és mindig leiratkozhatsz.
        </p>
      </div>

      <form class="newsletter__form" data-newsletter-form>
        <label for="newsletter-email" class="sr-only">Email cím</label>
        <input
          type="email"
          id="newsletter-email"
          name="email"
          inputmode="email"
          autocomplete="email"
          placeholder="email@cím.hu"
          required
        >
        <button type="submit" class="btn btn-primary">
          <span data-newsletter-text>Igen, küldd a naplót</span>
        </button>
        <p class="newsletter__notice">
          Az emailcímet csak a havi naplóhoz használjuk. Bármikor leiratkozhatsz.
        </p>
        <div class="newsletter__feedback" data-newsletter-feedback hidden></div>
      </form>

    </div>
  </div>
</section>

<style>
.newsletter {
  background: var(--mona-surface);
  border-block: 0.5px solid var(--mona-border);
}

.newsletter__inner {
  display: grid;
  grid-template-columns: 1fr;
  gap: var(--space-6);
  max-width: var(--container-lg);
  margin-inline: auto;
  align-items: center;
}

@media (min-width: 768px) {
  .newsletter__inner {
    grid-template-columns: 1fr 1fr;
    gap: var(--space-10);
  }
}

.newsletter__kicker {
  margin-bottom: var(--space-3);
  color: var(--mona-warm);
}

.newsletter__title {
  font-family: var(--mona-serif);
  font-size: clamp(1.75rem, 3vw + 1rem, 2.5rem);
  margin-bottom: var(--space-3);
  color: var(--mona-text);
  line-height: 1.15;
}

.newsletter__blurb {
  font-size: 15px;
  line-height: 1.65;
  color: var(--mona-text-2);
  max-width: 480px;
  margin: 0;
}

.newsletter__blurb--small {
  font-size: 13px;
  margin-top: var(--space-2);
  opacity: 0.8;
}

.newsletter__form {
  display: flex;
  flex-direction: column;
  gap: var(--space-3);
}

.newsletter__form input {
  background: var(--mona-elevated);
  font-size: 15px;
  padding: 14px 16px;
}

.newsletter__form .btn {
  padding: 14px 24px;
  font-size: 14px;
}

@media (min-width: 480px) {
  .newsletter__form {
    flex-direction: row;
    flex-wrap: wrap;
    align-items: flex-start;
  }
  .newsletter__form input {
    flex: 1;
    min-width: 0;
  }
  .newsletter__form .btn {
    flex-shrink: 0;
  }
  .newsletter__form .newsletter__notice,
  .newsletter__form .newsletter__feedback {
    flex: 1 0 100%;
  }
}

.newsletter__notice {
  font-size: 12px;
  color: var(--mona-text-3);
  margin: 0;
  line-height: 1.5;
}

.newsletter__feedback {
  font-size: 13px;
  padding: 12px 14px;
  border-left: 2px solid var(--mona-success);
  background: rgba(90, 107, 90, 0.08);
  color: var(--mona-text);
}

.newsletter__feedback[data-feedback-type="error"] {
  border-left-color: var(--mona-error);
  background: rgba(166, 66, 54, 0.06);
}

.newsletter__feedback[hidden] { display: none; }
</style>

<script>
  const form = document.querySelector<HTMLFormElement>("[data-newsletter-form]");
  const text = document.querySelector<HTMLSpanElement>("[data-newsletter-text]");
  const feedback = document.querySelector<HTMLDivElement>("[data-newsletter-feedback]");

  const btnLabelDefault = "Igen, küldd a naplót";

  if (form && text && feedback) {
    form.addEventListener("submit", async (e) => {
      e.preventDefault();
      const data = new FormData(form);
      const email = data.get("email")?.toString().trim() ?? "";

      if (!email || !/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(email)) {
        feedback.textContent = "Kérjük, érvényes email címet adj meg.";
        feedback.dataset.feedbackType = "error";
        feedback.removeAttribute("hidden");
        return;
      }

      const submitBtn = form.querySelector<HTMLButtonElement>("button[type='submit']");
      if (submitBtn) submitBtn.disabled = true;
      text.textContent = "Feldolgozás…";
      feedback.setAttribute("hidden", "");

      try {
        const res = await fetch("/api/newsletter/subscribe", {
          method: "POST",
          headers: { "Content-Type": "application/json" },
          body: JSON.stringify({ email, source: "website-footer" }),
        });
        const result = await res.json();

        if (!res.ok) throw new Error(result.error || "Sikertelen feliratkozás");

        // ── Siker ──
        feedback.textContent = "Köszönjük! A megerősítő emailt elküldtük.";
        feedback.dataset.feedbackType = "success";
        feedback.removeAttribute("hidden");
        form.reset();
        text.textContent = btnLabelDefault;
      } catch (err: any) {
        feedback.textContent = err.message || "Hiba történt. Próbáld újra később!";
        feedback.dataset.feedbackType = "error";
        feedback.removeAttribute("hidden");
        text.textContent = btnLabelDefault;
      } finally {
        if (submitBtn) submitBtn.disabled = false;
      }
    });
  }
</script>
