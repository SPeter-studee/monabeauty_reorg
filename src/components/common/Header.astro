---
// src/components/common/Header.astro — UPDATED v1.1
// Sprint 2A javítások:
// - Scroll direction logika (lefelé scroll → header eltűnik)
// - iOS-kompatibilis mobile menu scroll lock
// - Hover state csak hover-képes eszközön

import { getTranslations } from "@/i18n/utils";
import UserMenu from "@/components/auth/UserMenu.astro";

interface Props {
  currentPath?: string;
  locale?: "hu" | "en";
}

const { currentPath = Astro.url.pathname, locale = "hu" } = Astro.props;
const t = getTranslations(locale);

const navItems = [
  { href: "/szolgaltatasok",   label: t.nav.services },
  { href: "/webshop",          label: t.nav.shop },
  { href: "/blog",             label: t.nav.blog },
  { href: "/galeria",          label: t.nav.gallery },
  { href: "/velemenyek",       label: t.nav.reviews },
  { href: "/rolam",            label: t.nav.about },
];

const isActive = (href: string) =>
  currentPath === href || currentPath.startsWith(href + "/");
---

<header class="site-header" data-site-header data-scroll-direction="up">
  <div class="container site-header__inner">

    <a href="/" class="site-header__logo" aria-label="Mona Studio főoldal">
      <span class="site-header__logo-name">Mona Studio</span>
      <span class="site-header__logo-tagline">A szépség benned van</span>
    </a>

    <nav class="site-header__nav" aria-label="Főnavigáció">
      {navItems.map(item => (
        <a
          href={item.href}
          class="site-header__nav-link"
          aria-current={isActive(item.href) ? "page" : undefined}
        >
          {item.label}
        </a>
      ))}
    </nav>

    <div class="site-header__actions">

      <a href="/idopontfoglalas" class="btn btn-secondary btn-sm hide-tablet">
        {t.nav.book}
      </a>

      <div class="lang-switcher" aria-label="Nyelvválasztó">
        <a href="/" class={locale === "hu" ? "active" : ""}>HU</a>
        <span aria-hidden="true">·</span>
        <a href="/en/" class={locale === "en" ? "active" : ""}>EN</a>
      </div>

      <a href="/kosar" class="site-header__action" aria-label="Kosár megnyitása" data-cart-trigger>
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" aria-hidden="true">
          <path d="M6 2L3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4z" stroke-linecap="round" stroke-linejoin="round"/>
          <line x1="3" y1="6" x2="21" y2="6" stroke-linecap="round"/>
          <path d="M16 10a4 4 0 0 1-8 0" stroke-linecap="round"/>
        </svg>
        <span class="site-header__cart-count" data-cart-count hidden></span>
      </a>

      <div class="site-header__account-wrap" data-auth-trigger-wrap>
        <button
          type="button"
          class="site-header__action"
          aria-label="Belépés"
          data-auth-trigger
          aria-expanded="false"
          aria-haspopup="menu"
        >
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" aria-hidden="true">
            <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2" stroke-linecap="round" stroke-linejoin="round"/>
            <circle cx="12" cy="7" r="4" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </button>

        <UserMenu />
      </div>

      <button
        class="site-header__action site-header__hamburger"
        aria-label="Menü megnyitása"
        aria-expanded="false"
        aria-controls="mobile-menu"
        data-mobile-menu-toggle
      >
        <svg class="site-header__hamburger-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" aria-hidden="true">
          <line x1="3" y1="12" x2="21" y2="12" stroke-linecap="round"/>
          <line x1="3" y1="6" x2="21" y2="6" stroke-linecap="round"/>
          <line x1="3" y1="18" x2="21" y2="18" stroke-linecap="round"/>
        </svg>
        <svg class="site-header__close-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" aria-hidden="true">
          <line x1="18" y1="6" x2="6" y2="18" stroke-linecap="round"/>
          <line x1="6" y1="6" x2="18" y2="18" stroke-linecap="round"/>
        </svg>
      </button>

    </div>
  </div>

  <!-- Mobile dropdown overlay (v0.7.8) — a header alól nyílik le, a tartalom fölé esik -->
  <div class="mobile-menu" id="mobile-menu" data-mobile-menu data-open="false" aria-hidden="true">
    <nav class="mobile-menu__nav" aria-label="Mobil menü">
      {navItems.map(item => (
        <a href={item.href} aria-current={isActive(item.href) ? "page" : undefined}>
          {item.label}
        </a>
      ))}
    </nav>

    <div class="mobile-menu__footer">
      <a href="/idopontfoglalas" class="btn btn-primary mobile-menu__cta">
        {t.nav.book}
      </a>

      <div class="mobile-menu__social">
        <a
          href="https://www.facebook.com/monastudiovac"
          target="_blank"
          rel="noopener"
          aria-label="Facebook"
        >
          <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true" width="20" height="20">
            <path d="M9.198 21.5h4v-8.01h3.604l.396-3.98h-4V7.5a1 1 0 0 1 1-1h3v-4h-3a5 5 0 0 0-5 5v2.01h-2l-.396 3.98h2.396v8.01z"/>
          </svg>
          <span>Facebook</span>
        </a>
        <a
          href="https://www.instagram.com/monastudiovac/"
          target="_blank"
          rel="noopener"
          aria-label="Instagram"
        >
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" aria-hidden="true" width="20" height="20">
            <rect x="2" y="2" width="20" height="20" rx="5" ry="5"/>
            <path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"/>
            <line x1="17.5" y1="6.5" x2="17.51" y2="6.5"/>
          </svg>
          <span>Instagram</span>
        </a>
      </div>

      <div class="mobile-menu__contact">
        <a href="tel:+36209130126">+36 20 913 0126</a>
        <a href="mailto:mona@monastudio.hu">mona@monastudio.hu</a>
        <a
          href="https://maps.app.goo.gl/NrsyJ4eyMPsZCkUn6"
          target="_blank"
          rel="noopener"
          aria-label="Mona Studio Google Maps profil"
        >2600 Vác, Zrínyi Miklós u. 3.</a>
      </div>
    </div>
  </div>

  <!-- Backdrop (csak akkor látszik ha a menü nyitva van) -->
  <div class="mobile-menu-backdrop" data-mobile-menu-backdrop hidden></div>
</header>

<script>
  // ── Cart icon — drawer nyitás + counter sync (Sprint 3.3) ─────────────────
  import { getCartCount, openCartDrawer } from "@/lib/cart";

  // ── Sprint 4.2 — Auth state (top-level static import) ────────────────────
  import {
    refreshAuthState,
    subscribeAuthState,
    openAuthModal,
    setAnonymous,
    getAuthState,
  } from "@/lib/auth-state";

  const cartTrigger = document.querySelector<HTMLAnchorElement>("[data-cart-trigger]");
  const cartCount = document.querySelector<HTMLElement>("[data-cart-count]");

  function updateCartCount() {
    if (!cartCount) return;
    const count = getCartCount();
    if (count === 0) {
      cartCount.hidden = true;
    } else {
      cartCount.hidden = false;
      cartCount.textContent = String(count);
    }
  }

  // Click handler: ne navigáljon a /kosar-ra, hanem nyissa meg a drawer-t
  cartTrigger?.addEventListener("click", (e) => {
    // Ctrl/Cmd-klikk vagy középső gomb — engedjük a navigációt (új fül)
    if ((e as MouseEvent).ctrlKey || (e as MouseEvent).metaKey || (e as MouseEvent).button === 1) {
      return;
    }
    e.preventDefault();
    openCartDrawer();
  });

  window.addEventListener("mona-cart-update", updateCartCount);
  window.addEventListener("storage", updateCartCount);

  // Initial render
  updateCartCount();

  // ── Mobile menu scroll lock (iOS Safari kompatibilis) ────────────────────
  const menu = document.querySelector<HTMLDivElement>("[data-mobile-menu]");
  const toggleBtn = document.querySelector<HTMLButtonElement>("[data-mobile-menu-toggle]");
  const backdrop = document.querySelector<HTMLDivElement>("[data-mobile-menu-backdrop]");

  let savedScrollY = 0;

  const lockBodyScroll = () => {
    savedScrollY = window.scrollY;
    document.body.style.position = "fixed";
    document.body.style.top = `-${savedScrollY}px`;
    document.body.style.width = "100%";
    document.body.dataset.scrollLocked = "true";
  };

  const unlockBodyScroll = () => {
    document.body.style.position = "";
    document.body.style.top = "";
    document.body.style.width = "";
    document.body.dataset.scrollLocked = "false";
    window.scrollTo(0, savedScrollY);
  };

  const openMenu = () => {
    menu?.setAttribute("data-open", "true");
    menu?.setAttribute("aria-hidden", "false");
    toggleBtn?.setAttribute("aria-expanded", "true");
    toggleBtn?.setAttribute("aria-label", "Menü bezárása");
    if (backdrop) backdrop.hidden = false;
    lockBodyScroll();

    // Focus első link-re az accessibility-hez
    setTimeout(() => {
      menu?.querySelector<HTMLAnchorElement>(".mobile-menu__nav a")?.focus();
    }, 50);
  };

  const closeMenu = () => {
    menu?.setAttribute("data-open", "false");
    menu?.setAttribute("aria-hidden", "true");
    toggleBtn?.setAttribute("aria-expanded", "false");
    toggleBtn?.setAttribute("aria-label", "Menü megnyitása");
    if (backdrop) backdrop.hidden = true;
    unlockBodyScroll();
    toggleBtn?.focus();
  };

  // Hamburger maga vált hamburger → X között (egy gomb, két állapot)
  toggleBtn?.addEventListener("click", () => {
    if (menu?.getAttribute("data-open") === "true") {
      closeMenu();
    } else {
      openMenu();
    }
  });

  // Backdrop kattintás bezárja
  backdrop?.addEventListener("click", closeMenu);

  // Menü link kattintás után automatikusan bezárja
  menu?.querySelectorAll<HTMLAnchorElement>(".mobile-menu__nav a").forEach((link) => {
    link.addEventListener("click", closeMenu);
  });

  document.addEventListener("keydown", e => {
    if (e.key === "Escape" && menu?.getAttribute("data-open") === "true") {
      closeMenu();
    }
  });

  // Ha a viewport átmegy desktop-ra (>= 1024px) miközben a menü nyitva van, zárjuk
  const desktopMq = window.matchMedia("(min-width: 1024px)");
  desktopMq.addEventListener("change", (e) => {
    if (e.matches && menu?.getAttribute("data-open") === "true") {
      closeMenu();
    }
  });

  // ── Header scroll direction logika ───────────────────────────────────────
  const header = document.querySelector<HTMLElement>("[data-site-header]");
  let lastScroll = 0;
  let ticking = false;

  window.addEventListener("scroll", () => {
    if (ticking) return;
    requestAnimationFrame(() => {
      const current = window.scrollY;
      const direction = current > lastScroll && current > 100 ? "down" : "up";
      header?.setAttribute("data-scroll-direction", direction);
      lastScroll = Math.max(0, current);
      ticking = false;
    });
    ticking = true;
  }, { passive: true });

  // ── Sprint 4.2 — Auth integráció ──────────────────────────────────────────
  (() => {
    const authTrigger = document.querySelector<HTMLButtonElement>("[data-auth-trigger]");
    const authTriggerWrap = document.querySelector<HTMLElement>("[data-auth-trigger-wrap]");
    const userMenu = document.querySelector<HTMLElement>("[data-user-menu]");
    const userGreeting = document.querySelector<HTMLElement>("[data-user-greeting]");
    const userEmail = document.querySelector<HTMLElement>("[data-user-email]");
    const logoutBtn = document.querySelector<HTMLButtonElement>("[data-logout-btn]");

    if (!authTrigger || !authTriggerWrap || !userMenu) return;

    let menuOpen = false;

    // Initial load — server check
    refreshAuthState();

    // Subscribe — minden auth állapot változás-on frissít
    subscribeAuthState((state) => {
      if (state.status === "authenticated" && state.customer) {
        // Logged-in mód
        const greetingName = state.customer.firstName || "Vendég";
        authTrigger.setAttribute("aria-label", `${greetingName} — menü`);
        authTrigger.setAttribute("data-authenticated", "true");
        if (userGreeting) userGreeting.textContent = `Üdv, ${greetingName}!`;
        if (userEmail) userEmail.textContent = state.customer.email;
      } else {
        // Anonymous — modal nyitja
        authTrigger.setAttribute("aria-label", "Belépés");
        authTrigger.removeAttribute("data-authenticated");
        closeMenu();
      }
    });

    // Trigger gomb kattintás
    authTrigger.addEventListener("click", (e) => {
      e.stopPropagation();
      const state = getAuthState();
      if (state.status === "authenticated") {
        // Toggle menu
        if (menuOpen) {
          closeMenu();
        } else {
          openMenu();
        }
      } else {
        // Modal nyitás
        openAuthModal("login");
      }
    });

    // Click outside — menu close
    document.addEventListener("click", (e) => {
      if (menuOpen && authTriggerWrap && !authTriggerWrap.contains(e.target as Node)) {
        closeMenu();
      }
    });

    // Esc-re close
    document.addEventListener("keydown", (e) => {
      if (e.key === "Escape" && menuOpen) closeMenu();
    });

    function openMenu() {
      userMenu!.hidden = false;
      authTrigger!.setAttribute("aria-expanded", "true");
      menuOpen = true;
    }

    function closeMenu() {
      userMenu!.hidden = true;
      authTrigger!.setAttribute("aria-expanded", "false");
      menuOpen = false;
    }

    // Logout
    logoutBtn?.addEventListener("click", async () => {
      try {
        await fetch("/api/auth/logout", {
          method: "POST",
          credentials: "include",
        });
      } catch (err) {
        console.warn("[header] logout request failed:", err);
      }
      setAnonymous();
      closeMenu();
    });
  })();
</script>

<style>
  /* ── Header scroll direction (Sprint 2A új) ────────────────────────── */
  .site-header {
    transition: transform 200ms var(--ease);
    will-change: transform;
  }

  .site-header[data-scroll-direction="down"] {
    transform: translateY(-100%);
  }

  .site-header[data-scroll-direction="up"] {
    transform: translateY(0);
  }
</style>
