---
// src/components/common/ContactForm.astro
// Kapcsolat form Resend API-n keresztül
---

<form class="contact-form" data-contact-form>

  <div class="contact-form__row">
    <div>
      <label for="contact-name">Neved</label>
      <input
        type="text"
        id="contact-name"
        name="name"
        autocomplete="name"
        required
        minlength="2"
      >
    </div>
    <div>
      <label for="contact-email">Email</label>
      <input
        type="email"
        id="contact-email"
        name="email"
        inputmode="email"
        autocomplete="email"
        required
      >
    </div>
  </div>

  <div>
    <label for="contact-phone">Telefon (opcionális)</label>
    <input
      type="tel"
      id="contact-phone"
      name="phone"
      inputmode="tel"
      autocomplete="tel"
    >
  </div>

  <div>
    <label for="contact-subject">Téma</label>
    <select id="contact-subject" name="subject" required>
      <option value="">Válassz...</option>
      <option value="Kezeléssel kapcsolatos kérdés">Kezeléssel kapcsolatos kérdés</option>
      <option value="Időpontfoglalás">Időpontfoglalás</option>
      <option value="Webshop / termék kérdés">Webshop / termék kérdés</option>
      <option value="Egyéb">Egyéb</option>
    </select>
  </div>

  <div>
    <label for="contact-message">Üzenet</label>
    <textarea
      id="contact-message"
      name="message"
      required
      minlength="10"
      rows="6"
    ></textarea>
  </div>

  <div class="contact-form__consent">
    <label class="contact-form__checkbox">
      <input type="checkbox" name="consent" required>
      <span>
        Elolvastam és elfogadom az <a href="/adatvedelem">adatkezelési tájékoztatót</a>.
      </span>
    </label>
  </div>

  <button type="submit" class="btn btn-primary" data-contact-submit>
    <span data-contact-text>Üzenet küldése</span>
  </button>

  <div class="contact-form__feedback" data-contact-feedback hidden></div>

</form>

<style>
.contact-form {
  display: grid;
  gap: var(--space-4);
}

.contact-form__row {
  display: grid;
  grid-template-columns: 1fr;
  gap: var(--space-4);
}

@media (min-width: 640px) {
  .contact-form__row {
    grid-template-columns: 1fr 1fr;
  }
}

.contact-form__consent {
  margin-top: var(--space-2);
}

.contact-form__checkbox {
  display: flex;
  align-items: flex-start;
  gap: var(--space-2);
  cursor: pointer;
  font-size: 13px;
  color: var(--mona-text-2);
  line-height: 1.5;
  text-transform: none;
  letter-spacing: 0;
  font-weight: 400;
}

.contact-form__checkbox input {
  width: auto;
  min-height: auto;
  margin-top: 3px;
  accent-color: var(--mona-nature);
}

.contact-form__checkbox a {
  color: var(--mona-text);
  text-decoration: underline;
  text-underline-offset: 2px;
}

.contact-form__feedback {
  font-size: 14px;
  padding: var(--space-3) var(--space-4);
  border-left: 2px solid var(--mona-success);
  background: rgba(90, 107, 90, 0.08);
}

.contact-form__feedback[data-feedback-type="error"] {
  border-left-color: var(--mona-error);
  background: rgba(166, 66, 54, 0.06);
}

.contact-form__feedback[hidden] { display: none; }
</style>

<script>
  const form = document.querySelector<HTMLFormElement>("[data-contact-form]");
  const submitBtn = document.querySelector<HTMLButtonElement>("[data-contact-submit]");
  const text = document.querySelector<HTMLSpanElement>("[data-contact-text]");
  const feedback = document.querySelector<HTMLDivElement>("[data-contact-feedback]");

  if (form && submitBtn && text && feedback) {
    form.addEventListener("submit", async (e) => {
      e.preventDefault();
      const data = new FormData(form);
      const payload = {
        name: data.get("name")?.toString().trim(),
        email: data.get("email")?.toString().trim(),
        phone: data.get("phone")?.toString().trim() || undefined,
        subject: data.get("subject")?.toString(),
        message: data.get("message")?.toString().trim(),
        consent: data.get("consent") === "on",
      };

      submitBtn.disabled = true;
      text.textContent = "Küldés…";
      feedback.setAttribute("hidden", "");

      try {
        const res = await fetch("/api/contact", {
          method: "POST",
          headers: { "Content-Type": "application/json" },
          body: JSON.stringify(payload),
        });
        const result = await res.json();
        if (!res.ok) throw new Error(result.error || "Hiba történt");

        feedback.textContent = "Köszönjük! Az üzeneted megérkezett, hamarosan válaszolok.";
        feedback.dataset.feedbackType = "success";
        feedback.removeAttribute("hidden");
        form.reset();
        text.textContent = "Üzenet küldése";
      } catch (err: any) {
        feedback.textContent = err.message || "Hiba történt. Próbáld újra később!";
        feedback.dataset.feedbackType = "error";
        feedback.removeAttribute("hidden");
        text.textContent = "Üzenet küldése";
      } finally {
        submitBtn.disabled = false;
      }
    });
  }
</script>
