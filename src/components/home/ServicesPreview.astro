---
// src/components/home/ServicesPreview.astro
// Főoldali szolgáltatás bemutatás — featured: true szolgáltatások (max 4)

import { getCollection } from "astro:content";
import ServiceCard from "@/components/services/ServiceCard.astro";

const allServices = await getCollection("services");
const featured = allServices
  .filter(s => s.data.featured)
  .sort((a, b) => a.data.sortOrder - b.data.sortOrder)
  .slice(0, 4);
---

<section class="services-preview section">
  <div class="container">
    <div class="services-preview__intro">
      <p class="eyebrow">Kezelések</p>
      <h2 class="services-preview__title">Néhány kedvenc kezelésem</h2>
      <p class="services-preview__lead">
        Minden szolgáltatás személyre szabva — egyedi diagnózissal, prémium hatóanyagokkal.
      </p>
    </div>

    <div class="services-preview__grid">
      {featured.map(service => (
        <ServiceCard service={service} featured={false} />
      ))}
    </div>

    <div class="services-preview__cta">
      <a href="/szolgaltatasok" class="btn btn-secondary">
        Összes szolgáltatás megtekintése →
      </a>
    </div>
  </div>
</section>

<style>
.services-preview__intro {
  text-align: center;
  max-width: 680px;
  margin-inline: auto;
  margin-bottom: var(--space-10);
}

.services-preview__intro .eyebrow {
  margin-bottom: var(--space-3);
  color: var(--mona-warm);
}

.services-preview__title {
  font-family: var(--mona-serif);
  font-size: clamp(1.75rem, 3vw + 1rem, 2.5rem);
  line-height: 1.15;
  margin-bottom: var(--space-4);
  color: var(--mona-text);
}

.services-preview__lead {
  font-size: 1rem;
  line-height: 1.65;
  color: var(--mona-text-2);
}

.services-preview__grid {
  display: grid;
  grid-template-columns: 1fr;
  gap: var(--space-5);
  max-width: var(--container-xl);
  margin-inline: auto;
}

@media (min-width: 640px) {
  .services-preview__grid {
    grid-template-columns: repeat(2, 1fr);
    gap: var(--space-6);
  }
}

@media (min-width: 1024px) {
  .services-preview__grid {
    grid-template-columns: repeat(4, 1fr);
  }
}

.services-preview__cta {
  text-align: center;
  margin-top: var(--space-10);
}
</style>
