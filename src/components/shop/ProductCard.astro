---
// src/components/shop/ProductCard.astro
// Termék kártya — webshop hub és lista oldalakon
//
// Használat:
//   <ProductCard product={product} />

import type { Product } from "@/lib/types/shop";
import { effectivePrice, isOnSale, discountPercent, stockStatus } from "@/lib/types/shop";

interface Props {
  product: Product;
  /** Ha igaz, a kártya nagyobb hangsúlyt kap (pl. főoldal kiemeltek) */
  featured?: boolean;
}

const { product, featured = false } = Astro.props;

const price = effectivePrice(product);
const onSale = isOnSale(product);
const discount = discountPercent(product);
const stock = stockStatus(product);

const primaryImage = product.images?.find(img => img.isPrimary) ?? product.images?.[0];
const imageUrl = primaryImage?.url;
const imageAlt = primaryImage?.altText ?? product.name;

// Kategória oldalra kategória slug, márka slug a "tags" jelölőkhöz
const categorySlug = product.category?.slug;
const brandSlug = product.brand?.slug;

// HU-formátum forintban (1.990 Ft)
const formatPrice = (ft: number) => `${ft.toLocaleString("hu-HU")} Ft`;

const productUrl = `/webshop/termek/${product.slug}`;
---

<article class:list={["product-card", { "product-card--featured": featured }]}>
  <a href={productUrl} class="product-card__link" aria-label={`${product.name} — ${formatPrice(price)}`}>

    {/* Kép szekció — badge-ekkel */}
    <div class="product-card__image-wrap">
      {imageUrl ? (
        <img
          src={imageUrl}
          alt={imageAlt}
          class="product-card__image"
          loading="lazy"
          decoding="async"
          width="320"
          height="400"
        />
      ) : (
        <div class="product-card__image-placeholder" aria-hidden="true">
          <svg viewBox="0 0 24 24" width="40" height="40" fill="none" stroke="currentColor" stroke-width="1.2">
            <rect x="3" y="6" width="18" height="14" rx="1.5"/>
            <path d="M3 16l5-5 4 4 3-3 6 6"/>
            <circle cx="8" cy="11" r="1.5"/>
          </svg>
        </div>
      )}

      {/* Akció badge — patina arany alapon */}
      {onSale && (
        <span class="product-card__badge product-card__badge--sale">
          −{discount}%
        </span>
      )}

      {/* Új termék badge */}
      {!onSale && product.isNew && (
        <span class="product-card__badge product-card__badge--new">
          Új
        </span>
      )}

      {/* Mónika ajánlja badge — ha akció / új jelölés is van, csak akkor mutatjuk
          ha nincs más badge (a vizuális zaj ellen) */}
      {!onSale && !product.isNew && product.isRecommended && (
        <span class="product-card__badge product-card__badge--recommended">
          Mónika ajánlja
        </span>
      )}
    </div>

    {/* Tartalom */}
    <div class="product-card__content">
      {/* Márka eyebrow */}
      {product.brand && (
        <p class="product-card__brand">{product.brand.name}</p>
      )}

      {/* Termék név */}
      <h3 class="product-card__name">{product.name}</h3>

      {/* Rövid leírás — max 120 kar, kártyára optimalizált */}
      {product.shortDescription && (
        <p class="product-card__description">{product.shortDescription}</p>
      )}

      {/* Ár + méret sor */}
      <div class="product-card__bottom">
        <div class="product-card__price-wrap">
          {onSale ? (
            <>
              <span class="product-card__price product-card__price--sale">
                {formatPrice(price)}
              </span>
              <span class="product-card__price-original">
                {formatPrice(product.priceFt)}
              </span>
            </>
          ) : (
            <span class="product-card__price">{formatPrice(price)}</span>
          )}
        </div>

        {product.sizeValue && product.sizeUnit && (
          <span class="product-card__size">
            {product.sizeValue} {product.sizeUnit}
          </span>
        )}
      </div>

      {/* Készlet státusz — csak ha low/out */}
      {stock === "low_stock" && (
        <p class="product-card__stock product-card__stock--low">
          Kevés van készleten
        </p>
      )}
      {stock === "out_of_stock" && (
        <p class="product-card__stock product-card__stock--out">
          Jelenleg nincs készleten
        </p>
      )}
    </div>
  </a>
</article>

<style>
.product-card {
  background: var(--mona-elevated);
  border: 0.5px solid var(--mona-border);
  border-radius: 2px;
  overflow: hidden;
  transition: border-color var(--motion-base) var(--ease),
              transform var(--motion-base) var(--ease);
  display: flex;
  flex-direction: column;
}

@media (hover: hover) {
  .product-card:hover {
    border-color: var(--mona-warm);
    transform: translateY(-2px);
  }
}

.product-card--featured {
  background: var(--mona-bg);
}

.product-card__link {
  text-decoration: none;
  color: inherit;
  display: flex;
  flex-direction: column;
  height: 100%;
}

/* ─── Kép szekció ────────────────────────────────────────────────────────── */
.product-card__image-wrap {
  position: relative;
  aspect-ratio: 4 / 5;
  background: var(--mona-bg);
  overflow: hidden;
}

.product-card__image {
  width: 100%;
  height: 100%;
  object-fit: contain;
  padding: var(--space-5);
  transition: transform var(--motion-slow) var(--ease);
}

@media (hover: hover) {
  .product-card:hover .product-card__image {
    transform: scale(1.03);
  }
}

.product-card__image-placeholder {
  width: 100%;
  height: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
  color: var(--mona-text-3);
  opacity: 0.4;
}

/* ─── Badge-ek ───────────────────────────────────────────────────────────── */
.product-card__badge {
  position: absolute;
  top: var(--space-3);
  right: var(--space-3);
  padding: 4px 10px;
  font-family: var(--mona-sans);
  font-size: 11px;
  font-weight: 500;
  letter-spacing: 0.04em;
  text-transform: uppercase;
  border-radius: 1px;
}

.product-card__badge--sale {
  background: var(--mona-sale);
  color: var(--mona-elevated);
}

.product-card__badge--new {
  background: var(--mona-nature);
  color: var(--mona-elevated);
}

.product-card__badge--recommended {
  background: var(--mona-warm);
  color: var(--mona-elevated);
}

/* ─── Tartalom ───────────────────────────────────────────────────────────── */
.product-card__content {
  padding: var(--space-5);
  display: flex;
  flex-direction: column;
  gap: var(--space-2);
  flex: 1;
}

.product-card__brand {
  font-family: var(--mona-sans);
  font-size: 11px;
  letter-spacing: 0.08em;
  text-transform: uppercase;
  color: var(--mona-warm);
  margin: 0;
}

.product-card__name {
  font-family: var(--mona-serif);
  font-size: 20px;
  font-weight: 500;
  line-height: 1.25;
  color: var(--mona-text);
  margin: 0;
}

.product-card__description {
  font-size: 14px;
  line-height: 1.5;
  color: var(--mona-text-2);
  margin: 0;
  /* max 3 sor a kártyán — ha hosszabb, three-dot */
  display: -webkit-box;
  -webkit-line-clamp: 3;
  line-clamp: 3;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.product-card__bottom {
  margin-top: auto;
  padding-top: var(--space-3);
  display: flex;
  align-items: baseline;
  justify-content: space-between;
  gap: var(--space-3);
}

.product-card__price-wrap {
  display: flex;
  align-items: baseline;
  gap: var(--space-2);
  flex-wrap: wrap;
}

.product-card__price {
  font-family: var(--mona-serif);
  font-size: 22px;
  font-weight: 500;
  color: var(--mona-text);
}

.product-card__price--sale {
  color: var(--mona-sale);
}

.product-card__price-original {
  font-family: var(--mona-sans);
  font-size: 14px;
  color: var(--mona-text-3);
  text-decoration: line-through;
}

.product-card__size {
  font-family: var(--mona-sans);
  font-size: 12px;
  color: var(--mona-text-3);
  white-space: nowrap;
}

/* ─── Készlet jelzés ─────────────────────────────────────────────────────── */
.product-card__stock {
  font-family: var(--mona-sans);
  font-size: 12px;
  margin: var(--space-2) 0 0;
}

.product-card__stock--low {
  color: var(--mona-sale);
}

.product-card__stock--out {
  color: var(--mona-text-3);
  font-style: italic;
}
</style>
