---
// src/components/shop/ProductCard.astro
// Termék kártya — webshop hub és lista oldalakon
//
// Használat:
//   <ProductCard product={product} />
//
// v0.7.12: Quick-add gombok (ikon a sarokban + szöveges gomb az alján)

import type { Product } from "@/lib/types/shop";
import { effectivePrice, isOnSale, discountPercent, stockStatus } from "@/lib/types/shop";

interface Props {
  product: Product;
  /** Ha igaz, a kártya nagyobb hangsúlyt kap (pl. főoldal kiemeltek) */
  featured?: boolean;
}

const { product, featured = false } = Astro.props;

const price = effectivePrice(product);
const onSale = isOnSale(product);
const discount = discountPercent(product);
const stock = stockStatus(product);
const inStock = stock !== "out_of_stock";

const primaryImage = product.images?.find(img => img.isPrimary) ?? product.images?.[0];
const imageUrl = primaryImage?.url;
const imageAlt = primaryImage?.altText ?? product.name;

// Kategória oldalra kategória slug, márka slug a "tags" jelölőkhöz
const categorySlug = product.category?.slug;
const brandSlug = product.brand?.slug;

// HU-formátum forintban (1.990 Ft)
const formatPrice = (ft: number) => `${ft.toLocaleString("hu-HU")} Ft`;

const productUrl = `/webshop/termek/${product.slug}`;

// Quick-add adatok JSON-ben — a JS event handler ezt olvassa be
// Megjegyzés: az addToCart(product, qty) egy Product-szerű objektumot vár,
// ezért a teljes szükséges termék-shape-et küldjük, nem a kész CartItem mezőit.
const quickAddPayload = JSON.stringify({
  id: product.id,
  slug: product.slug,
  name: product.name,
  stockQty: product.stockQty ?? 99,
  priceFt: product.priceFt,
  salePriceFt: product.salePriceFt ?? null,
  saleStartsAt: product.saleStartsAt ?? null,
  saleEndsAt: product.saleEndsAt ?? null,
  images: imageUrl ? [{ url: imageUrl, isPrimary: true }] : [],
  brand: product.brand ? { name: product.brand.name } : null,
});
---

<article
  class:list={["product-card", { "product-card--featured": featured }]}
  data-product-card-url={productUrl}
>
  <div class="product-card__link" aria-hidden="true">

    {/* Kép szekció — badge-ekkel */}
    <div class="product-card__image-wrap">
      {imageUrl ? (
        <img
          src={imageUrl}
          alt={imageAlt}
          class="product-card__image"
          loading="lazy"
          decoding="async"
          width="320"
          height="400"
        />
      ) : (
        <div class="product-card__image-placeholder" aria-hidden="true">
          <svg viewBox="0 0 24 24" width="40" height="40" fill="none" stroke="currentColor" stroke-width="1.2">
            <rect x="3" y="6" width="18" height="14" rx="1.5"/>
            <path d="M3 16l5-5 4 4 3-3 6 6"/>
            <circle cx="8" cy="11" r="1.5"/>
          </svg>
        </div>
      )}

      {/* Akció badge — patina arany alapon */}
      {onSale && (
        <span class="product-card__badge product-card__badge--sale">
          −{discount}%
        </span>
      )}

      {/* Új termék badge */}
      {!onSale && product.isNew && (
        <span class="product-card__badge product-card__badge--new">
          Új
        </span>
      )}

    </div>

    {/* Tartalom */}
    <div class="product-card__content">
      {/* Mónika ajánlja eyebrow — a brand eyebrow felett, prominentebb pozíció */}
      {product.isRecommended && (
        <p class="product-card__recommended">
          <span class="product-card__recommended-mark" aria-hidden="true">✦</span>
          Mónika ajánlja
        </p>
      )}

      {/* Márka eyebrow */}
      {product.brand && (
        <p class="product-card__brand">{product.brand.name}</p>
      )}

      {/* Termék név */}
      <h3 class="product-card__name">{product.name}</h3>

      {/* Rövid leírás — max 120 kar, kártyára optimalizált */}
      {product.shortDescription && (
        <p class="product-card__description">{product.shortDescription}</p>
      )}

      {/* Ár + méret sor */}
      <div class="product-card__bottom">
        <div class="product-card__price-wrap">
          {onSale ? (
            <>
              <span class="product-card__price product-card__price--sale">
                {formatPrice(price)}
              </span>
              <span class="product-card__price-original">
                {formatPrice(product.priceFt)}
              </span>
            </>
          ) : (
            <span class="product-card__price">{formatPrice(price)}</span>
          )}
        </div>

        {product.sizeValue && product.sizeUnit && (
          <span class="product-card__size">
            {product.sizeValue} {product.sizeUnit}
          </span>
        )}
      </div>

      {/* Készlet státusz — csak ha low/out */}
      {stock === "low_stock" && (
        <p class="product-card__stock product-card__stock--low">
          Kevés van készleten
        </p>
      )}
      {stock === "out_of_stock" && (
        <p class="product-card__stock product-card__stock--out">
          Jelenleg nincs készleten
        </p>
      )}

      {/* Quick-add szöveges gomb — csak ha készleten van */}
      {inStock && (
        <button
          type="button"
          class="product-card__add-btn"
          data-product-card-add
          data-product-payload={quickAddPayload}
          aria-label={`${product.name} kosárba`}
        >
          Kosárba
        </button>
      )}
    </div>
  </div>

  {/* Quick-add ikon-gomb — abszolút pozícionálva, mindig látszik */}
  {inStock && (
    <button
      type="button"
      class="product-card__quick-add"
      data-product-card-add
      data-product-payload={quickAddPayload}
      aria-label={`${product.name} kosárba (gyors)`}
      title="Kosárba"
    >
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" aria-hidden="true">
        <path d="M6 2L3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4z" stroke-linecap="round" stroke-linejoin="round"/>
        <line x1="3" y1="6" x2="21" y2="6" stroke-linecap="round"/>
        <path d="M16 10a4 4 0 0 1-8 0" stroke-linecap="round"/>
      </svg>
    </button>
  )}
</article>

<script>
  import { addToCart, openCartDrawer } from "@/lib/cart";

  // ── Termékkártya navigáció + quick-add ─────────────────────────
  // A kártya egész területe kattintható (navigáció a termékoldalra),
  // KIVÉVE a quick-add gomb(ok) — azok event.stopPropagation()-vel kosárba teszik a terméket.
  document.querySelectorAll<HTMLElement>("[data-product-card-url]").forEach((card) => {
    const url = card.dataset.productCardUrl;
    if (!url) return;

    // Egész kártya kattintható navigáció
    card.addEventListener("click", (e) => {
      // Ha a klikk a quick-add gombról jött, ne navigáljunk
      const target = e.target as HTMLElement;
      if (target.closest("[data-product-card-add]")) return;

      // Ctrl/Cmd-klikk vagy középső gomb — engedjük az új fülben nyitást
      const ev = e as MouseEvent;
      if (ev.ctrlKey || ev.metaKey || ev.button === 1) {
        window.open(url, "_blank");
        return;
      }
      window.location.href = url;
    });

    // Quick-add gombok — csak a kártyán belül
    card.querySelectorAll<HTMLButtonElement>("[data-product-card-add]").forEach((btn) => {
      btn.addEventListener("click", (e) => {
        e.preventDefault();
        e.stopPropagation();

        const payloadStr = btn.dataset.productPayload;
        if (!payloadStr) return;

        try {
          const product = JSON.parse(payloadStr);
          addToCart(product, 1);

          // Vizuális feedback — kis pulzálás a gombon
          btn.classList.add("product-card__add-btn--pulse");
          setTimeout(() => btn.classList.remove("product-card__add-btn--pulse"), 400);

          // CartDrawer megnyitása
          openCartDrawer();
        } catch (err) {
          console.error("[ProductCard] addToCart parse error:", err);
        }
      });
    });
  });
</script>

<style is:global>
.product-card {
  position: relative;
  background: var(--mona-elevated);
  border: 0.5px solid var(--mona-border);
  border-radius: 2px;
  overflow: hidden;
  transition: border-color var(--motion-base) var(--ease),
              transform var(--motion-base) var(--ease);
  display: flex;
  flex-direction: column;
  cursor: pointer;
}

@media (hover: hover) {
  .product-card:hover {
    border-color: var(--mona-warm);
    transform: translateY(-2px);
  }
}

.product-card--featured {
  background: var(--mona-bg);
}

.product-card__link {
  text-decoration: none;
  color: inherit;
  display: flex;
  flex-direction: column;
  height: 100%;
}

/* ─── Kép szekció ────────────────────────────────────────────────────────── */
.product-card__image-wrap {
  position: relative;
  aspect-ratio: 4 / 5;
  background: var(--mona-bg);
  overflow: hidden;
}

.product-card__image {
  width: 100%;
  height: 100%;
  object-fit: contain;
  padding: var(--space-5);
  transition: transform var(--motion-slow) var(--ease);
}

@media (hover: hover) {
  .product-card:hover .product-card__image {
    transform: scale(1.03);
  }
}

.product-card__image-placeholder {
  width: 100%;
  height: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
  color: var(--mona-text-3);
  opacity: 0.4;
}

/* ─── Badge-ek ───────────────────────────────────────────────────────────── */
.product-card__badge {
  position: absolute;
  top: var(--space-3);
  left: var(--space-3);
  padding: 4px 10px;
  font-family: var(--mona-sans);
  font-size: 11px;
  font-weight: 500;
  letter-spacing: 0.04em;
  text-transform: uppercase;
  border-radius: 1px;
  z-index: 1;
}

.product-card__badge--sale {
  background: var(--mona-sale);
  color: var(--mona-elevated);
}

.product-card__badge--new {
  background: var(--mona-nature);
  color: var(--mona-elevated);
}

.product-card__badge--recommended {
  /* Már nem használt — a Mónika ajánlja eyebrow-ként szerepel a tartalmi blokkban */
  display: none;
}

/* Mónika ajánlja eyebrow — a tartalmi blokk tetején, a márka eyebrow felett */
.product-card__recommended {
  display: flex;
  align-items: center;
  gap: 6px;
  font-family: var(--mona-sans);
  font-size: 11px;
  letter-spacing: 0.12em;
  text-transform: uppercase;
  color: var(--mona-warm);
  margin: 0 0 var(--space-1);
  font-weight: 500;
}

.product-card__recommended-mark {
  font-size: 13px;
  line-height: 1;
}

/* ─── Tartalom ───────────────────────────────────────────────────────────── */
.product-card__content {
  padding: var(--space-5);
  display: flex;
  flex-direction: column;
  align-items: flex-start;
  gap: var(--space-2);
  flex: 1;
  text-align: left;
}

.product-card__brand {
  font-family: var(--mona-sans);
  font-size: 11px;
  letter-spacing: 0.08em;
  text-transform: uppercase;
  color: var(--mona-warm);
  margin: 0;
  text-align: left;
}

.product-card__name {
  font-family: var(--mona-serif);
  font-size: 20px;
  font-weight: 500;
  line-height: 1.25;
  color: var(--mona-text);
  margin: 0;
  text-align: left;
  /* Ha a quick-add ikon a jobb felső sarokban van (38+8+8 = 54px),
     a hosszú nevek ne csússzanak alá vizuálisan */
  padding-right: var(--space-2);
}

.product-card__description {
  font-size: 14px;
  line-height: 1.5;
  color: var(--mona-text-2);
  margin: 0;
  text-align: left;
  /* max 3 sor a kártyán — ha hosszabb, three-dot */
  display: -webkit-box;
  -webkit-line-clamp: 3;
  line-clamp: 3;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.product-card__bottom {
  margin-top: auto;
  padding-top: var(--space-3);
  display: flex;
  align-items: baseline;
  justify-content: flex-start;
  gap: var(--space-3);
  flex-wrap: wrap;
  width: 100%;
}

.product-card__price-wrap {
  display: flex;
  align-items: baseline;
  gap: var(--space-2);
  flex-wrap: wrap;
}

.product-card__price {
  font-family: var(--mona-serif);
  font-size: 22px;
  font-weight: 500;
  color: var(--mona-text);
}

.product-card__price--sale {
  color: var(--mona-sale);
}

.product-card__price-original {
  font-family: var(--mona-sans);
  font-size: 14px;
  color: var(--mona-text-3);
  text-decoration: line-through;
}

.product-card__size {
  font-family: var(--mona-sans);
  font-size: 12px;
  color: var(--mona-text-3);
  white-space: nowrap;
}

/* ─── Készlet jelzés ─────────────────────────────────────────────────────── */
.product-card__stock {
  font-family: var(--mona-sans);
  font-size: 12px;
  margin: var(--space-2) 0 0;
  text-align: left;
  width: 100%;
}

.product-card__stock--low {
  color: var(--mona-sale);
}

.product-card__stock--out {
  color: var(--mona-text-3);
  font-style: italic;
}

/* ─── Quick-add: ikon-gomb a kártya jobb felső sarkán ──────────────────────── */
.product-card__quick-add {
  position: absolute;
  top: var(--space-3);
  right: var(--space-3);
  z-index: 2;
  width: 38px;
  height: 38px;
  min-height: 0;
  padding: 0;
  border: 0.5px solid var(--mona-border);
  background: var(--mona-elevated);
  color: var(--mona-text);
  cursor: pointer;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 50%;
  transition: background var(--motion-fast) var(--ease),
              border-color var(--motion-fast) var(--ease),
              transform var(--motion-fast) var(--ease);
  box-shadow: 0 1px 4px rgb(0 0 0 / 0.06);
}

.product-card__quick-add svg {
  width: 18px;
  height: 18px;
  stroke-width: 1.5;
  flex-shrink: 0;
}

@media (hover: hover) {
  .product-card__quick-add:hover {
    background: var(--mona-warm);
    border-color: var(--mona-warm);
    color: var(--mona-elevated);
    transform: scale(1.05);
  }
}

.product-card__quick-add:active {
  transform: scale(0.95);
}

/* ─── Quick-add: szöveges "Kosárba" gomb a kártya alján ─────────────────── */
.product-card__add-btn {
  display: block;
  width: 100%;
  margin-top: var(--space-3);
  padding: 10px var(--space-4);
  min-height: 0;
  background: transparent;
  border: 0.5px solid var(--mona-text);
  color: var(--mona-text);
  font-family: var(--mona-sans);
  font-size: 12px;
  letter-spacing: 0.12em;
  text-transform: uppercase;
  text-align: left;
  cursor: pointer;
  transition: background var(--motion-fast) var(--ease),
              color var(--motion-fast) var(--ease),
              border-color var(--motion-fast) var(--ease);
}

@media (hover: hover) {
  .product-card__add-btn:hover {
    background: var(--mona-text);
    color: var(--mona-elevated);
  }
}

.product-card__add-btn:active {
  transform: scale(0.99);
}

/* Pulse animáció a sikeres kosárba tétel feedback-jéhez */
.product-card__add-btn--pulse,
.product-card__quick-add.product-card__add-btn--pulse {
  animation: mona-card-pulse 400ms var(--ease);
}

@keyframes mona-card-pulse {
  0%   { transform: scale(1); }
  50%  { transform: scale(1.05); background: var(--mona-warm); color: var(--mona-elevated); border-color: var(--mona-warm); }
  100% { transform: scale(1); }
}
</style>
