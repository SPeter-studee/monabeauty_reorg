---
// src/components/shop/CartDrawer.astro
// Oldalsó kosár panel — minden oldalon elérhető
// Beemelve a BaseLayout footer után

// Nincsenek props — a komponens client-side reaktív
---

<div class="cart-drawer" data-cart-drawer aria-hidden="true">
  <div class="cart-drawer__backdrop" data-cart-drawer-close></div>

  <aside
    class="cart-drawer__panel"
    role="dialog"
    aria-label="Kosár"
    aria-modal="true"
  >
    <header class="cart-drawer__header">
      <h2 class="cart-drawer__title">Kosár</h2>
      <button
        type="button"
        class="cart-drawer__close"
        data-cart-drawer-close
        aria-label="Kosár bezárása"
      >
        <svg viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="1.5">
          <path d="M6 6l12 12M6 18L18 6"/>
        </svg>
      </button>
    </header>

    <div class="cart-drawer__body" data-cart-drawer-body>
      {/* Tartalom client-side render */}
      <div class="cart-drawer__empty" data-cart-empty>
        <svg viewBox="0 0 24 24" width="48" height="48" fill="none" stroke="currentColor" stroke-width="1">
          <path d="M3 3h2l3.6 11.59a2 2 0 002 1.41h7.72a2 2 0 002-1.41L23 6H6"/>
          <circle cx="9" cy="20" r="1.5"/>
          <circle cx="18" cy="20" r="1.5"/>
        </svg>
        <p class="cart-drawer__empty-title">A kosarad még üres</p>
        <p class="cart-drawer__empty-text">
          Nézz be a <a href="/webshop">webshopba</a> — Mónika ajánlásával.
        </p>
      </div>

      <ul class="cart-drawer__items" data-cart-items hidden></ul>
    </div>

    <footer class="cart-drawer__footer" data-cart-drawer-footer hidden>
      {/* Szállítási mód választó */}
      <div class="cart-shipping">
        <p class="cart-shipping__label">Szállítási mód</p>
        <div class="cart-shipping__options">
          <label class="cart-shipping__option">
            <input type="radio" name="shipping" value="foxpost" data-shipping-radio>
            <div class="cart-shipping__option-content">
              <span class="cart-shipping__option-name">FoxPost csomagautomata</span>
              <span class="cart-shipping__option-price" data-foxpost-price>1.990 Ft</span>
            </div>
          </label>
          <label class="cart-shipping__option">
            <input type="radio" name="shipping" value="personal" data-shipping-radio>
            <div class="cart-shipping__option-content">
              <span class="cart-shipping__option-name">Személyes átvétel — Vác</span>
              <span class="cart-shipping__option-price">Ingyen</span>
            </div>
          </label>
        </div>
      </div>

      {/* Összegzés */}
      <div class="cart-totals">
        <div class="cart-totals__row">
          <span>Részösszeg</span>
          <span data-cart-subtotal>0 Ft</span>
        </div>
        <div class="cart-totals__row">
          <span>Szállítás</span>
          <span data-cart-shipping>0 Ft</span>
        </div>
        <div class="cart-totals__row cart-totals__row--total">
          <span>Összesen</span>
          <span data-cart-total>0 Ft</span>
        </div>

        <div class="cart-totals__free-progress" data-free-progress hidden>
          <div class="cart-totals__free-bar">
            <div class="cart-totals__free-fill" data-free-fill></div>
          </div>
          <p class="cart-totals__free-text" data-free-text></p>
        </div>
      </div>

      <a href="/penztar" class="btn btn-primary cart-drawer__checkout">
        Tovább a pénztárhoz →
      </a>
      <a href="/kosar" class="cart-drawer__view-cart">
        Kosár megtekintése
      </a>
    </footer>
  </aside>
</div>

<script>
  import { getCartSummary, updateQuantity, removeFromCart, setShippingMethod } from "@/lib/cart";
  import type { CartItem, ShippingMethod } from "@/lib/types/shop";
  import { FREE_SHIPPING_THRESHOLD_FT } from "@/lib/types/shop";

  const drawer = document.querySelector<HTMLElement>("[data-cart-drawer]");
  const itemsContainer = document.querySelector<HTMLUListElement>("[data-cart-items]");
  const emptyContainer = document.querySelector<HTMLElement>("[data-cart-empty]");
  const footerContainer = document.querySelector<HTMLElement>("[data-cart-drawer-footer]");

  if (!drawer || !itemsContainer || !emptyContainer || !footerContainer) {
    console.warn("CartDrawer DOM elemek nem találhatók");
  }

  // ─── Drawer nyitás / zárás ─────────────────────────────────────────────────
  function openDrawer() {
    drawer?.setAttribute("aria-hidden", "false");
    document.body.style.overflow = "hidden";
    render();
  }

  function closeDrawer() {
    drawer?.setAttribute("aria-hidden", "true");
    document.body.style.overflow = "";
  }

  document.querySelectorAll("[data-cart-drawer-close]").forEach(el => {
    el.addEventListener("click", closeDrawer);
  });

  // Esc — bezárás
  document.addEventListener("keydown", (e) => {
    if (e.key === "Escape" && drawer?.getAttribute("aria-hidden") === "false") {
      closeDrawer();
    }
  });

  // Custom events
  window.addEventListener("mona-cart-open", openDrawer);
  window.addEventListener("mona-cart-update", () => {
    if (drawer?.getAttribute("aria-hidden") === "false") render();
  });

  // ─── HU ár formázás ────────────────────────────────────────────────────────
  function formatPrice(ft: number): string {
    return `${ft.toLocaleString("hu-HU")} Ft`;
  }

  // ─── Render ────────────────────────────────────────────────────────────────
  function render() {
    const summary = getCartSummary();

    if (summary.items.length === 0) {
      // Üres kosár
      if (emptyContainer) emptyContainer.hidden = false;
      if (itemsContainer) itemsContainer.hidden = true;
      if (footerContainer) footerContainer.hidden = true;
      return;
    }

    // Vannak termékek
    if (emptyContainer) emptyContainer.hidden = true;
    if (itemsContainer) itemsContainer.hidden = false;
    if (footerContainer) footerContainer.hidden = false;

    // Tételek
    if (itemsContainer) {
      itemsContainer.innerHTML = "";
      summary.items.forEach(item => {
        const li = renderItem(item);
        itemsContainer.appendChild(li);
      });
    }

    // Összegzés
    document.querySelector("[data-cart-subtotal]")!.textContent = formatPrice(summary.subtotalFt);
    document.querySelector("[data-cart-shipping]")!.textContent =
      summary.shippingFt === 0 ? "Ingyen" : formatPrice(summary.shippingFt);
    document.querySelector("[data-cart-total]")!.textContent = formatPrice(summary.totalFt);

    // Szállítási mód radio sync
    document.querySelectorAll<HTMLInputElement>("[data-shipping-radio]").forEach(radio => {
      radio.checked = radio.value === summary.shippingMethod;
    });

    // Free shipping progress
    renderFreeShippingProgress(summary.subtotalFt);
  }

  function renderItem(item: CartItem): HTMLLIElement {
    const li = document.createElement("li");
    li.className = "cart-item";
    li.innerHTML = `
      <a href="/webshop/termek/${escapeHtml(item.slug)}" class="cart-item__image-link">
        ${item.imageUrl
          ? `<img src="${escapeAttr(item.imageUrl)}" alt="${escapeAttr(item.name)}" class="cart-item__image" loading="lazy">`
          : `<div class="cart-item__image-placeholder"></div>`
        }
      </a>
      <div class="cart-item__details">
        ${item.brandName ? `<p class="cart-item__brand">${escapeHtml(item.brandName)}</p>` : ""}
        <a href="/webshop/termek/${escapeHtml(item.slug)}" class="cart-item__name">${escapeHtml(item.name)}</a>
        <div class="cart-item__bottom">
          <div class="cart-item__qty">
            <button type="button" class="cart-item__qty-btn" data-qty-dec="${item.productId}" aria-label="Csökkentés">−</button>
            <span class="cart-item__qty-value">${item.qty}</span>
            <button type="button" class="cart-item__qty-btn" data-qty-inc="${item.productId}" ${item.qty >= item.maxQty ? "disabled" : ""} aria-label="Növelés">+</button>
          </div>
          <span class="cart-item__price">${formatPrice(item.priceAtAddFt * item.qty)}</span>
        </div>
        <button type="button" class="cart-item__remove" data-remove="${item.productId}">Eltávolítás</button>
      </div>
    `;

    // Event handlerek
    li.querySelector(`[data-qty-dec="${item.productId}"]`)?.addEventListener("click", () => {
      updateQuantity(item.productId, item.qty - 1);
    });
    li.querySelector(`[data-qty-inc="${item.productId}"]`)?.addEventListener("click", () => {
      updateQuantity(item.productId, item.qty + 1);
    });
    li.querySelector(`[data-remove="${item.productId}"]`)?.addEventListener("click", () => {
      removeFromCart(item.productId);
    });

    return li;
  }

  function renderFreeShippingProgress(subtotal: number) {
    const progress = document.querySelector<HTMLElement>("[data-free-progress]");
    const fill = document.querySelector<HTMLElement>("[data-free-fill]");
    const text = document.querySelector<HTMLElement>("[data-free-text]");
    if (!progress || !fill || !text) return;

    if (subtotal >= FREE_SHIPPING_THRESHOLD_FT) {
      progress.hidden = false;
      fill.style.width = "100%";
      text.textContent = "✓ Ingyenes szállításra jogosult!";
      text.classList.add("cart-totals__free-text--achieved");
    } else {
      progress.hidden = false;
      const percent = (subtotal / FREE_SHIPPING_THRESHOLD_FT) * 100;
      fill.style.width = `${percent}%`;
      const remaining = FREE_SHIPPING_THRESHOLD_FT - subtotal;
      text.textContent = `Még ${formatPrice(remaining)} az ingyenes szállításhoz`;
      text.classList.remove("cart-totals__free-text--achieved");
    }
  }

  // ─── Szállítási mód váltás ────────────────────────────────────────────────
  document.querySelectorAll<HTMLInputElement>("[data-shipping-radio]").forEach(radio => {
    radio.addEventListener("change", () => {
      if (radio.checked) {
        setShippingMethod(radio.value as ShippingMethod);
      }
    });
  });

  // ─── HTML escape helpers ──────────────────────────────────────────────────
  function escapeHtml(s: string): string {
    return s.replace(/[<>&"]/g, c =>
      ({ "<": "&lt;", ">": "&gt;", "&": "&amp;", '"': "&quot;" } as any)[c]
    );
  }
  function escapeAttr(s: string): string {
    return escapeHtml(s);
  }

  // Init render
  render();
</script>

<style>
.cart-drawer {
  position: fixed;
  inset: 0;
  z-index: 1000;
  visibility: hidden;
  pointer-events: none;
  transition: visibility 0s linear var(--motion-base);
  overflow: hidden;
}

.cart-drawer[aria-hidden="false"] {
  visibility: visible;
  pointer-events: auto;
  transition: visibility 0s linear 0s;
}

.cart-drawer__backdrop {
  position: absolute;
  inset: 0;
  background: rgba(44, 41, 38, 0.4);
  opacity: 0;
  transition: opacity var(--motion-base) var(--ease);
}

.cart-drawer[aria-hidden="false"] .cart-drawer__backdrop {
  opacity: 1;
}

.cart-drawer__panel {
  position: absolute;
  top: 0;
  right: 0;
  bottom: 0;
  width: 100%;
  max-width: 480px;
  background: var(--mona-bg);
  display: flex;
  flex-direction: column;
  transform: translateX(100%);
  transition: transform var(--motion-base) var(--ease);
  box-shadow: -4px 0 24px rgba(44, 41, 38, 0.1);
}

.cart-drawer[aria-hidden="false"] .cart-drawer__panel {
  transform: translateX(0);
}

.cart-drawer__header {
  padding: var(--space-5);
  border-bottom: 0.5px solid var(--mona-border);
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.cart-drawer__title {
  font-family: var(--mona-serif);
  font-size: 24px;
  font-weight: 500;
  margin: 0;
  color: var(--mona-text);
}

.cart-drawer__close {
  background: none;
  border: none;
  width: 40px;
  height: 40px;
  display: flex;
  align-items: center;
  justify-content: center;
  color: var(--mona-text-2);
  cursor: pointer;
  transition: color var(--motion-fast) var(--ease);
}

.cart-drawer__close:hover {
  color: var(--mona-text);
}

.cart-drawer__body {
  flex: 1;
  overflow-y: auto;
  padding: var(--space-5);

  /* Vékony, diszkrét scrollbar (Chrome/Edge/Safari) */
  scrollbar-width: thin;
  scrollbar-color: var(--mona-border) transparent;
}

.cart-drawer__body::-webkit-scrollbar {
  width: 6px;
}

.cart-drawer__body::-webkit-scrollbar-track {
  background: transparent;
}

.cart-drawer__body::-webkit-scrollbar-thumb {
  background: var(--mona-border);
  border-radius: 3px;
}

.cart-drawer__body::-webkit-scrollbar-thumb:hover {
  background: var(--mona-text-3);
}

/* ─── Üres állapot ─────────────────────────── */
.cart-drawer__empty {
  display: flex;
  flex-direction: column;
  align-items: center;
  text-align: center;
  padding: var(--space-10) var(--space-4);
  color: var(--mona-text-3);
}

.cart-drawer__empty svg {
  margin-bottom: var(--space-4);
  opacity: 0.4;
}

.cart-drawer__empty-title {
  font-family: var(--mona-serif);
  font-size: 22px;
  color: var(--mona-text);
  margin: 0 0 var(--space-2);
}

.cart-drawer__empty-text {
  font-size: 14px;
  color: var(--mona-text-2);
  margin: 0;
  line-height: 1.6;
}

.cart-drawer__empty-text a {
  color: var(--mona-warm);
  border-bottom: 0.5px solid var(--mona-warm);
  text-decoration: none;
}

/* ─── Cart item ────────────────────────────── */
.cart-drawer__items {
  list-style: none;
  margin: 0;
  padding: 0;
  display: flex;
  flex-direction: column;
  gap: var(--space-4);
}

.cart-item {
  display: grid;
  grid-template-columns: 80px 1fr;
  gap: var(--space-3);
  padding-bottom: var(--space-4);
  border-bottom: 0.5px solid var(--mona-border);
}

.cart-item:last-child {
  border-bottom: none;
  padding-bottom: 0;
}

.cart-item__image-link {
  display: block;
  width: 80px;
  height: 100px;       /* explicit magasság aspect-ratio helyett — fallback */
  aspect-ratio: 4 / 5;
  background: var(--mona-elevated);
  border: 0.5px solid var(--mona-border);
  overflow: hidden;
  flex-shrink: 0;
}

.cart-item__image,
.cart-item__image-placeholder {
  width: 100%;
  height: 100%;
  max-width: 80px;
  max-height: 100px;
  object-fit: contain;
  padding: var(--space-2);
  display: block;
}

.cart-item__details {
  display: flex;
  flex-direction: column;
  gap: var(--space-2);
  min-width: 0;
}

.cart-item__brand {
  font-family: var(--mona-sans);
  font-size: 10px;
  letter-spacing: 0.08em;
  text-transform: uppercase;
  color: var(--mona-warm);
  margin: 0;
}

.cart-item__name {
  font-family: var(--mona-serif);
  font-size: 16px;
  font-weight: 500;
  color: var(--mona-text);
  text-decoration: none;
  line-height: 1.3;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.cart-item__bottom {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-top: auto;
}

.cart-item__qty {
  display: flex;
  align-items: center;
  border: 0.5px solid var(--mona-border);
  background: var(--mona-elevated);
  height: 32px;
}

.cart-item__qty-btn {
  width: 28px;
  height: 100%;
  border: none;
  background: transparent;
  color: var(--mona-text-2);
  cursor: pointer;
  font-size: 14px;
}

.cart-item__qty-btn:disabled {
  opacity: 0.3;
  cursor: not-allowed;
}

.cart-item__qty-value {
  width: 30px;
  text-align: center;
  font-family: var(--mona-sans);
  font-size: 13px;
  border-inline: 0.5px solid var(--mona-border);
  height: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
}

.cart-item__price {
  font-family: var(--mona-serif);
  font-size: 16px;
  font-weight: 500;
  color: var(--mona-text);
}

.cart-item__remove {
  background: none;
  border: none;
  padding: 0;
  font-family: var(--mona-sans);
  font-size: 11px;
  color: var(--mona-text-3);
  cursor: pointer;
  text-decoration: underline;
  align-self: flex-start;
  transition: color var(--motion-fast) var(--ease);
  min-height: auto;
}

.cart-item__remove:hover {
  color: var(--mona-error);
}

/* ─── Footer ────────────────────────────────── */
.cart-drawer__footer {
  padding: var(--space-5);
  border-top: 0.5px solid var(--mona-border);
  background: var(--mona-elevated);
  display: flex;
  flex-direction: column;
  gap: var(--space-4);
}

/* CRITICAL: a hidden attribute felülírja a display:flex-et */
.cart-drawer__footer[hidden],
.cart-drawer__empty[hidden],
.cart-drawer__items[hidden] {
  display: none !important;
}

.cart-shipping__label {
  font-family: var(--mona-sans);
  font-size: 11px;
  font-weight: 600;
  letter-spacing: 0.06em;
  text-transform: uppercase;
  color: var(--mona-text-3);
  margin: 0 0 var(--space-2);
}

.cart-shipping__options {
  display: flex;
  flex-direction: column;
  gap: var(--space-2);
}

.cart-shipping__option {
  display: flex;
  align-items: center;
  gap: var(--space-3);
  padding: var(--space-3);
  border: 0.5px solid var(--mona-border);
  background: var(--mona-bg);
  cursor: pointer;
  transition: border-color var(--motion-fast) var(--ease);
}

.cart-shipping__option:has(input:checked) {
  border-color: var(--mona-warm);
}

.cart-shipping__option input {
  margin: 0;
  cursor: pointer;
  width: 18px;
  height: 18px;
  flex-shrink: 0;
  accent-color: var(--mona-warm);
}

.cart-shipping__option-content {
  display: flex;
  justify-content: space-between;
  flex: 1;
  align-items: center;
  gap: var(--space-2);
  min-width: 0;
}

.cart-shipping__option-name {
  font-family: var(--mona-sans);
  font-size: 13px;
  color: var(--mona-text);
  flex: 1;
  min-width: 0;
}

.cart-shipping__option-price {
  font-family: var(--mona-sans);
  font-size: 13px;
  color: var(--mona-text-2);
  white-space: nowrap;
  flex-shrink: 0;
}

/* ─── Totals ───────────────────────────────── */
.cart-totals {
  display: flex;
  flex-direction: column;
  gap: var(--space-2);
  padding-block: var(--space-3);
  border-block: 0.5px solid var(--mona-border);
}

.cart-totals__row {
  display: flex;
  justify-content: space-between;
  font-family: var(--mona-sans);
  font-size: 14px;
  color: var(--mona-text-2);
}

.cart-totals__row--total {
  font-family: var(--mona-serif);
  font-size: 20px;
  font-weight: 500;
  color: var(--mona-text);
  padding-top: var(--space-2);
  margin-top: var(--space-2);
  border-top: 0.5px solid var(--mona-border);
}

.cart-totals__free-progress {
  margin-top: var(--space-3);
}

.cart-totals__free-bar {
  height: 4px;
  background: var(--mona-border);
  border-radius: 2px;
  overflow: hidden;
  margin-bottom: var(--space-2);
}

.cart-totals__free-fill {
  height: 100%;
  background: var(--mona-warm);
  width: 0%;
  transition: width var(--motion-slow) var(--ease);
}

.cart-totals__free-text {
  font-family: var(--mona-sans);
  font-size: 12px;
  color: var(--mona-text-3);
  margin: 0;
}

.cart-totals__free-text--achieved {
  color: var(--mona-success);
  font-weight: 500;
}

.cart-drawer__checkout {
  width: 100%;
}

.cart-drawer__view-cart {
  text-align: center;
  font-family: var(--mona-sans);
  font-size: 13px;
  color: var(--mona-warm);
  text-decoration: none;
  border-bottom: 0.5px solid transparent;
  padding-bottom: 1px;
  transition: border-color var(--motion-fast) var(--ease);
  align-self: center;
}

.cart-drawer__view-cart:hover {
  border-bottom-color: var(--mona-warm);
}
</style>
