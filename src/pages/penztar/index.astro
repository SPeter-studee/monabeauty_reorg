---
// src/pages/penztar.astro
// Checkout oldal — vendég adatok + szállítás + fizetés + submit
//
// localStorage-ből olvassuk a kosár tartalmat, és a /api/checkout endpoint-ra
// POST-oljuk. Sikeres rendelés után átirányít a /penztar/koszonjuk?rendeles=...
// oldalra, és üríti a kosarat.

import BaseLayout from "@/layouts/BaseLayout.astro";
import PageHero from "@/components/common/PageHero.astro";
---

<BaseLayout
  title="Pénztár — Mona Studio"
  description="Rendelési adatok megadása és véglegesítés."
  noindex
>
  <PageHero
    title="Pénztár"
    breadcrumbs={[
      { label: "Főoldal", href: "/" },
      { label: "Webshop", href: "/webshop" },
      { label: "Kosár", href: "/kosar" },
      { label: "Pénztár" }
    ]}
  />

  <section class="checkout section">
    <div class="container">

      {/* Üres kosár — átirányítás */}
      <div class="checkout-empty" data-checkout-empty hidden>
        <p>A kosarad üres — vissza a webshopba.</p>
        <a href="/webshop" class="btn btn-primary">Irány a webshop →</a>
      </div>

      <div class="checkout__layout" data-checkout-content>
        {/* ─── BAL OLDAL — Form ─────────────────────────────────────── */}
        <form class="checkout__form" data-checkout-form>

          {/* Vendég adatok */}
          <div class="checkout-section">
            <div class="checkout-section__header">
              <h3 class="checkout-section__title">Vásárlói adatok</h3>
              {/* Sprint 4.5.x — Logged-in chip a fejlécben */}
              <div class="checkout-loggedin-chip" data-checkout-chip hidden>
                <svg viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                  <circle cx="12" cy="8" r="4"/>
                  <path d="M4 21c0-4 4-7 8-7s8 3 8 7"/>
                </svg>
                <span data-checkout-chip-email>—</span>
                <button type="button" class="checkout-loggedin-chip__logout" data-checkout-logout title="Kijelentkezés">
                  Kijelentkezés
                </button>
              </div>
            </div>

            {/* Welcome blokk — csak logged-in vendégeknek */}
            <div class="checkout-welcome" data-checkout-welcome hidden>
              <div class="checkout-welcome__icon" aria-hidden="true">
                <svg viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M9 12l2 2 4-4"/>
                  <circle cx="12" cy="12" r="10"/>
                </svg>
              </div>
              <div class="checkout-welcome__content">
                <strong class="checkout-welcome__title">
                  Üdv újra, <span data-checkout-welcome-name>—</span>!
                </strong>
                <p class="checkout-welcome__text">
                  Az adatokat átvettük a fiókodból. Ha másik címre szeretnéd, alább módosítsd.
                </p>
              </div>
            </div>

            <div class="form-row">
              <label class="form-field">
                <span class="form-field__label">Teljes név <span class="required">*</span></span>
                <input type="text" name="guestName" required autocomplete="name" data-checkout-name />
              </label>
            </div>

            <div class="form-row form-row--two">
              <label class="form-field">
                <span class="form-field__label">
                  Email <span class="required">*</span>
                  <span class="form-field__hint" data-checkout-email-locked hidden>(fiókod email-je)</span>
                </span>
                <input type="email" name="guestEmail" required autocomplete="email" data-checkout-email />
              </label>
              <label class="form-field">
                <span class="form-field__label">Telefon <span class="required">*</span></span>
                <input type="tel" name="guestPhone" required autocomplete="tel" placeholder="+36 ..." data-checkout-phone />
              </label>
            </div>

            <p class="form-hint">
              <strong>Miért kell a telefonszám?</strong> A FoxPost SMS-ben értesít a csomag érkezéséről.
              Személyes átvételnél Mónika telefonon hív, mikor jöhetsz érte.
            </p>
          </div>

          {/* Szállítási mód */}
          <div class="checkout-section">
            <h3 class="checkout-section__title">Szállítási mód</h3>

            <div class="shipping-options">
              <label class="shipping-option">
                <input type="radio" name="shippingMethod" value="foxpost" data-shipping-radio />
                <div class="shipping-option__content">
                  <div class="shipping-option__head">
                    <span class="shipping-option__name">FoxPost csomagautomata</span>
                    <span class="shipping-option__price" data-foxpost-price>1.990 Ft</span>
                  </div>
                  <p class="shipping-option__desc">
                    Országosan, 600+ átvevőhelyen. SMS-ben értesít.
                  </p>
                </div>
              </label>

              <label class="shipping-option">
                <input type="radio" name="shippingMethod" value="personal" data-shipping-radio />
                <div class="shipping-option__content">
                  <div class="shipping-option__head">
                    <span class="shipping-option__name">Személyes átvétel — Vác</span>
                    <span class="shipping-option__price">Ingyen</span>
                  </div>
                  <p class="shipping-option__desc">
                    Mona Studio · 2600 Vác, Zrínyi Miklós u. 3. · Egy kávé mellett.
                  </p>
                </div>
              </label>
            </div>
          </div>

          {/* Szállítási cím (csak FoxPost-nál) */}
          <div class="checkout-section" data-shipping-address-section>
            <h3 class="checkout-section__title">Szállítási cím</h3>

            {/* Sprint 4.5.3.x — Korábbi címek selector (csak ha logged-in és van mentett cím) */}
            <div class="saved-addresses" data-saved-addresses-block hidden>
              <p class="saved-addresses__label">Korábbi címek</p>
              <div class="saved-addresses__list" data-saved-addresses-list>
                {/* JS-ben renderelve */}
              </div>
            </div>

            <div class="form-row">
              <label class="form-field">
                <span class="form-field__label">Utca, házszám <span class="required">*</span></span>
                <input type="text" name="shippingAddress" autocomplete="street-address" data-shipping-address-input />
              </label>
            </div>

            <div class="form-row form-row--two">
              <label class="form-field">
                <span class="form-field__label">Irányítószám <span class="required">*</span></span>
                <input type="text" name="shippingZip" pattern="[0-9]{4}" autocomplete="postal-code" data-shipping-zip-input />
              </label>
              <label class="form-field">
                <span class="form-field__label">Város <span class="required">*</span></span>
                <input type="text" name="shippingCity" autocomplete="address-level2" data-shipping-city-input list="hu-cities-datalist" />
                <datalist id="hu-cities-datalist"></datalist>
              </label>
            </div>

            {/* Sprint 4.5.3.x — Címmentés blokk (logged-in vendégeknek)
                Két variáns:
                - Üres címkönyv (első cím): info + checkbox bekattintva default
                - Van címkönyv + új cím: csak checkbox (vendég dönti el) */}
            <div class="checkout-save-address-block" data-save-address-block hidden>
              <p class="checkout-save-address-block__info" data-save-address-info hidden>
                <svg viewBox="0 0 16 16" width="14" height="14" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                  <circle cx="8" cy="8" r="6.5"/>
                  <line x1="8" y1="11" x2="8" y2="7.5"/>
                  <circle cx="8" cy="5" r="0.5" fill="currentColor"/>
                </svg>
                <span>
                  Ez a cím <strong>automatikusan elmentődik</strong> a fiókodba sikeres rendelés után.
                  A <a href="/profil/cimek" target="_blank">profilban</a> később megtekintheted és módosíthatod.
                </span>
              </p>
              <label class="checkout-save-address">
                <input type="checkbox" name="saveAddress" data-save-address-checkbox />
                <span data-save-address-label>Mentsd a címet a fiókomba a következő rendeléshez</span>
              </label>
            </div>

            <p class="form-hint">
              <strong>FoxPost címválasztás</strong>: a rendelés feldolgozása után
              elküldjük a linket, ahol a hozzád legközelebbi automatát választhatod ki.
            </p>
          </div>

          {/* Fizetési mód */}
          <div class="checkout-section">
            <h3 class="checkout-section__title">Fizetési mód</h3>

            <div class="payment-options">
              <label class="payment-option">
                <input type="radio" name="paymentMethod" value="transfer" checked />
                <div class="payment-option__content">
                  <span class="payment-option__name">Átutalás</span>
                  <p class="payment-option__desc">
                    Az utalási adatokat emailben küldjük. A csomagot az utalás
                    megérkezése után indítjuk útnak.
                  </p>
                </div>
              </label>

              <label class="payment-option">
                <input type="radio" name="paymentMethod" value="on_delivery" />
                <div class="payment-option__content">
                  <span class="payment-option__name">Utánvét</span>
                  <p class="payment-option__desc">
                    A futárnak fizetsz amikor megérkezik a csomag.
                    <em>(+ 0 Ft, nincs felár)</em>
                  </p>
                </div>
              </label>
            </div>

            <p class="form-hint">
              Bankkártyás fizetés (SimplePay) <strong>hamarosan</strong> elérhető lesz.
            </p>
          </div>

          {/* Megjegyzés */}
          <div class="checkout-section">
            <h3 class="checkout-section__title">Megjegyzés <em>(opcionális)</em></h3>

            <label class="form-field">
              <textarea name="customerNote" rows="3" placeholder="Bármilyen kérés vagy kérdés..."></textarea>
            </label>
          </div>

          {/* GDPR */}
          <div class="checkout-section">
            <label class="form-checkbox">
              <input type="checkbox" name="gdpr" required />
              <span>
                Elolvastam és elfogadom az <a href="/aszf" target="_blank">ÁSZF</a> és
                <a href="/adatvedelem" target="_blank">Adatvédelmi tájékoztató</a> tartalmát. <span class="required">*</span>
              </span>
            </label>
          </div>

          <button
            type="submit"
            class="btn btn-primary checkout__submit"
            data-checkout-submit
          >
            <span data-submit-text>Megrendelem</span>
          </button>

          <div class="checkout__error" data-checkout-error hidden></div>
        </form>

        {/* ─── JOBB OLDAL — Összegzés (sticky) ──────────────────────── */}
        <aside class="checkout__summary">
          <h2 class="checkout__summary-title">Rendelés összegzése</h2>

          <ul class="checkout-items" data-checkout-items></ul>

          <div class="checkout-totals">
            <div class="checkout-totals__row">
              <span>Részösszeg</span>
              <span data-summary-subtotal>0 Ft</span>
            </div>
            <div class="checkout-totals__row">
              <span>Szállítás</span>
              <span data-summary-shipping>—</span>
            </div>
            <div class="checkout-totals__row checkout-totals__row--total">
              <span>Összesen</span>
              <span data-summary-total>0 Ft</span>
            </div>
          </div>
        </aside>
      </div>
    </div>
  </section>

  <script>
    import { getCartSummary, clearCart, setShippingMethod } from "@/lib/cart";
    import type { CartItem, ShippingMethod } from "@/lib/types/shop";
    import { subscribeAuthState, setAnonymous } from "@/lib/auth-state";
    import { bindZipCityAutofill } from "@/lib/utils/zip-city-lookup";

    const form = document.querySelector<HTMLFormElement>("[data-checkout-form]");
    const emptyContainer = document.querySelector<HTMLElement>("[data-checkout-empty]");
    const contentContainer = document.querySelector<HTMLElement>("[data-checkout-content]");
    const itemsContainer = document.querySelector<HTMLUListElement>("[data-checkout-items]");
    const submitBtn = document.querySelector<HTMLButtonElement>("[data-checkout-submit]");
    const submitText = document.querySelector<HTMLElement>("[data-submit-text]");
    const errorContainer = document.querySelector<HTMLElement>("[data-checkout-error]");
    const shippingAddressSection = document.querySelector<HTMLElement>("[data-shipping-address-section]");

    // Sprint 4.5.x — Logged-in checkout UX
    const checkoutChip = document.querySelector<HTMLElement>("[data-checkout-chip]");
    const checkoutChipEmail = document.querySelector<HTMLElement>("[data-checkout-chip-email]");
    const checkoutLogout = document.querySelector<HTMLButtonElement>("[data-checkout-logout]");
    const checkoutWelcome = document.querySelector<HTMLElement>("[data-checkout-welcome]");
    const checkoutWelcomeName = document.querySelector<HTMLElement>("[data-checkout-welcome-name]");
    const checkoutEmailLocked = document.querySelector<HTMLElement>("[data-checkout-email-locked]");
    const inputName = document.querySelector<HTMLInputElement>("[data-checkout-name]");
    const inputEmail = document.querySelector<HTMLInputElement>("[data-checkout-email]");
    const inputPhone = document.querySelector<HTMLInputElement>("[data-checkout-phone]");

    // Sprint 4.5.3.x — Saved addresses (logged-in vendég korábbi címei)
    const savedAddressesBlock = document.querySelector<HTMLElement>("[data-saved-addresses-block]");
    const savedAddressesList = document.querySelector<HTMLElement>("[data-saved-addresses-list]");
    const saveAddressBlock = document.querySelector<HTMLElement>("[data-save-address-block]");
    const saveAddressCheckbox = document.querySelector<HTMLInputElement>("[data-save-address-checkbox]");
    const shippingAddressInput = document.querySelector<HTMLInputElement>("[data-shipping-address-input]");
    const shippingZipInput = document.querySelector<HTMLInputElement>("[data-shipping-zip-input]");
    const shippingCityInput = document.querySelector<HTMLInputElement>("[data-shipping-city-input]");

    // State a saved addresses-szel (a render funkciókban használjuk)
    let savedAddresses: any[] = [];
    let selectedAddressId: number | null = null;

    // ── Sprint 4.5.3.x — Magyar irányítószám → település lookup ─────────
    let postcodeMap: Record<string, string> | null = null;
    let postcodeLoadAttempted = false;
    let cityManuallyEdited = false;

    async function loadPostcodes() {
      if (postcodeMap || postcodeLoadAttempted) return;
      postcodeLoadAttempted = true;
      try {
        const res = await fetch("/data/hu-postcodes.json");
        if (!res.ok) return;
        const data = await res.json();
        postcodeMap = data.codes || null;
      } catch (err) {
        console.warn("[checkout] postcode load failed:", err);
      }
    }

    function lookupPostcode(zip: string): string | null {
      if (!postcodeMap) return null;
      const trimmed = zip.trim();
      if (!/^\d{4}$/.test(trimmed)) return null;
      return postcodeMap[trimmed] || null;
    }

    // ZIP mező változásakor: lookup + auto-fill (csak ha a vendég nem írt rá manuálisan)
    shippingZipInput?.addEventListener("input", async () => {
      // Lazy-load: első írás esetén töltjük le a JSON-t
      if (!postcodeMap) await loadPostcodes();

      const zip = shippingZipInput!.value.trim();
      if (!/^\d{4}$/.test(zip)) return;

      const city = lookupPostcode(zip);
      if (!city) return;

      // Csak akkor írjuk át a város mezőt, ha a vendég nem szerkesztette manuálisan
      if (shippingCityInput && (!cityManuallyEdited || !shippingCityInput.value.trim())) {
        shippingCityInput.value = city;
        // Ne tekintse manuális edit-nek
        cityManuallyEdited = false;
      }
    });

    // City mező manual edit detection
    shippingCityInput?.addEventListener("input", () => {
      cityManuallyEdited = true;
    });

    // ── Auth state subscribe — auto-fill + chip kezelés ─────────────────
    subscribeAuthState((state) => {
      if (state.status === "authenticated" && state.customer) {
        const c = state.customer;
        const fullName = [c.firstName, c.lastName].filter(Boolean).join(" ").trim();

        // Auto-fill — csak ha az adott mező még üres (ne írjuk felül a vendég módosítását)
        if (inputName && !inputName.value && fullName) {
          inputName.value = fullName;
          inputName.classList.add("checkout-input--prefilled");
        }
        if (inputEmail && !inputEmail.value && c.email) {
          inputEmail.value = c.email;
          inputEmail.classList.add("checkout-input--prefilled");
          // Email mező: readonly logged-in vendégeknek (ne tudjon változtatni)
          inputEmail.readOnly = true;
          if (checkoutEmailLocked) checkoutEmailLocked.hidden = false;
        }
        if (inputPhone && !inputPhone.value && c.phone) {
          inputPhone.value = c.phone;
          inputPhone.classList.add("checkout-input--prefilled");
        }

        // Chip megjelenítés
        if (checkoutChip) checkoutChip.hidden = false;
        if (checkoutChipEmail) checkoutChipEmail.textContent = c.email;

        // Welcome blokk megjelenítés (csak akkor ha van név)
        if (checkoutWelcome && fullName) {
          checkoutWelcome.hidden = false;
          if (checkoutWelcomeName) checkoutWelcomeName.textContent = c.firstName || fullName;
        }

        // Sprint 4.5.3.x — Saved addresses lekérés
        loadSavedAddresses();
      } else {
        // Anonymous — minden chip rejtve
        if (checkoutChip) checkoutChip.hidden = true;
        if (checkoutWelcome) checkoutWelcome.hidden = true;
        if (inputEmail) {
          inputEmail.readOnly = false;
        }
        if (checkoutEmailLocked) checkoutEmailLocked.hidden = true;
        // Saved addresses elrejtése
        if (savedAddressesBlock) savedAddressesBlock.hidden = true;
        if (saveAddressBlock) saveAddressBlock.hidden = true;
      }
    });

    // ── Sprint 4.5.3.x — Saved addresses logika ─────────────────────────
    async function loadSavedAddresses() {
      try {
        const res = await fetch("/api/profile/addresses", { credentials: "include" });
        const data = await res.json();
        if (!res.ok || !data.success) return;

        savedAddresses = (data.addresses || []).filter((a: any) => a.isShipping);
        renderSavedAddresses();
      } catch (err) {
        console.warn("[checkout] saved addresses load failed:", err);
      }
    }

    function renderSavedAddresses() {
      if (!savedAddressesList || !savedAddressesBlock) return;

      // Save address block - mindig megjelenik logged-in vendégeknek (a save block-ot
      // a renderelés végén állítjuk be a megfelelő variánsra)

      if (savedAddresses.length === 0) {
        // ÜRES CÍMKÖNYV: nincs selector, de az "auto-mentés" info+checkbox MEGJELENIK
        savedAddressesBlock.hidden = true;
        showSaveBlockForFirstAddress();
        return;
      }

      savedAddressesBlock.hidden = false;

      // Default szállítási cím elsőként
      const sorted = [...savedAddresses].sort((a, b) => {
        if (a.isDefaultShipping && !b.isDefaultShipping) return -1;
        if (!a.isDefaultShipping && b.isDefaultShipping) return 1;
        return 0;
      });

      // Mini kártyák render
      savedAddressesList.innerHTML = sorted.map(addr => `
        <label class="saved-address-card">
          <input type="radio" name="savedAddress" value="${addr.id}" ${addr.isDefaultShipping ? "checked" : ""} />
          <div class="saved-address-card__content">
            <div class="saved-address-card__head">
              <strong class="saved-address-card__label">${escapeHtml(addr.label)}</strong>
              ${addr.isDefaultShipping ? '<span class="saved-address-card__badge">Default</span>' : ""}
            </div>
            <p class="saved-address-card__body">
              ${escapeHtml(addr.recipientName)}<br/>
              ${escapeHtml(addr.postalCode)} ${escapeHtml(addr.city)}, ${escapeHtml(addr.street)}
            </p>
          </div>
        </label>
      `).join("") + `
        <label class="saved-address-card saved-address-card--new">
          <input type="radio" name="savedAddress" value="new" />
          <div class="saved-address-card__content">
            <strong class="saved-address-card__label">+ Új cím megadása</strong>
            <p class="saved-address-card__body">A lent megadott cím használata</p>
          </div>
        </label>
      `;

      // Default selection: az első default cím auto-fill-elve
      const defaultAddr = sorted.find(a => a.isDefaultShipping);
      if (defaultAddr) {
        selectAddress(defaultAddr.id);
      }

      // Bind radio change events
      savedAddressesList.querySelectorAll<HTMLInputElement>("input[name='savedAddress']").forEach(radio => {
        radio.addEventListener("change", () => {
          const value = radio.value;
          if (value === "new") {
            selectAddress(null);
          } else {
            selectAddress(parseInt(value, 10));
          }
        });
      });

      // Watch for manual changes to address fields → check if "save" checkbox should appear
      [shippingAddressInput, shippingZipInput, shippingCityInput].forEach(input => {
        input?.addEventListener("input", checkIfNewAddressEntered);
      });
    }

    function selectAddress(addressId: number | null) {
      selectedAddressId = addressId;

      if (addressId === null) {
        // "Új cím" választva — mezők ürítése (a vendég írja be)
        if (shippingAddressInput) shippingAddressInput.value = "";
        if (shippingZipInput) shippingZipInput.value = "";
        if (shippingCityInput) shippingCityInput.value = "";
        // Save block: ha van már mentett cím → "új cím" → kis bekattolható checkbox (info nélkül)
        if (savedAddresses.length > 0) {
          showSaveBlockForExistingUser();
        } else {
          showSaveBlockForFirstAddress();
        }
      } else {
        // Mentett cím választva — mezők kitöltése + save block elrejtése (cím már megvan)
        const addr = savedAddresses.find(a => a.id === addressId);
        if (!addr) return;
        if (shippingAddressInput) shippingAddressInput.value = addr.street;
        if (shippingZipInput) shippingZipInput.value = addr.postalCode;
        if (shippingCityInput) shippingCityInput.value = addr.city;
        // Save block elrejtése — már mentett cím
        if (saveAddressBlock) saveAddressBlock.hidden = true;
      }
    }

    function showSaveBlockForFirstAddress() {
      // Üres címkönyv variáns: info látszik, checkbox bekattintva default
      if (!saveAddressBlock) return;
      saveAddressBlock.hidden = false;

      const infoEl = document.querySelector<HTMLElement>("[data-save-address-info]");
      const labelEl = document.querySelector<HTMLElement>("[data-save-address-label]");
      if (infoEl) infoEl.hidden = false;
      if (labelEl) labelEl.textContent = "Igen, mentsd el a fiókomba";
      if (saveAddressCheckbox) saveAddressCheckbox.checked = true;
    }

    function showSaveBlockForExistingUser() {
      // Van mentett cím + új cím beírás variáns: csak checkbox (info elrejtve)
      if (!saveAddressBlock) return;
      saveAddressBlock.hidden = false;

      const infoEl = document.querySelector<HTMLElement>("[data-save-address-info]");
      const labelEl = document.querySelector<HTMLElement>("[data-save-address-label]");
      if (infoEl) infoEl.hidden = true;
      if (labelEl) labelEl.textContent = "Mentsd a címet a fiókomba a következő rendeléshez";
      if (saveAddressCheckbox) saveAddressCheckbox.checked = false;
    }

    function checkIfNewAddressEntered() {
      // Ha "Új cím" mód aktív + valamit írt be → már látszik a save block
      // (a selectAddress(null)-ból). Most csak az input watching marad
      // hogy semmi nem fog elromlani — a logika a selectAddress-ben van.
      // Ezt a függvényt mostantól csak a backwards-compat miatt tartjuk.
    }

    // ── Logout a chip-ről ───────────────────────────────────────────────
    checkoutLogout?.addEventListener("click", async () => {
      if (!confirm("Biztosan kijelentkezel? A megadott adatok megmaradnak a form-on.")) return;
      try {
        await fetch("/api/auth/logout", {
          method: "POST",
          credentials: "include",
        });
      } catch (err) {
        console.warn("[checkout] logout request failed:", err);
      }
      setAnonymous();
      // Az adatokat hagyjuk a form-on (vendég úgy is továbbmehet)
    });

    function formatPrice(ft: number): string {
      return `${ft.toLocaleString("hu-HU")} Ft`;
    }

    function escapeHtml(s: string): string {
      return s.replace(/[<>&"]/g, c =>
        ({ "<": "&lt;", ">": "&gt;", "&": "&amp;", '"': "&quot;" } as any)[c]
      );
    }

    // ─── Kosár tartalom megjelenítése ──────────────────────────────
    function renderSummary() {
      const summary = getCartSummary();

      if (summary.items.length === 0) {
        if (emptyContainer) emptyContainer.hidden = false;
        if (contentContainer) contentContainer.style.display = "none";
        return;
      }

      if (emptyContainer) emptyContainer.hidden = true;
      if (contentContainer) contentContainer.style.display = "";

      // Tételek
      if (itemsContainer) {
        itemsContainer.innerHTML = "";
        summary.items.forEach(item => {
          const li = document.createElement("li");
          li.className = "checkout-item";
          li.style.cssText = "display: grid; grid-template-columns: 60px 1fr; gap: var(--space-3); align-items: center;";
          li.innerHTML = `
            <div class="checkout-item__image-wrap" style="position: relative; width: 60px; max-width: 60px; aspect-ratio: 4 / 5; background: var(--mona-bg); border: 0.5px solid var(--mona-border); flex-shrink: 0;">
              ${item.imageUrl
                ? `<img src="${escapeHtml(item.imageUrl)}" alt="${escapeHtml(item.name)}" class="checkout-item__image" style="width: 100%; height: 100%; max-width: 60px; object-fit: contain; padding: 4px; display: block;">`
                : `<div class="checkout-item__image-placeholder" style="width: 100%; height: 100%;"></div>`
              }
              <span class="checkout-item__qty">${item.qty}</span>
            </div>
            <div class="checkout-item__details" style="min-width: 0;">
              <p class="checkout-item__name">${escapeHtml(item.name)}</p>
              <p class="checkout-item__price">${formatPrice(item.priceAtAddFt * item.qty)}</p>
            </div>
          `;
          itemsContainer.appendChild(li);
        });
      }

      // Összegzés
      document.querySelector("[data-summary-subtotal]")!.textContent = formatPrice(summary.subtotalFt);
      document.querySelector("[data-summary-shipping]")!.textContent =
        summary.shippingFt === 0 ? "Ingyen" : formatPrice(summary.shippingFt);
      document.querySelector("[data-summary-total]")!.textContent = formatPrice(summary.totalFt);

      // Szállítási mód radio sync
      document.querySelectorAll<HTMLInputElement>("[data-shipping-radio]").forEach(radio => {
        radio.checked = radio.value === summary.shippingMethod;
      });

      // Szállítási cím szekció láthatóság
      if (shippingAddressSection) {
        shippingAddressSection.style.display = summary.shippingMethod === "foxpost" ? "" : "none";
      }
    }

    // ─── Szállítási mód váltás ──────────────────────────────────────
    document.querySelectorAll<HTMLInputElement>("[data-shipping-radio]").forEach(radio => {
      radio.addEventListener("change", () => {
        if (radio.checked) {
          setShippingMethod(radio.value as ShippingMethod);
          renderSummary();
        }
      });
    });

    // Kosár frissülés event
    window.addEventListener("mona-cart-update", renderSummary);

    // ─── Form submit ────────────────────────────────────────────────
    form?.addEventListener("submit", async (e) => {
      e.preventDefault();
      if (!submitBtn || !submitText) return;

      const summary = getCartSummary();
      if (summary.items.length === 0) {
        showError("A kosár üres.");
        return;
      }

      // Form data összeállítás
      const formData = new FormData(form);
      const payload = {
        guestName: formData.get("guestName"),
        guestEmail: formData.get("guestEmail"),
        guestPhone: formData.get("guestPhone"),
        shippingMethod: summary.shippingMethod,
        shippingAddress: formData.get("shippingAddress") || undefined,
        shippingCity: formData.get("shippingCity") || undefined,
        shippingZip: formData.get("shippingZip") || undefined,
        paymentMethod: formData.get("paymentMethod"),
        customerNote: formData.get("customerNote") || undefined,
        items: summary.items.map(i => ({
          productId: i.productId,
          qty: i.qty,
        })),
      };

      // Loading állapot
      submitBtn.disabled = true;
      submitText.textContent = "Megrendelés feldolgozása...";
      errorContainer!.hidden = true;

      try {
        const res = await fetch("/api/checkout", {
          method: "POST",
          headers: { "Content-Type": "application/json" },
          body: JSON.stringify(payload),
        });

        const data = await res.json();

        if (!res.ok) {
          throw new Error(data.error || "Hiba történt a megrendelés feldolgozása közben.");
        }

        // Sikeres! Ürítjük a kosarat és átirányítunk
        clearCart();

        // Sprint 4.5.3.x — Cím auto-mentés a fiókba (logged-in + új cím esetén)
        // Háttérben fut, nem blokkolja a redirect-et — ha sikertelen, csendben elnyeljük
        await maybeSaveAddressAfterCheckout(payload);

        window.location.href = data.redirectUrl || `/penztar/koszonjuk?rendeles=${data.orderNumber}`;
      } catch (err: any) {
        console.error("[checkout] error:", err);
        showError(err.message || "Hiba történt. Próbáld újra!");
        submitBtn.disabled = false;
        submitText.textContent = "Megrendelem";
      }
    });

    // Sprint 4.5.3.x — Cím auto-mentés/manuális mentés a sikeres rendelés után
    async function maybeSaveAddressAfterCheckout(payload: any) {
      // Csak akkor próbáljuk, ha:
      // 1. Logged-in vendég (van address-list)
      // 2. Mentett cím nem lett kiválasztva (selectedAddressId === null)
      // 3. Van shipping address adat
      // 4. ÉS: vagy üres a savedAddresses (auto-mentés első cím), vagy a checkbox bekattintva

      if (selectedAddressId !== null) return;
      if (!payload.shippingAddress || !payload.shippingCity || !payload.shippingZip) return;

      const isFirstAddress = savedAddresses.length === 0;
      const checkboxChecked = saveAddressCheckbox?.checked === true;

      if (!isFirstAddress && !checkboxChecked) return;

      // Címke logika — értelmes default
      const label = pickDefaultLabel(savedAddresses);

      // Recipient név: a guestName alapján
      const recipientName = String(payload.guestName || "Vendég");

      try {
        const res = await fetch("/api/profile/addresses", {
          method: "POST",
          headers: { "Content-Type": "application/json" },
          credentials: "include",
          body: JSON.stringify({
            label,
            recipientName,
            phone: null,  // a profil telefonja használt — nem duplikáljuk
            street: payload.shippingAddress,
            city: payload.shippingCity,
            postalCode: payload.shippingZip,
            country: "HU",
            isShipping: true,
            isBilling: true,
            // Első cím: mindkét default automatikusan
            setDefaultShipping: isFirstAddress,
            setDefaultBilling: isFirstAddress,
          }),
        });

        if (res.ok) {
          // Diszkrét toast notification — a köszönjük oldalra is átvisszük
          // sessionStorage-on át (a köszönjük oldal megjeleníti)
          sessionStorage.setItem("checkout:addressSaved", JSON.stringify({
            label,
            timestamp: Date.now(),
          }));
        }
      } catch (err) {
        console.warn("[checkout] address auto-save failed:", err);
        // Csendben elnyeljük — nem blokkoljuk a sikeres rendelést
      }
    }

    function pickDefaultLabel(existing: any[]): string {
      const labels = new Set(existing.map(a => a.label.toLowerCase()));
      if (!labels.has("otthon")) return "Otthon";
      if (!labels.has("munkahely")) return "Munkahely";
      if (!labels.has("nyaraló")) return "Nyaraló";
      // Fallback: numerikus
      let n = existing.length + 1;
      while (labels.has(`cím #${n}`)) n++;
      return `Cím #${n}`;
    }

    function showError(message: string) {
      if (!errorContainer) return;
      errorContainer.hidden = false;
      errorContainer.textContent = message;
      errorContainer.scrollIntoView({ behavior: "smooth", block: "center" });
    }

    // Initial render
    renderSummary();

    // Sprint 4.5.3.x v0.9.18 — ZIP → város auto-fill bind
    bindZipCityAutofill({
      zipInput: shippingZipInput,
      cityInput: shippingCityInput,
      citiesDatalist: document.querySelector<HTMLDataListElement>("#hu-cities-datalist"),
    });
  </script>
</BaseLayout>

