---
// src/pages/bejelentkezes.astro
// Bejelentkezés form — Sprint 4-ben funkcionálissá

export const prerender = true;

import BaseLayout from "@/layouts/BaseLayout.astro";
import PageHero from "@/components/common/PageHero.astro";
---

<BaseLayout
  title="Bejelentkezés — Mona Studio"
  description="Bejelentkezés a Mona Studio webshopba — kosár, kívánságlista és rendelési előzmények."
  noindex={true}
>
  <PageHero
    title="Bejelentkezés"
    description="Kosár, kívánságlista és rendelési előzmények egy helyen."
    breadcrumbs={[
      { label: "Főoldal", href: "/" },
      { label: "Bejelentkezés" }
    ]}
    variant="compact"
  />

  <section class="auth section">
    <div class="container">
      <div class="auth__card">

        <div class="auth__placeholder">
          <p>
            <strong>Hamarosan érkezik!</strong>
          </p>
          <p>
            A bejelentkezés és regisztráció funkció <strong>Sprint 4-ben</strong> kerül
            aktiválásra a webshop indulásával együtt. Most még csak vendégként vásárolhatsz.
          </p>
        </div>

        <form class="auth__form" data-login-form>

          <div class="auth__field">
            <label for="login-email">Email</label>
            <input
              type="email"
              id="login-email"
              name="email"
              autocomplete="email"
              required
              disabled
            >
          </div>

          <div class="auth__field">
            <label for="login-password">Jelszó</label>
            <input
              type="password"
              id="login-password"
              name="password"
              autocomplete="current-password"
              required
              disabled
            >
          </div>

          <div class="auth__row">
            <label class="auth__checkbox">
              <input type="checkbox" name="remember" disabled>
              <span>Maradjak bejelentkezve</span>
            </label>
            <a href="/elfelejtett-jelszo" class="auth__link">Elfelejtett jelszó</a>
          </div>

          <button type="submit" class="btn btn-primary auth__submit" disabled>
            Bejelentkezés
          </button>

          <div class="auth__divider">
            <span>vagy</span>
          </div>

          <button type="button" class="btn btn-secondary auth__google" disabled>
            <svg viewBox="0 0 24 24" width="18" height="18" aria-hidden="true">
              <path fill="#4285f4" d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z"/>
              <path fill="#34a853" d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z"/>
              <path fill="#fbbc05" d="M5.84 14.1c-.22-.66-.35-1.36-.35-2.1s.13-1.44.35-2.1V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.61z"/>
              <path fill="#ea4335" d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z"/>
            </svg>
            <span>Google fiókkal</span>
          </button>
        </form>

        <p class="auth__footer">
          Még nincs fiókod?
          <a href="/regisztracio">Regisztráció →</a>
        </p>

      </div>
    </div>
  </section>
</BaseLayout>

<style>
.auth__card {
  max-width: 440px;
  margin-inline: auto;
  padding: var(--space-8) var(--space-6);
  background: var(--mona-elevated);
  border: 0.5px solid var(--mona-border);
}

.auth__placeholder {
  background: rgba(184, 90, 60, 0.05);
  border-left: 2px solid var(--mona-sale);
  padding: var(--space-3) var(--space-4);
  font-size: 14px;
  color: var(--mona-text-2);
  margin-bottom: var(--space-6);
}

.auth__placeholder p {
  margin-bottom: var(--space-2);
}

.auth__placeholder p:last-child {
  margin-bottom: 0;
}

.auth__form {
  display: flex;
  flex-direction: column;
  gap: var(--space-4);
}

.auth__field {
  display: flex;
  flex-direction: column;
  gap: var(--space-2);
}

.auth__row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  font-size: 13px;
  flex-wrap: wrap;
  gap: var(--space-2);
}

.auth__checkbox {
  display: flex;
  align-items: center;
  gap: var(--space-2);
  cursor: pointer;
  color: var(--mona-text-2);
  text-transform: none;
  letter-spacing: 0;
  font-weight: 400;
}

.auth__checkbox input {
  width: auto;
  min-height: auto;
  accent-color: var(--mona-nature);
}

.auth__link {
  color: var(--mona-text);
  text-decoration: underline;
  text-underline-offset: 2px;
}

.auth__submit {
  margin-top: var(--space-2);
}

.auth__divider {
  display: flex;
  align-items: center;
  gap: var(--space-3);
  margin-block: var(--space-3);
  font-size: 12px;
  color: var(--mona-text-3);
  text-transform: uppercase;
  letter-spacing: 0.1em;
}

.auth__divider::before,
.auth__divider::after {
  content: "";
  flex: 1;
  height: 0.5px;
  background: var(--mona-border);
}

.auth__google {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  gap: var(--space-2);
}

.auth__footer {
  margin-top: var(--space-6);
  padding-top: var(--space-5);
  border-top: 0.5px solid var(--mona-border);
  text-align: center;
  font-size: 14px;
  color: var(--mona-text-2);
}

.auth__footer a {
  color: var(--mona-text);
  text-decoration: underline;
  text-underline-offset: 3px;
  margin-left: var(--space-2);
}
</style>
