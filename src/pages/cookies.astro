---
// src/pages/cookies.astro
// Cookie tájékoztató

export const prerender = true;

import BaseLayout from "@/layouts/BaseLayout.astro";
import PageHero from "@/components/common/PageHero.astro";

const lastUpdated = "2026-04-26";
---

<BaseLayout
  title="Cookie tájékoztató — Mona Studio"
  description="Mona Studio cookie tájékoztató — milyen cookie-kat használunk, mire valók, és hogyan tudod kezelni a beállításokat."
>
  <PageHero
    title="Cookie tájékoztató"
    description={`Utolsó frissítés: ${lastUpdated}`}
    breadcrumbs={[
      { label: "Főoldal", href: "/" },
      { label: "Cookie kezelés" }
    ]}
  />

  <article class="legal section">
    <div class="container container-prose">

      <p class="legal__intro">
        A Mona Studio weboldal cookie-kat (sütiket) használ a megfelelő működéshez,
        a forgalom elemzéséhez és a felhasználói élmény javításához. Jelen tájékoztató
        elmagyarázza milyen cookie-kat használunk, mire valók, és hogyan kezelheted őket.
      </p>

      <h2>Mi a cookie?</h2>
      <p>
        A cookie egy kis szöveges fájl, amit a böngésződ tárol a meglátogatott weboldalakról.
        Ezek az adatok lehetővé teszik, hogy a weboldal "emlékezzen" rád — például ne kelljen
        minden alkalommal újra bejelentkezned.
      </p>

      <h2>Cookie kategóriák</h2>

      <h3>1. Szükséges cookie-k (mindig aktív)</h3>
      <p>
        Ezek nélkül a weboldal nem működik megfelelően. Nem tárolnak személyes információt,
        és nem szükséges hozzájárulás.
      </p>
      <ul>
        <li><strong>mona_consent</strong> — a cookie hozzájárulás állapota (1 év)</li>
        <li><strong>mona_cart</strong> — a kosár tartalma (session)</li>
        <li><strong>mona_session</strong> — bejelentkezett felhasználó (30 nap)</li>
      </ul>

      <h3>2. Forgalomelemző cookie-k (analytics)</h3>
      <p>
        Ezek segítenek megérteni hogyan használod az oldalt, így javíthatjuk a tartalmat.
        Csak akkor töltődnek be, ha hozzájárulsz.
      </p>
      <ul>
        <li><strong>Google Analytics 4</strong> (_ga, _gid) — látogatottság elemzés (2 év)</li>
      </ul>

      <h3>3. Marketing cookie-k</h3>
      <p>
        Releváns hirdetések megjelenítéséhez és a kampányok hatékonyságának méréséhez.
        Csak akkor töltődnek be, ha hozzájárulsz.
      </p>
      <ul>
        <li><strong>Facebook Pixel</strong> (_fbp) — remarketing (90 nap)</li>
      </ul>

      <h2>Hogyan kezelheted a cookie-kat?</h2>
      <p>
        A weboldalon első látogatáskor egy cookie banner jelenik meg, ahol választhatsz:
      </p>
      <ul>
        <li><strong>"Mindent elfogadok"</strong> — minden cookie engedélyezett</li>
        <li><strong>"Csak szükséges"</strong> — csak a működéshez szükséges cookie-k</li>
        <li><strong>"Beállítások"</strong> — kategóriánként választható</li>
      </ul>
      <p>
        A beállításaidat <strong>bármikor módosíthatod</strong> a weboldal alján található
        <strong>"Cookie beállítások"</strong> gombbal.
      </p>

      <h2>Cookie törlése böngészőben</h2>
      <p>
        A cookie-kat a böngésződ beállításaiban is kezelheted (törölheted, blokkolhatod):
      </p>
      <ul>
        <li><strong>Chrome:</strong> Beállítások → Adatvédelem és biztonság → Cookie-k</li>
        <li><strong>Firefox:</strong> Beállítások → Adatvédelem és biztonság → Sütik</li>
        <li><strong>Safari:</strong> Beállítások → Adatvédelem → Sütik kezelése</li>
        <li><strong>Edge:</strong> Beállítások → Cookie-k és webhelyek engedélyei</li>
      </ul>
      <p>
        Megjegyzés: ha letiltod az összes cookie-t, lehet hogy a weboldal egyes funkciói
        nem működnek megfelelően (pl. a kosár vagy a bejelentkezés).
      </p>

      <h2>Kapcsolódó dokumentumok</h2>
      <ul>
        <li><a href="/adatvedelem">Adatkezelési tájékoztató</a></li>
        <li><a href="/aszf">Általános Szerződési Feltételek</a></li>
      </ul>

      <p class="legal__updated">
        Utolsó frissítés: <strong>{lastUpdated}</strong>
      </p>

    </div>
  </article>
</BaseLayout>

<style>
.legal__intro {
  font-style: italic;
  color: var(--mona-text-2);
  border-block: 0.5px solid var(--mona-border);
  padding-block: var(--space-4);
  margin-bottom: var(--space-8);
}

.legal h2 {
  font-family: var(--mona-serif);
  font-size: clamp(1.25rem, 1.5vw + 0.75rem, 1.5rem);
  margin-top: var(--space-8);
  margin-bottom: var(--space-3);
}

.legal h3 {
  font-family: var(--mona-serif);
  font-size: 1.125rem;
  margin-top: var(--space-5);
  margin-bottom: var(--space-3);
}

.legal p {
  font-size: 1rem;
  line-height: 1.75;
  color: var(--mona-text);
  margin-bottom: var(--space-4);
}

.legal ul {
  list-style: none;
  padding: 0;
  margin-bottom: var(--space-4);
}

.legal ul li {
  position: relative;
  padding-left: var(--space-5);
  margin-bottom: var(--space-2);
  line-height: 1.6;
}

.legal ul li::before {
  content: "";
  position: absolute;
  left: 0;
  top: 0.7em;
  width: 8px;
  height: 1px;
  background: var(--mona-warm);
}

.legal a {
  color: var(--mona-text);
  text-decoration: underline;
  text-underline-offset: 3px;
}

.legal__updated {
  margin-top: var(--space-10);
  padding-top: var(--space-5);
  border-top: 0.5px solid var(--mona-border);
  font-size: 13px;
  color: var(--mona-text-3);
  text-align: center;
}

/* ─── v0.9.23 — Mobile responsive (Sprint 4.6 ZIP 3) ──────── */
@media (max-width: 600px) {
  .legal h2 {
    font-size: 1.25rem;
    margin-top: var(--space-6);
  }

  .legal p,
  .legal li {
    font-size: 14px;
    line-height: 1.7;
  }

  .legal__placeholder {
    padding: var(--space-3);
    font-size: 13px;
  }

  .legal__updated {
    margin-top: var(--space-6);
    padding-top: var(--space-4);
    font-size: 12px;
  }
}
</style>
