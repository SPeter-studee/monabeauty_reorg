---
// src/pages/szolgaltatasok/[slug].astro
// Egyedi szolgáltatás oldal — markdown content + Schema.org Service

export const prerender = true;

import { getCollection, type CollectionEntry } from "astro:content";
import BaseLayout from "@/layouts/BaseLayout.astro";
import PageHero from "@/components/common/PageHero.astro";

export async function getStaticPaths() {
  const services = await getCollection("services");
  return services.map(service => ({
    params: { slug: service.slug },
    props: { service },
  }));
}

interface Props {
  service: CollectionEntry<"services">;
}

const { service } = Astro.props;
const { Content } = await service.render();
const {
  title,
  description,
  heroImageUrl,
  heroImageAlt,
  duration,
  priceFrom,
  priceNote,
  bookingUrl,
} = service.data;

const ogImage = heroImageUrl
  ? new URL(heroImageUrl, Astro.site).href
  : undefined;
---

<BaseLayout
  title={`${title} — Mona Studio`}
  description={description}
  image={ogImage}
>
  {/* Schema.org Service markup */}
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "Service",
      "name": title,
      "description": description,
      "provider": {
        "@type": "BeautySalon",
        "name": "Mona Studio",
        "url": "https://monastudio.hu",
        "address": {
          "@type": "PostalAddress",
          "streetAddress": "Zrínyi Miklós u. 3.",
          "addressLocality": "Vác",
          "postalCode": "2600",
          "addressCountry": "HU"
        }
      },
      "areaServed": [
        { "@type": "City", "name": "Vác" },
        { "@type": "City", "name": "Budapest" }
      ],
      ...(priceFrom && {
        "offers": {
          "@type": "Offer",
          "price": priceFrom,
          "priceCurrency": "HUF",
          "availability": "https://schema.org/InStock"
        }
      }),
      ...(heroImageUrl && {
        "image": new URL(heroImageUrl, Astro.site).href
      })
    })} />
  </Fragment>

  <PageHero
    eyebrow="Szolgáltatás"
    title={title}
    description={description}
    breadcrumbs={[
      { label: "Főoldal", href: "/" },
      { label: "Szolgáltatások", href: "/szolgaltatasok" },
      { label: title }
    ]}
    variant="compact"
    align="left"
  />

  <article class="service-detail section">
    <div class="container container-prose">

      {/* Meta sor */}
      {(duration || priceFrom || priceNote) && (
        <div class="service-detail__meta">
          {duration && (
            <div class="service-detail__meta-item">
              <span class="service-detail__meta-label">Időtartam</span>
              <span class="service-detail__meta-value">{duration}</span>
            </div>
          )}
          {priceFrom && (
            <div class="service-detail__meta-item">
              <span class="service-detail__meta-label">Ár</span>
              <span class="service-detail__meta-value">
                {priceFrom.toLocaleString("hu-HU")} Ft-tól
              </span>
            </div>
          )}
          {priceNote && !priceFrom && (
            <div class="service-detail__meta-item service-detail__meta-item--note">
              <span class="service-detail__meta-value">{priceNote}</span>
            </div>
          )}
        </div>
      )}

      {/* Markdown tartalom */}
      <div class="service-detail__content">
        <Content />
      </div>

      {/* CTA */}
      <div class="service-detail__cta">
        <a href={bookingUrl ?? "/idopontfoglalas"} class="btn btn-primary btn-lg">
          Időpontfoglalás
        </a>
        <a href="/kapcsolat" class="btn btn-secondary">
          Kérdésem van
        </a>
      </div>

    </div>
  </article>
</BaseLayout>

<style>
.service-detail__meta {
  display: flex;
  flex-wrap: wrap;
  gap: var(--space-6);
  padding-bottom: var(--space-6);
  margin-bottom: var(--space-6);
  border-bottom: 0.5px solid var(--mona-border);
}

.service-detail__meta-item {
  display: flex;
  flex-direction: column;
  gap: var(--space-1);
}

.service-detail__meta-item--note {
  flex: 1;
}

.service-detail__meta-label {
  font-size: 11px;
  letter-spacing: 0.08em;
  text-transform: uppercase;
  color: var(--mona-text-3);
}

.service-detail__meta-value {
  font-family: var(--mona-sans);
  font-size: 1rem;
  color: var(--mona-text);
  font-weight: 500;
}

/* Markdown content */
.service-detail__content {
  font-size: 1.0625rem;
  line-height: 1.75;
  color: var(--mona-text);
}

.service-detail__content :global(h2) {
  font-family: var(--mona-serif);
  font-size: clamp(1.5rem, 2vw + 1rem, 2rem);
  margin-top: var(--space-10);
  margin-bottom: var(--space-4);
  color: var(--mona-text);
  padding-top: var(--space-6);
  border-top: 0.5px solid var(--mona-border);
}

.service-detail__content :global(h2):first-child {
  margin-top: 0;
  padding-top: 0;
  border-top: none;
}

.service-detail__content :global(h3) {
  font-family: var(--mona-serif);
  font-size: 1.375rem;
  margin-top: var(--space-6);
  margin-bottom: var(--space-3);
  color: var(--mona-text);
}

.service-detail__content :global(p) {
  margin-bottom: var(--space-4);
}

.service-detail__content :global(ul) {
  list-style: none;
  margin-bottom: var(--space-4);
  padding: 0;
}

.service-detail__content :global(ul li) {
  position: relative;
  padding-left: var(--space-5);
  margin-bottom: var(--space-2);
}

.service-detail__content :global(ul li)::before {
  content: "";
  position: absolute;
  left: 0;
  top: 0.6em;
  width: 8px;
  height: 1px;
  background: var(--mona-warm);
}

.service-detail__content :global(strong) {
  font-weight: 500;
  color: var(--mona-text);
}

.service-detail__content :global(blockquote) {
  border-left: 2px solid var(--mona-warm);
  padding: var(--space-3) var(--space-5);
  margin-block: var(--space-5);
  background: var(--mona-elevated);
  font-family: var(--mona-serif);
  font-style: italic;
}

.service-detail__cta {
  display: flex;
  flex-wrap: wrap;
  gap: var(--space-3);
  padding-top: var(--space-8);
  margin-top: var(--space-10);
  border-top: 0.5px solid var(--mona-border);
}
</style>
