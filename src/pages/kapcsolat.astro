---
// src/pages/kapcsolat.astro

import BaseLayout from "@/layouts/BaseLayout.astro";
import PageHero from "@/components/common/PageHero.astro";
import ContactForm from "@/components/common/ContactForm.astro";
---

<BaseLayout
  title="Kapcsolat — Mona Studio"
  description="Vegyél fel velem a kapcsolatot. Mona Studio, 2600 Vác, Zrínyi Miklós u. 3. — telefon: +36 20 913 0126, email: mona@monastudio.hu"
>
  <PageHero
    title="Kapcsolat"
    description="Írj nekem nyugodtan, vagy gyere el a szalonba. Hamarosan válaszolok."
    breadcrumbs={[
      { label: "Főoldal", href: "/" },
      { label: "Kapcsolat" }
    ]}
  />

  <section class="contact section">
    <div class="container">
      <div class="contact__grid">

        <div class="contact__info">
          <div class="contact__block">
            <p class="eyebrow">Cím</p>
            <p>
              <a href="https://maps.app.goo.gl/NrsyJ4eyMPsZCkUn6"
                 target="_blank" rel="noopener">
                2600 Vác,<br>
                Zrínyi Miklós u. 3.
              </a>
            </p>
          </div>

          <div class="contact__block">
            <p class="eyebrow">Telefon</p>
            <p><a href="tel:+36209130126">+36 20 913 0126</a></p>
          </div>

          <div class="contact__block">
            <p class="eyebrow">Email</p>
            <p><a href="mailto:mona@monastudio.hu">mona@monastudio.hu</a></p>
          </div>

          <div class="contact__block">
            <p class="eyebrow">Nyitvatartás</p>
            <ul class="contact__hours">
              <li><span>Hétfő</span><span>13:00 – 19:00</span></li>
              <li><span>Kedd</span><span>08:00 – 14:00</span></li>
              <li><span>Szerda</span><span>13:00 – 19:00</span></li>
              <li><span>Csütörtök</span><span>13:00 – 19:00</span></li>
              <li><span>Péntek</span><span>08:00 – 14:00</span></li>
              <li><span>Szombat</span><span>zárva</span></li>
              <li><span>Vasárnap</span><span>zárva</span></li>
            </ul>
          </div>

          <div class="contact__block">
            <p class="eyebrow">Közösségi média</p>
            <div class="contact__social">
              <a href="https://www.facebook.com/monastudiovac"
                 target="_blank" rel="noopener">Facebook</a>
              <a href="https://www.instagram.com/monastudiovac/"
                 target="_blank" rel="noopener">Instagram</a>
            </div>
          </div>
        </div>

        <div class="contact__form-wrap">
          <h2 class="contact__form-title">Írj üzenetet</h2>
          <p class="contact__form-blurb">
            Egy munkanapon belül válaszolok. Ha sürgős, hívj a fenti telefonszámon!
          </p>
          <ContactForm />
        </div>

      </div>
    </div>
  </section>

  <section class="contact-map section" aria-labelledby="contact-map-title">
    <div class="container">
      <div class="contact-map__inner">
        <div class="contact-map__text">
          <h2 id="contact-map-title" class="contact-map__title">Hogyan találsz meg</h2>
          <p class="contact-map__lead">
            A szalon Vác belvárosában található, a Zrínyi Miklós utca 3. szám alatt.
            A környéken több ingyenes parkolóhely is elérhető, és a városi
            buszmegállók 5 perces sétára vannak.
          </p>
          <div class="contact-map__actions">
            <a
              href="https://maps.app.goo.gl/NrsyJ4eyMPsZCkUn6"
              target="_blank"
              rel="noopener"
              class="btn btn-primary"
              aria-label="Útvonal Google Maps-en"
            >
              Útvonal a Google Maps-en →
            </a>
          </div>
        </div>

        <a
          href="https://maps.app.goo.gl/NrsyJ4eyMPsZCkUn6"
          target="_blank"
          rel="noopener"
          class="contact-map__visual"
          aria-label="Mona Studio Vác — térkép megnyitása Google Maps-ben"
        >
          <svg viewBox="0 0 400 280" xmlns="http://www.w3.org/2000/svg" role="img" aria-hidden="true">
            <!-- Térkép háttér — bézs Mona stílusban -->
            <rect width="400" height="280" fill="var(--mona-elevated)"/>

            <!-- Folyó (Duna) — Vác mellett -->
            <path d="M 0 200 Q 80 180 160 195 T 320 200 L 400 210 L 400 280 L 0 280 Z"
                  fill="var(--mona-bg)" opacity="0.7"/>

            <!-- Utak — finom világos vonalak -->
            <path d="M 0 100 L 400 110" stroke="var(--mona-border)" stroke-width="1.5" fill="none"/>
            <path d="M 50 0 L 60 280" stroke="var(--mona-border)" stroke-width="1.5" fill="none"/>
            <path d="M 200 0 L 210 280" stroke="var(--mona-border)" stroke-width="1.5" fill="none"/>
            <path d="M 350 0 L 340 280" stroke="var(--mona-border)" stroke-width="1.5" fill="none"/>
            <path d="M 0 50 L 400 60" stroke="var(--mona-border)" stroke-width="1" fill="none" opacity="0.6"/>
            <path d="M 0 150 L 400 160" stroke="var(--mona-border)" stroke-width="1" fill="none" opacity="0.6"/>

            <!-- Háztömbök — finom téglalapok -->
            <rect x="80" y="60" width="100" height="35" fill="var(--mona-bg)" opacity="0.5"/>
            <rect x="220" y="60" width="100" height="35" fill="var(--mona-bg)" opacity="0.5"/>
            <rect x="80" y="120" width="100" height="25" fill="var(--mona-bg)" opacity="0.5"/>
            <rect x="220" y="120" width="100" height="25" fill="var(--mona-bg)" opacity="0.5"/>

            <!-- Tűpont a stúdió helyén — patina arany Mona pin -->
            <g transform="translate(200, 130)">
              <!-- Árnyék -->
              <ellipse cx="0" cy="22" rx="10" ry="3" fill="rgb(0 0 0 / 0.15)"/>
              <!-- Pin szára -->
              <path d="M 0 22 L 0 0" stroke="var(--mona-warm)" stroke-width="2"/>
              <!-- Pin köre -->
              <circle cx="0" cy="-12" r="14" fill="var(--mona-warm)"/>
              <circle cx="0" cy="-12" r="6" fill="var(--mona-elevated)"/>
            </g>

            <!-- Felirat -->
            <text x="200" y="180" text-anchor="middle"
                  font-family="serif" font-size="14" fill="var(--mona-text)"
                  font-style="italic">Mona Studio</text>
            <text x="200" y="198" text-anchor="middle"
                  font-family="sans-serif" font-size="10" fill="var(--mona-text-3)"
                  letter-spacing="1">2600 VÁC · ZRÍNYI MIKLÓS U. 3.</text>
          </svg>

          <span class="contact-map__overlay">
            <span class="contact-map__overlay-text">Térkép megnyitása →</span>
          </span>
        </a>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
.contact__grid {
  display: grid;
  grid-template-columns: 1fr;
  gap: var(--space-10);
  max-width: var(--container-lg);
  margin-inline: auto;
}

@media (min-width: 1024px) {
  .contact__grid {
    grid-template-columns: minmax(280px, 1fr) 2fr;
    gap: var(--space-12);
  }
}

.contact__info {
  display: flex;
  flex-direction: column;
  gap: var(--space-6);
}

.contact__block {
  border-bottom: 0.5px solid var(--mona-border);
  padding-bottom: var(--space-4);
}

.contact__block:last-child {
  border-bottom: none;
}

.contact__block .eyebrow {
  margin-bottom: var(--space-2);
}

.contact__block p {
  font-size: 1rem;
  line-height: 1.5;
  color: var(--mona-text);
}

.contact__block a {
  color: var(--mona-text);
  text-decoration: none;
  border-bottom: 0.5px solid var(--mona-border);
  padding-bottom: 1px;
  transition: border-color var(--motion-fast) var(--ease);
}

.contact__block a:hover {
  border-bottom-color: var(--mona-text);
  color: var(--mona-text);
}

.contact__hours {
  display: grid;
  gap: var(--space-2);
}

.contact__hours li {
  display: flex;
  justify-content: space-between;
  font-size: 14px;
  color: var(--mona-text);
}

.contact__hours li span:last-child {
  color: var(--mona-text-2);
}

.contact__social {
  display: flex;
  gap: var(--space-4);
}

.contact__form-title {
  font-family: var(--mona-serif);
  font-size: clamp(1.5rem, 2vw + 1rem, 2rem);
  margin-bottom: var(--space-2);
}

.contact__form-blurb {
  font-size: 14px;
  color: var(--mona-text-2);
  margin-bottom: var(--space-6);
}

/* ─── Térkép szekció ──────────────────────────────────────── */
.contact-map {
  border-top: 0.5px solid var(--mona-border);
  background: var(--mona-bg);
}

.contact-map__inner {
  display: grid;
  grid-template-columns: 1fr;
  gap: var(--space-8);
  align-items: center;
  max-width: var(--container-lg);
  margin-inline: auto;
}

@media (min-width: 1024px) {
  .contact-map__inner {
    grid-template-columns: 1fr 1.2fr;
    gap: var(--space-12);
  }
}

.contact-map__title {
  font-family: var(--mona-serif);
  font-size: clamp(1.5rem, 2vw + 1rem, 2rem);
  font-weight: 500;
  margin: 0 0 var(--space-4);
  color: var(--mona-text);
}

.contact-map__lead {
  font-size: 15px;
  line-height: 1.65;
  color: var(--mona-text-2);
  margin: 0 0 var(--space-6);
}

.contact-map__actions {
  display: flex;
  flex-wrap: wrap;
  gap: var(--space-3);
}

.contact-map__visual {
  position: relative;
  display: block;
  background: var(--mona-elevated);
  border: 0.5px solid var(--mona-border);
  overflow: hidden;
  text-decoration: none;
  aspect-ratio: 400 / 280;
  transition: border-color var(--motion-base) var(--ease);
}

.contact-map__visual:hover {
  border-color: var(--mona-warm);
}

.contact-map__visual svg {
  width: 100%;
  height: 100%;
  display: block;
}

.contact-map__overlay {
  position: absolute;
  inset: 0;
  display: flex;
  align-items: flex-end;
  justify-content: center;
  padding: var(--space-4);
  background: linear-gradient(
    to bottom,
    transparent 50%,
    rgb(0 0 0 / 0.04) 100%
  );
  opacity: 0;
  transition: opacity var(--motion-base) var(--ease);
}

.contact-map__visual:hover .contact-map__overlay,
.contact-map__visual:focus-visible .contact-map__overlay {
  opacity: 1;
}

.contact-map__overlay-text {
  font-family: var(--mona-sans);
  font-size: 12px;
  letter-spacing: 0.12em;
  text-transform: uppercase;
  color: var(--mona-text);
  background: var(--mona-bg);
  padding: var(--space-2) var(--space-4);
  border: 0.5px solid var(--mona-border);
}

/* ─── v0.9.22 — Mobile responsive (Sprint 4.6 ZIP 2) ─────────── */
@media (max-width: 600px) {
  /* Grid gap kisebb mobile-on */
  .contact__grid {
    gap: var(--space-6);
  }

  .contact__info {
    gap: var(--space-4);
  }

  .contact__block {
    padding-bottom: var(--space-3);
  }

  .contact__block p {
    font-size: 14px;
  }

  .contact__hours li {
    font-size: 13px;
  }
}

@media (max-width: 480px) {
  /* Hours rows kicsit kompaktabb */
  .contact__hours li {
    font-size: 12px;
  }
}
</style>
