---
// src/pages/index.astro
// Mona Studio főoldal

import BaseLayout from "@/layouts/BaseLayout.astro";
import HomeHero from "@/components/home/HomeHero.astro";
import BrandPillars from "@/components/home/BrandPillars.astro";
import FeaturedTreatment from "@/components/home/FeaturedTreatment.astro";
import ActivePromotion from "@/components/home/ActivePromotion.astro";
import ServicesPreview from "@/components/home/ServicesPreview.astro";
import BlogPreview from "@/components/home/BlogPreview.astro";
import AboutMonikaTeaser from "@/components/home/AboutMonikaTeaser.astro";
import TrustindexReviews from "@/components/home/TrustindexReviews.astro";
import NewsletterForm from "@/components/common/NewsletterForm.astro";

// Trustindex widget URL — ha üres, placeholder jelenik meg (dev jelzés)
// TODO: cseréld le az igazi Trustindex loader URL-jére (lásd trustindex.io)
const TRUSTINDEX_WIDGET_URL = ""; // pl. "https://cdn.trustindex.io/loader.js?XXXXX"
---

<BaseLayout
  title="Mona Studio — A szépség benned van"
  description="Prémium kozmetikai kezelések Vácon — Szabó Mónika 20+ év szakmai tapasztalattal. Szemöldök tetoválás, arckezelés, nanopen, gyantázás és további szolgáltatások."
>
  <HomeHero />

  <BrandPillars />

  <FeaturedTreatment featuredSlug="szemoldok-tetovalas" />

  <ActivePromotion />

  <ServicesPreview />

  <BlogPreview />

  <AboutMonikaTeaser />

  <TrustindexReviews widgetUrl={TRUSTINDEX_WIDGET_URL} />

  <NewsletterForm />
</BaseLayout>
