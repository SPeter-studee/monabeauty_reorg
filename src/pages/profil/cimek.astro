---
// src/pages/profil/cimek.astro
// Sprint 4.5.3 — Címkönyv (v0.9.9: inline expand form, modal helyett)
//
// Változás a v0.9.6-hoz képest:
//   - Modal popup helyett INLINE EXPAND a profil oldalon
//   - "+ Új cím hozzáadása" gomb helyén nyílik ki a form
//   - Szerkesztés a kártya helyén (helyette megjelenik a form)
//   - Csendesebb UX, brand-konzisztens, mobile-on jobb
//   - Settings: Cím használata + Alapértelmezett ÖSSZEVONVA, 2x2 grid
//   - Checkbox feliratok: normál súly (nem uppercase, nem bold)

import ProfileLayout from "@/layouts/ProfileLayout.astro";
---

<ProfileLayout currentSection="addresses" title="Címeim">
  <div class="addresses-page">
    <header class="addresses-page__header">
      <h1 class="addresses-page__title">Címeim</h1>
      <p class="addresses-page__subtitle">
        Ide menthetsz le címeket, hogy a következő rendelésednél már ne kelljen
        újra beírnod. Maximum 10 címet tárolhatsz.
      </p>
    </header>

    {/* Loading állapot */}
    <div class="addresses-page__loading" data-addresses-loading>
      <div class="addresses-page__spinner"></div>
      <p>Címek betöltése...</p>
    </div>

    {/* Empty state */}
    <div class="addresses-page__empty" data-addresses-empty hidden>
      <div class="addresses-page__empty-icon" aria-hidden="true">
        <svg viewBox="0 0 24 24" width="48" height="48" fill="none" stroke="currentColor" stroke-width="1" stroke-linecap="round" stroke-linejoin="round">
          <path d="M12 2C8 2 5 5 5 9c0 5 7 13 7 13s7-8 7-13c0-4-3-7-7-7z"/>
          <circle cx="12" cy="9" r="2.5"/>
        </svg>
      </div>
      <h2>Még nincsenek mentett címeid</h2>
      <p>Adj hozzá egy címet, hogy a következő rendelésednél már ne kelljen újra beírnod.</p>
      <button type="button" class="btn btn-primary" data-add-address-btn>+ Új cím hozzáadása</button>
    </div>

    {/* Error state */}
    <div class="addresses-page__error" data-addresses-error hidden>
      <p data-addresses-error-text>—</p>
      <button type="button" class="btn-secondary" data-addresses-retry>Újrapróbálás</button>
    </div>

    {/* Címek lista + inline form */}
    <div class="addresses-page__container" data-addresses-container hidden>
      <ul class="addresses-page__list" data-addresses-list></ul>

      {/* Inline form — kibontódik a lista alatt */}
      <div class="address-form-block" data-form-block hidden>
        <h3 class="address-form-block__title" data-form-title>Új cím hozzáadása</h3>

        <form class="address-form-block__form" data-address-form novalidate>
          <input type="hidden" name="addressId" value="" data-form-id />

          <div class="address-form-block__field">
            <label class="address-form-block__label" for="addr-label">Címke *</label>
            <input type="text" id="addr-label" name="label" class="address-form-block__input" required maxlength="50" placeholder="pl. Otthon, Munkahely" />
            <p class="address-form-block__hint">Csak Te látod — segít megkülönböztetni a címeket.</p>
          </div>

          <div class="address-form-block__field">
            <label class="address-form-block__label" for="addr-recipient">Címzett neve *</label>
            <input type="text" id="addr-recipient" name="recipientName" class="address-form-block__input" required maxlength="100" autocomplete="name" />
          </div>

          <div class="address-form-block__field">
            <label class="address-form-block__label" for="addr-phone">Címzett telefonja</label>
            <input type="tel" id="addr-phone" name="phone" class="address-form-block__input" maxlength="20" autocomplete="tel" placeholder="Üresen hagyhatod" />
            <p class="address-form-block__hint">
              Csak ha másik telefonszámon hívja a futár (pl. ha nem a tied a cím — anyu, munkahely).
              Üresen hagyva a profilodban megadott telefonszámot használjuk.
            </p>
          </div>

          <div class="address-form-block__field">
            <label class="address-form-block__label" for="addr-street">Utca, házszám *</label>
            <input type="text" id="addr-street" name="street" class="address-form-block__input" required maxlength="200" autocomplete="street-address" />
          </div>

          <div class="address-form-block__field-row">
            <div class="address-form-block__field">
              <label class="address-form-block__label" for="addr-postal">Irányítószám *</label>
              <input type="text" id="addr-postal" name="postalCode" class="address-form-block__input" required maxlength="10" autocomplete="postal-code" inputmode="numeric" />
            </div>
            <div class="address-form-block__field">
              <label class="address-form-block__label" for="addr-city">Város *</label>
              <input type="text" id="addr-city" name="city" class="address-form-block__input" required maxlength="100" autocomplete="address-level2" />
            </div>
          </div>

          {/* Settings blokk — kompakt 2x2 grid */}
          <div class="address-form-block__settings">
            <p class="address-form-block__settings-label">Beállítások</p>

            {/* Hint csak az első címnél */}
            <p class="address-form-block__hint address-form-block__settings-hint" data-first-address-hint hidden>
              Mivel ez az első címed, automatikusan alapértelmezett lesz mind szállításra, mind számlázásra.
              Később a kártya alatt válthatsz másikra.
            </p>

            <div class="address-form-block__settings-grid">
              <label class="address-form-block__checkbox">
                <input type="checkbox" name="setDefaultShipping" data-default-shipping />
                <span>Alapértelmezett szállítási cím</span>
              </label>

              <label class="address-form-block__checkbox">
                <input type="checkbox" name="setDefaultBilling" data-default-billing />
                <span>Alapértelmezett számlázási cím</span>
              </label>
            </div>
          </div>

          <p class="address-form-block__error" data-form-error hidden></p>

          <div class="address-form-block__actions">
            <button type="button" class="address-form-block__btn address-form-block__btn--secondary" data-form-cancel>Mégse</button>
            <button type="submit" class="address-form-block__btn address-form-block__btn--primary" data-form-submit>
              <span data-submit-text>Cím mentése</span>
              <span data-submit-loading hidden>Mentés...</span>
            </button>
          </div>
        </form>
      </div>

      {/* "+ Új cím hozzáadása" gomb — eltűnik amikor form látszik */}
      <button
        type="button"
        class="addresses-page__add-btn"
        data-add-address-btn
      >
        <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
          <path d="M12 5v14M5 12h14"/>
        </svg>
        <span data-add-btn-text>Új cím hozzáadása</span>
      </button>
    </div>
  </div>
</ProfileLayout>

<script>
  import { subscribeAuthState } from "@/lib/auth-state";
  import type { AddressPublic } from "@/lib/types/addresses";

  (() => {
    let addresses: AddressPublic[] = [];
    let editingAddressId: number | null = null;
    let initialized = false;

    const loadingEl = document.querySelector<HTMLElement>("[data-addresses-loading]");
    const emptyEl = document.querySelector<HTMLElement>("[data-addresses-empty]");
    const errorEl = document.querySelector<HTMLElement>("[data-addresses-error]");
    const errorText = document.querySelector<HTMLElement>("[data-addresses-error-text]");
    const retryBtn = document.querySelector<HTMLButtonElement>("[data-addresses-retry]");
    const containerEl = document.querySelector<HTMLElement>("[data-addresses-container]");
    const listEl = document.querySelector<HTMLUListElement>("[data-addresses-list]");

    const formBlock = document.querySelector<HTMLElement>("[data-form-block]");
    const formTitle = document.querySelector<HTMLElement>("[data-form-title]");
    const form = document.querySelector<HTMLFormElement>("[data-address-form]");
    const formIdInput = document.querySelector<HTMLInputElement>("[data-form-id]");
    const formError = document.querySelector<HTMLElement>("[data-form-error]");
    const submitBtn = document.querySelector<HTMLButtonElement>("[data-form-submit]");
    const submitText = document.querySelector<HTMLElement>("[data-submit-text]");
    const submitLoading = document.querySelector<HTMLElement>("[data-submit-loading]");
    const cancelBtn = document.querySelector<HTMLButtonElement>("[data-form-cancel]");

    const addButtons = document.querySelectorAll<HTMLButtonElement>("[data-add-address-btn]");
    const addBtnText = document.querySelector<HTMLElement>("[data-add-btn-text]");

    if (!listEl || !formBlock || !form) return;

    subscribeAuthState((state) => {
      if (state.status === "authenticated" && !initialized) {
        initialized = true;
        loadAddresses();
      }
    });

    addButtons.forEach(btn => {
      btn.addEventListener("click", () => openForm(null));
    });

    cancelBtn?.addEventListener("click", () => closeForm());

    retryBtn?.addEventListener("click", () => {
      hideAll();
      showLoading();
      loadAddresses();
    });

    form.addEventListener("submit", async (e) => {
      e.preventDefault();
      await handleFormSubmit();
    });

    async function loadAddresses() {
      try {
        const res = await fetch("/api/profile/addresses", { credentials: "include" });
        const data = await res.json();
        if (!res.ok || !data.success) {
          showError(data.message || `Sikertelen betöltés (HTTP ${res.status}).`);
          return;
        }
        addresses = data.addresses || [];
        renderAddresses();
      } catch (err) {
        console.error("[addresses] load error:", err);
        showError("Hálózati hiba a címek betöltésekor.");
      }
    }

    function renderAddresses() {
      if (addresses.length === 0) {
        showEmpty();
        return;
      }

      hideAll();
      if (containerEl) containerEl.hidden = false;

      listEl!.innerHTML = addresses.map(addressToHtml).join("");

      listEl!.querySelectorAll<HTMLButtonElement>("[data-edit-id]").forEach(btn => {
        btn.addEventListener("click", () => {
          const id = parseInt(btn.dataset.editId!, 10);
          openForm(id);
        });
      });

      listEl!.querySelectorAll<HTMLButtonElement>("[data-delete-id]").forEach(btn => {
        btn.addEventListener("click", () => {
          const id = parseInt(btn.dataset.deleteId!, 10);
          handleDelete(id);
        });
      });

      listEl!.querySelectorAll<HTMLButtonElement>("[data-default-id]").forEach(btn => {
        btn.addEventListener("click", () => {
          const id = parseInt(btn.dataset.defaultId!, 10);
          const type = btn.dataset.defaultType as "shipping" | "billing";
          handleSetDefault(id, type);
        });
      });

      addButtons.forEach(btn => {
        btn.disabled = addresses.length >= 10;
      });
      if (addBtnText && addresses.length >= 10) {
        addBtnText.textContent = `Maximum 10 cím tárolható (${addresses.length}/10)`;
      } else if (addBtnText) {
        addBtnText.textContent = "Új cím hozzáadása";
      }
    }

    function addressToHtml(addr: AddressPublic): string {
      const badges: string[] = [];
      if (addr.isDefaultShipping) badges.push(`<span class="address-card__badge address-card__badge--shipping">Szállítási default</span>`);
      if (addr.isDefaultBilling) badges.push(`<span class="address-card__badge address-card__badge--billing">Számlázási default</span>`);

      return `
        <li class="address-card">
          <div class="address-card__head">
            <div class="address-card__head-main">
              <h3 class="address-card__label">${escape(addr.label)}</h3>
              ${badges.length > 0 ? `<div class="address-card__badges">${badges.join("")}</div>` : ""}
            </div>
            <div class="address-card__actions">
              <button type="button" class="address-card__action-btn" data-edit-id="${addr.id}" title="Szerkesztés">
                <svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M11 4H4a2 2 0 00-2 2v14a2 2 0 002 2h14a2 2 0 002-2v-7"/><path d="M18.5 2.5a2.121 2.121 0 113 3L12 15l-4 1 1-4 9.5-9.5z"/></svg>
              </button>
              <button type="button" class="address-card__action-btn address-card__action-btn--danger" data-delete-id="${addr.id}" title="Törlés">
                <svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M3 6h18M8 6V4a2 2 0 012-2h4a2 2 0 012 2v2M19 6l-1 14a2 2 0 01-2 2H8a2 2 0 01-2-2L5 6"/></svg>
              </button>
            </div>
          </div>
          <div class="address-card__body">
            <p class="address-card__recipient">${escape(addr.recipientName)}${addr.phone ? ` · ${escape(addr.phone)}` : ""}</p>
            <p class="address-card__address">${escape(addr.postalCode)} ${escape(addr.city)}, ${escape(addr.street)}</p>
          </div>
          <div class="address-card__footer">
            ${!addr.isDefaultShipping ? `<button type="button" class="address-card__set-default" data-default-id="${addr.id}" data-default-type="shipping">Tedd szállítási default-tá</button>` : ""}
            ${!addr.isDefaultBilling ? `<button type="button" class="address-card__set-default" data-default-id="${addr.id}" data-default-type="billing">Tedd számlázási default-tá</button>` : ""}
          </div>
        </li>
      `;
    }

    function escape(text: string): string {
      const div = document.createElement("div");
      div.textContent = text;
      return div.innerHTML;
    }

    function openForm(addressId: number | null) {
      editingAddressId = addressId;
      hideMessage(formError);
      form!.reset();

      if (addressId === null) {
        if (formTitle) formTitle.textContent = "Új cím hozzáadása";
        if (formIdInput) formIdInput.value = "";
        // FONTOS: a default checkbox-ok ALAPBÓL KIKAPCSOLVA. Ha első cím,
        // a backend automatikusan default-tá teszi (lásd POST endpoint).
        // A UI-on viszont nem akarunk agresszív vizuális default-ot.
        // Vizuális hint a "Beállítások" cím mellett értesít az automatizmusról.
        const isFirst = addresses.length === 0;
        const cbShip = form!.querySelector<HTMLInputElement>("[data-default-shipping]");
        const cbBill = form!.querySelector<HTMLInputElement>("[data-default-billing]");
        if (cbShip) cbShip.checked = false;
        if (cbBill) cbBill.checked = false;

        // Első cím hint megjelenítés
        const firstHint = document.querySelector<HTMLElement>("[data-first-address-hint]");
        if (firstHint) firstHint.hidden = !isFirst;
      } else {
        const addr = addresses.find(a => a.id === addressId);
        if (!addr) return;
        if (formTitle) formTitle.textContent = `${addr.label} — szerkesztés`;
        if (formIdInput) formIdInput.value = String(addr.id);
        (form!.querySelector("[name='label']") as HTMLInputElement).value = addr.label;
        (form!.querySelector("[name='recipientName']") as HTMLInputElement).value = addr.recipientName;
        (form!.querySelector("[name='phone']") as HTMLInputElement).value = addr.phone || "";
        (form!.querySelector("[name='street']") as HTMLInputElement).value = addr.street;
        (form!.querySelector("[name='postalCode']") as HTMLInputElement).value = addr.postalCode;
        (form!.querySelector("[name='city']") as HTMLInputElement).value = addr.city;
        (form!.querySelector("[name='setDefaultShipping']") as HTMLInputElement).checked = addr.isDefaultShipping;
        (form!.querySelector("[name='setDefaultBilling']") as HTMLInputElement).checked = addr.isDefaultBilling;

        // Szerkesztésnél: hint elrejtése (nem első cím szituáció)
        const firstHint = document.querySelector<HTMLElement>("[data-first-address-hint]");
        if (firstHint) firstHint.hidden = true;
      }

      // FONTOS (v0.9.12): ha empty state-ben vagyunk, váltsunk container-be
      // hogy a form-block (ami a container belsejében van) látszódjon
      hideAll();
      if (containerEl) containerEl.hidden = false;

      if (formBlock) formBlock.hidden = false;
      addButtons.forEach(btn => { btn.hidden = true; });

      setTimeout(() => {
        formBlock?.scrollIntoView({ behavior: "smooth", block: "start" });
        const labelInput = form!.querySelector<HTMLInputElement>("#addr-label");
        labelInput?.focus();
      }, 50);
    }

    function closeForm() {
      editingAddressId = null;
      if (formBlock) formBlock.hidden = true;
      addButtons.forEach(btn => { btn.hidden = false; });

      // FONTOS (v0.9.12): ha üres lista, vissza az empty state-be
      // (különben üres container marad látszik egy magányos add gombbal)
      if (addresses.length === 0) {
        showEmpty();
      }
    }

    async function handleFormSubmit() {
      hideMessage(formError);
      setLoading(true);

      const formData = new FormData(form!);
      const body = {
        label: String(formData.get("label") || ""),
        recipientName: String(formData.get("recipientName") || ""),
        phone: String(formData.get("phone") || "") || null,
        street: String(formData.get("street") || ""),
        city: String(formData.get("city") || ""),
        postalCode: String(formData.get("postalCode") || ""),
        country: "HU",
        // v0.9.15: minden cím alapból mindkettőre használható (egyszerűbb UX)
        isShipping: true,
        isBilling: true,
        setDefaultShipping: formData.get("setDefaultShipping") === "on",
        setDefaultBilling: formData.get("setDefaultBilling") === "on",
      };

      try {
        const isEdit = editingAddressId !== null;
        const url = isEdit ? `/api/profile/addresses/${editingAddressId}` : "/api/profile/addresses";
        const method = isEdit ? "PUT" : "POST";

        const res = await fetch(url, {
          method,
          headers: { "Content-Type": "application/json" },
          credentials: "include",
          body: JSON.stringify(body),
        });

        const data = await res.json();
        if (!res.ok || !data.success) {
          let msg = data.message || `Sikertelen mentés (HTTP ${res.status}).`;
          if (data.debug) msg += ` [debug: ${data.debug}]`;
          showMessage(formError, msg);
          setLoading(false);
          return;
        }

        await loadAddresses();
        closeForm();
        setLoading(false);
      } catch (err) {
        console.error("[addresses] form submit error:", err);
        showMessage(formError, "Hálózati hiba. Próbáld újra.");
        setLoading(false);
      }
    }

    async function handleDelete(id: number) {
      const addr = addresses.find(a => a.id === id);
      if (!addr) return;
      if (!confirm(`Biztosan törölni szeretnéd a(z) "${addr.label}" címet?`)) return;
      try {
        const res = await fetch(`/api/profile/addresses/${id}`, { method: "DELETE", credentials: "include" });
        const data = await res.json();
        if (!res.ok || !data.success) {
          alert(data.message || "Sikertelen törlés.");
          return;
        }
        await loadAddresses();
      } catch (err) {
        alert("Hálózati hiba a törléskor.");
      }
    }

    async function handleSetDefault(id: number, type: "shipping" | "billing") {
      try {
        const res = await fetch("/api/profile/addresses/default", {
          method: "POST",
          headers: { "Content-Type": "application/json" },
          credentials: "include",
          body: JSON.stringify({ addressId: id, type }),
        });
        const data = await res.json();
        if (!res.ok || !data.success) {
          alert(data.message || "Sikertelen beállítás.");
          return;
        }
        await loadAddresses();
      } catch (err) {
        alert("Hálózati hiba.");
      }
    }

    function hideAll() {
      if (loadingEl) loadingEl.hidden = true;
      if (emptyEl) emptyEl.hidden = true;
      if (errorEl) errorEl.hidden = true;
      if (containerEl) containerEl.hidden = true;
    }
    function showLoading() { hideAll(); if (loadingEl) loadingEl.hidden = false; }
    function showEmpty() { hideAll(); if (emptyEl) emptyEl.hidden = false; }
    function showError(msg: string) {
      hideAll();
      if (errorText) errorText.textContent = msg;
      if (errorEl) errorEl.hidden = false;
    }
    function setLoading(loading: boolean) {
      if (!submitBtn) return;
      submitBtn.disabled = loading;
      if (submitText) submitText.hidden = loading;
      if (submitLoading) submitLoading.hidden = !loading;
    }
    function showMessage(el: HTMLElement | null, msg: string) {
      if (!el) return;
      el.textContent = msg;
      el.hidden = false;
    }
    function hideMessage(el: HTMLElement | null) {
      if (!el) return;
      el.textContent = "";
      el.hidden = true;
    }
  })();
</script>

<style is:global>
  /* ─── Addresses page ─────────────────────────────────────────────────── */
  .addresses-page {
    display: flex;
    flex-direction: column;
    gap: var(--space-6);
  }

  /* [hidden] override */
  .addresses-page__loading[hidden],
  .addresses-page__empty[hidden],
  .addresses-page__error[hidden],
  .addresses-page__container[hidden],
  .address-form-block[hidden],
  .addresses-page__add-btn[hidden] {
    display: none !important;
  }

  .addresses-page__header {
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
  }

  .addresses-page__title {
    font-family: var(--mona-serif);
    font-size: 36px;
    line-height: 1.1;
    color: var(--mona-text);
    margin: 0;
  }

  .addresses-page__subtitle {
    font-family: var(--mona-sans);
    font-size: 14px;
    color: var(--mona-text-2);
    margin: 0;
  }

  /* ─── Loading / empty / error ────────────────────────────────────────── */
  .addresses-page__loading {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-3);
    padding: var(--space-8) 0;
    color: var(--mona-text-3);
    font-family: var(--mona-sans);
    font-size: 13px;
  }

  .addresses-page__spinner {
    width: 24px;
    height: 24px;
    border: 1.5px solid var(--mona-border);
    border-top-color: var(--mona-warm);
    border-radius: 50%;
    animation: addresses-spin 0.7s linear infinite;
  }

  @keyframes addresses-spin {
    to { transform: rotate(360deg); }
  }

  .addresses-page__empty {
    text-align: center;
    padding: var(--space-8) var(--space-4);
    border: 0.5px dashed var(--mona-border);
  }

  .addresses-page__empty-icon {
    color: var(--mona-text-3);
    margin-bottom: var(--space-4);
    display: flex;
    justify-content: center;
  }

  .addresses-page__empty h2 {
    font-family: var(--mona-serif);
    font-size: 22px;
    color: var(--mona-text);
    margin: 0 0 var(--space-2);
  }

  .addresses-page__empty p {
    font-family: var(--mona-sans);
    font-size: 13px;
    color: var(--mona-text-2);
    margin: 0 0 var(--space-5);
  }

  .addresses-page__error {
    text-align: center;
    padding: var(--space-6);
    background: rgb(212 80 80 / 0.08);
    border-left: 2px solid var(--mona-sale, #c84545);
