---
// src/pages/profil/cimek.astro
// Sprint 4.5.3 — Címkönyv (logged-in vendég címeinek kezelése)

import ProfileLayout from "@/layouts/ProfileLayout.astro";
---

<ProfileLayout currentSection="addresses" title="Címeim">
  <div class="addresses-page">
    <header class="addresses-page__header">
      <h1 class="addresses-page__title">Címeim</h1>
      <p class="addresses-page__subtitle">
        Ide menthetsz le címeket, hogy a következő rendelésednél már ne kelljen
        újra beírnod. Maximum 10 címet tárolhatsz.
      </p>
    </header>

    {/* Loading állapot */}
    <div class="addresses-page__loading" data-addresses-loading>
      <div class="addresses-page__spinner"></div>
      <p>Címek betöltése...</p>
    </div>

    {/* Empty state */}
    <div class="addresses-page__empty" data-addresses-empty hidden>
      <div class="addresses-page__empty-icon" aria-hidden="true">
        <svg viewBox="0 0 24 24" width="48" height="48" fill="none" stroke="currentColor" stroke-width="1" stroke-linecap="round" stroke-linejoin="round">
          <path d="M12 2C8 2 5 5 5 9c0 5 7 13 7 13s7-8 7-13c0-4-3-7-7-7z"/>
          <circle cx="12" cy="9" r="2.5"/>
        </svg>
      </div>
      <h2>Még nincsenek mentett címeid</h2>
      <p>Adj hozzá egy címet, hogy a következő rendelésednél már ne kelljen újra beírnod.</p>
      <button type="button" class="btn btn-primary" data-add-address-btn>+ Új cím hozzáadása</button>
    </div>

    {/* Error state */}
    <div class="addresses-page__error" data-addresses-error hidden>
      <p data-addresses-error-text>—</p>
      <button type="button" class="btn-secondary" data-addresses-retry>Újrapróbálás</button>
    </div>

    {/* Címek lista */}
    <div class="addresses-page__container" data-addresses-container hidden>
      <ul class="addresses-page__list" data-addresses-list></ul>

      <button
        type="button"
        class="addresses-page__add-btn"
        data-add-address-btn
      >
        <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
          <path d="M12 5v14M5 12h14"/>
        </svg>
        <span data-add-btn-text>Új cím hozzáadása</span>
      </button>
    </div>
  </div>

  {/* Modal: új / szerkesztés ─────────────────────────────────────────────── */}
  <div class="address-modal" data-address-modal hidden role="dialog" aria-modal="true" aria-labelledby="address-modal-title">
    <div class="address-modal__backdrop" data-modal-backdrop></div>
    <div class="address-modal__panel">
      <header class="address-modal__header">
        <h2 id="address-modal-title" class="address-modal__title" data-modal-title>Új cím</h2>
        <button type="button" class="address-modal__close" data-modal-close aria-label="Bezárás">
          <svg viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
            <path d="M18 6L6 18M6 6l12 12"/>
          </svg>
        </button>
      </header>

      <form class="address-modal__form" data-address-form novalidate>
        <input type="hidden" name="addressId" value="" data-form-id />

        <div class="address-modal__field">
          <label class="address-modal__label" for="addr-label">Címke *</label>
          <input type="text" id="addr-label" name="label" class="address-modal__input" required maxlength="50" placeholder="pl. Otthon, Munkahely" />
          <p class="address-modal__hint">Csak Te látod — segít megkülönböztetni a címeket.</p>
        </div>

        <div class="address-modal__field">
          <label class="address-modal__label" for="addr-recipient">Címzett neve *</label>
          <input type="text" id="addr-recipient" name="recipientName" class="address-modal__input" required maxlength="100" autocomplete="name" />
        </div>

        <div class="address-modal__field">
          <label class="address-modal__label" for="addr-phone">Telefon</label>
          <input type="tel" id="addr-phone" name="phone" class="address-modal__input" maxlength="20" autocomplete="tel" placeholder="+36 30 ..." />
          <p class="address-modal__hint">Opcionális — a futár hívja erre, ha gond van.</p>
        </div>

        <div class="address-modal__field">
          <label class="address-modal__label" for="addr-street">Utca, házszám *</label>
          <input type="text" id="addr-street" name="street" class="address-modal__input" required maxlength="200" autocomplete="street-address" />
        </div>

        <div class="address-modal__field-row">
          <div class="address-modal__field">
            <label class="address-modal__label" for="addr-postal">Irányítószám *</label>
            <input type="text" id="addr-postal" name="postalCode" class="address-modal__input" required maxlength="10" autocomplete="postal-code" inputmode="numeric" />
          </div>
          <div class="address-modal__field">
            <label class="address-modal__label" for="addr-city">Város *</label>
            <input type="text" id="addr-city" name="city" class="address-modal__input" required maxlength="100" autocomplete="address-level2" />
          </div>
        </div>

        <fieldset class="address-modal__fieldset">
          <legend class="address-modal__legend">Cím használata</legend>

          <label class="address-modal__checkbox">
            <input type="checkbox" name="isShipping" checked />
            <span>Szállításra használható</span>
          </label>

          <label class="address-modal__checkbox">
            <input type="checkbox" name="isBilling" checked />
            <span>Számlázásra használható</span>
          </label>
        </fieldset>

        <fieldset class="address-modal__fieldset">
          <legend class="address-modal__legend">Alapértelmezett</legend>

          <label class="address-modal__checkbox">
            <input type="checkbox" name="setDefaultShipping" data-default-shipping />
            <span>Alapértelmezett szállítási cím</span>
          </label>

          <label class="address-modal__checkbox">
            <input type="checkbox" name="setDefaultBilling" data-default-billing />
            <span>Alapértelmezett számlázási cím</span>
          </label>
        </fieldset>

        <p class="address-modal__error" data-form-error hidden></p>

        <div class="address-modal__actions">
          <button type="button" class="btn-secondary" data-modal-close>Mégse</button>
          <button type="submit" class="btn btn-primary" data-form-submit>
            <span data-submit-text>Mentés</span>
            <span data-submit-loading hidden>Mentés...</span>
          </button>
        </div>
      </form>
    </div>
  </div>
</ProfileLayout>

<script>
  // ── Címkönyv logika ────────────────────────────────────────────────────
  import { subscribeAuthState } from "@/lib/auth-state";
  import type { AddressPublic } from "@/lib/types/addresses";

  (() => {
    // State
    let addresses: AddressPublic[] = [];
    let editingAddressId: number | null = null;
    let initialized = false;

    // DOM refs
    const loadingEl = document.querySelector<HTMLElement>("[data-addresses-loading]");
    const emptyEl = document.querySelector<HTMLElement>("[data-addresses-empty]");
    const errorEl = document.querySelector<HTMLElement>("[data-addresses-error]");
    const errorText = document.querySelector<HTMLElement>("[data-addresses-error-text]");
    const retryBtn = document.querySelector<HTMLButtonElement>("[data-addresses-retry]");
    const containerEl = document.querySelector<HTMLElement>("[data-addresses-container]");
    const listEl = document.querySelector<HTMLUListElement>("[data-addresses-list]");

    // Modal refs
    const modal = document.querySelector<HTMLElement>("[data-address-modal]");
    const modalTitle = document.querySelector<HTMLElement>("[data-modal-title]");
    const modalForm = document.querySelector<HTMLFormElement>("[data-address-form]");
    const modalIdInput = document.querySelector<HTMLInputElement>("[data-form-id]");
    const formError = document.querySelector<HTMLElement>("[data-form-error]");
    const submitBtn = document.querySelector<HTMLButtonElement>("[data-form-submit]");
    const submitText = document.querySelector<HTMLElement>("[data-submit-text]");
    const submitLoading = document.querySelector<HTMLElement>("[data-submit-loading]");

    if (!listEl || !modal || !modalForm) return;

    // Auth state subscribe — ha autentikált, töltsd be
    subscribeAuthState((state) => {
      if (state.status === "authenticated" && !initialized) {
        initialized = true;
        loadAddresses();
      }
    });

    // ── Add / Retry gombok ──────────────────────────────────────────────
    document.querySelectorAll<HTMLButtonElement>("[data-add-address-btn]").forEach(btn => {
      btn.addEventListener("click", () => openModal(null));
    });
    retryBtn?.addEventListener("click", () => {
      hideAll();
      showLoading();
      loadAddresses();
    });

    // ── Modal close gombok ──────────────────────────────────────────────
    document.querySelectorAll<HTMLElement>("[data-modal-close], [data-modal-backdrop]").forEach(el => {
      el.addEventListener("click", () => closeModal());
    });

    document.addEventListener("keydown", (e) => {
      if (e.key === "Escape" && modal && !modal.hidden) {
        closeModal();
      }
    });

    // ── Modal form submit ───────────────────────────────────────────────
    modalForm.addEventListener("submit", async (e) => {
      e.preventDefault();
      await handleFormSubmit();
    });

    // ── API: címek betöltés ─────────────────────────────────────────────
    async function loadAddresses() {
      try {
        const res = await fetch("/api/profile/addresses", { credentials: "include" });
        const data = await res.json();

        if (!res.ok || !data.success) {
          showError(data.message || `Sikertelen betöltés (HTTP ${res.status}).`);
          return;
        }

        addresses = data.addresses || [];
        renderAddresses();
      } catch (err) {
        console.error("[addresses] load error:", err);
        showError("Hálózati hiba a címek betöltésekor.");
      }
    }

    // ── Render ──────────────────────────────────────────────────────────
    function renderAddresses() {
      if (addresses.length === 0) {
        showEmpty();
        return;
      }

      hideAll();
      if (containerEl) containerEl.hidden = false;

      listEl!.innerHTML = addresses.map(addressToHtml).join("");

      // Bind action buttons
      listEl!.querySelectorAll<HTMLButtonElement>("[data-edit-id]").forEach(btn => {
        btn.addEventListener("click", () => {
          const id = parseInt(btn.dataset.editId!, 10);
          openModal(id);
        });
      });

      listEl!.querySelectorAll<HTMLButtonElement>("[data-delete-id]").forEach(btn => {
        btn.addEventListener("click", () => {
          const id = parseInt(btn.dataset.deleteId!, 10);
          handleDelete(id);
        });
      });

      listEl!.querySelectorAll<HTMLButtonElement>("[data-default-id]").forEach(btn => {
        btn.addEventListener("click", () => {
          const id = parseInt(btn.dataset.defaultId!, 10);
          const type = btn.dataset.defaultType as "shipping" | "billing";
          handleSetDefault(id, type);
        });
      });

      // Update "Add" button state — kihalt ha 10 cím van
      document.querySelectorAll<HTMLButtonElement>("[data-add-address-btn]").forEach(btn => {
        btn.disabled = addresses.length >= 10;
      });
      const addBtnText = document.querySelector<HTMLElement>("[data-add-btn-text]");
      if (addBtnText && addresses.length >= 10) {
        addBtnText.textContent = `Maximum 10 cím tárolható (${addresses.length}/10)`;
      }
    }

    function addressToHtml(addr: AddressPublic): string {
      const badges: string[] = [];
      if (addr.isDefaultShipping) badges.push(`<span class="address-card__badge address-card__badge--shipping">Szállítási default</span>`);
      if (addr.isDefaultBilling) badges.push(`<span class="address-card__badge address-card__badge--billing">Számlázási default</span>`);

      const useTags: string[] = [];
      if (addr.isShipping && !addr.isDefaultShipping) useTags.push("Szállítás");
      if (addr.isBilling && !addr.isDefaultBilling) useTags.push("Számlázás");

      return `
        <li class="address-card">
          <div class="address-card__head">
            <div class="address-card__head-main">
              <h3 class="address-card__label">${escape(addr.label)}</h3>
              ${badges.length > 0 ? `<div class="address-card__badges">${badges.join("")}</div>` : ""}
            </div>
            <div class="address-card__actions">
              <button type="button" class="address-card__action-btn" data-edit-id="${addr.id}" title="Szerkesztés">
                <svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M11 4H4a2 2 0 00-2 2v14a2 2 0 002 2h14a2 2 0 002-2v-7"/><path d="M18.5 2.5a2.121 2.121 0 113 3L12 15l-4 1 1-4 9.5-9.5z"/></svg>
              </button>
              <button type="button" class="address-card__action-btn address-card__action-btn--danger" data-delete-id="${addr.id}" title="Törlés">
                <svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M3 6h18M8 6V4a2 2 0 012-2h4a2 2 0 012 2v2M19 6l-1 14a2 2 0 01-2 2H8a2 2 0 01-2-2L5 6"/></svg>
              </button>
            </div>
          </div>

          <div class="address-card__body">
            <p class="address-card__recipient">${escape(addr.recipientName)}${addr.phone ? ` · ${escape(addr.phone)}` : ""}</p>
            <p class="address-card__address">${escape(addr.postalCode)} ${escape(addr.city)}, ${escape(addr.street)}</p>
            ${useTags.length > 0 ? `<p class="address-card__usage">${useTags.join(" · ")}</p>` : ""}
          </div>

          <div class="address-card__footer">
            ${!addr.isDefaultShipping && addr.isShipping ? `<button type="button" class="address-card__set-default" data-default-id="${addr.id}" data-default-type="shipping">Tedd szállítási default-tá</button>` : ""}
            ${!addr.isDefaultBilling && addr.isBilling ? `<button type="button" class="address-card__set-default" data-default-id="${addr.id}" data-default-type="billing">Tedd számlázási default-tá</button>` : ""}
          </div>
        </li>
      `;
    }

    function escape(text: string): string {
      const div = document.createElement("div");
      div.textContent = text;
      return div.innerHTML;
    }

    // ── Modal: open / close ─────────────────────────────────────────────
    function openModal(addressId: number | null) {
      editingAddressId = addressId;

      // Reset form
      modalForm!.reset();
      hideMessage(formError);

      if (addressId === null) {
        // Új cím
        if (modalTitle) modalTitle.textContent = "Új cím";
        if (modalIdInput) modalIdInput.value = "";

        // Default checkbox: ha első cím, mindkét default-tá tesszük
        const isFirst = addresses.length === 0;
        const defaultShippingCb = modalForm!.querySelector<HTMLInputElement>("[data-default-shipping]");
        const defaultBillingCb = modalForm!.querySelector<HTMLInputElement>("[data-default-billing]");
        if (defaultShippingCb) defaultShippingCb.checked = isFirst;
        if (defaultBillingCb) defaultBillingCb.checked = isFirst;
      } else {
        // Szerkesztés
        const addr = addresses.find(a => a.id === addressId);
        if (!addr) return;

        if (modalTitle) modalTitle.textContent = "Cím szerkesztése";
        if (modalIdInput) modalIdInput.value = String(addr.id);

        (modalForm!.querySelector("[name='label']") as HTMLInputElement).value = addr.label;
        (modalForm!.querySelector("[name='recipientName']") as HTMLInputElement).value = addr.recipientName;
        (modalForm!.querySelector("[name='phone']") as HTMLInputElement).value = addr.phone || "";
        (modalForm!.querySelector("[name='street']") as HTMLInputElement).value = addr.street;
        (modalForm!.querySelector("[name='postalCode']") as HTMLInputElement).value = addr.postalCode;
        (modalForm!.querySelector("[name='city']") as HTMLInputElement).value = addr.city;
        (modalForm!.querySelector("[name='isShipping']") as HTMLInputElement).checked = addr.isShipping;
        (modalForm!.querySelector("[name='isBilling']") as HTMLInputElement).checked = addr.isBilling;
        (modalForm!.querySelector("[name='setDefaultShipping']") as HTMLInputElement).checked = addr.isDefaultShipping;
        (modalForm!.querySelector("[name='setDefaultBilling']") as HTMLInputElement).checked = addr.isDefaultBilling;
      }

      modal!.hidden = false;
      document.body.style.overflow = "hidden";
    }

    function closeModal() {
      modal!.hidden = true;
      document.body.style.overflow = "";
      editingAddressId = null;
    }

    // ── Form submit ─────────────────────────────────────────────────────
    async function handleFormSubmit() {
      hideMessage(formError);
      setLoading(true);

      const formData = new FormData(modalForm!);
      const body = {
        label: String(formData.get("label") || ""),
        recipientName: String(formData.get("recipientName") || ""),
        phone: String(formData.get("phone") || "") || null,
        street: String(formData.get("street") || ""),
        city: String(formData.get("city") || ""),
        postalCode: String(formData.get("postalCode") || ""),
        country: "HU",
        isShipping: formData.get("isShipping") === "on",
        isBilling: formData.get("isBilling") === "on",
        setDefaultShipping: formData.get("setDefaultShipping") === "on",
        setDefaultBilling: formData.get("setDefaultBilling") === "on",
      };

      try {
        const isEdit = editingAddressId !== null;
        const url = isEdit
          ? `/api/profile/addresses/${editingAddressId}`
          : "/api/profile/addresses";
        const method = isEdit ? "PUT" : "POST";

        const res = await fetch(url, {
          method,
          headers: { "Content-Type": "application/json" },
          credentials: "include",
          body: JSON.stringify(body),
        });

        const data = await res.json();

        if (!res.ok || !data.success) {
          let msg = data.message || `Sikertelen mentés (HTTP ${res.status}).`;
          if (data.debug) msg += ` [debug: ${data.debug}]`;
          showMessage(formError, msg);
          setLoading(false);
          return;
        }

        // Sikeres → újratöltjük a listát és bezárjuk
        await loadAddresses();
        closeModal();
        setLoading(false);
      } catch (err) {
        console.error("[addresses] form submit error:", err);
        showMessage(formError, "Hálózati hiba. Próbáld újra.");
        setLoading(false);
      }
    }

    // ── Delete ──────────────────────────────────────────────────────────
    async function handleDelete(id: number) {
      const addr = addresses.find(a => a.id === id);
      if (!addr) return;

      const confirmed = confirm(`Biztosan törölni szeretnéd a(z) "${addr.label}" címet?`);
      if (!confirmed) return;

      try {
        const res = await fetch(`/api/profile/addresses/${id}`, {
          method: "DELETE",
          credentials: "include",
        });
        const data = await res.json();

        if (!res.ok || !data.success) {
          alert(data.message || "Sikertelen törlés.");
          return;
        }

        await loadAddresses();
      } catch (err) {
        console.error("[addresses] delete error:", err);
        alert("Hálózati hiba a törléskor.");
      }
    }

    // ── Set default ────────────────────────────────────────────────────
    async function handleSetDefault(id: number, type: "shipping" | "billing") {
      try {
        const res = await fetch("/api/profile/addresses/default", {
          method: "POST",
          headers: { "Content-Type": "application/json" },
          credentials: "include",
          body: JSON.stringify({ addressId: id, type }),
        });
        const data = await res.json();

        if (!res.ok || !data.success) {
          alert(data.message || "Sikertelen beállítás.");
          return;
        }

        await loadAddresses();
      } catch (err) {
        console.error("[addresses] set default error:", err);
        alert("Hálózati hiba.");
      }
    }

    // ── State helpers ────────────────────────────────────────────────────
    function hideAll() {
      if (loadingEl) loadingEl.hidden = true;
      if (emptyEl) emptyEl.hidden = true;
      if (errorEl) errorEl.hidden = true;
      if (containerEl) containerEl.hidden = true;
    }

    function showLoading() {
      hideAll();
      if (loadingEl) loadingEl.hidden = false;
    }

    function showEmpty() {
      hideAll();
      if (emptyEl) emptyEl.hidden = false;
    }

    function showError(msg: string) {
      hideAll();
      if (errorText) errorText.textContent = msg;
      if (errorEl) errorEl.hidden = false;
    }

    function setLoading(loading: boolean) {
      if (!submitBtn) return;
      submitBtn.disabled = loading;
      if (submitText) submitText.hidden = loading;
      if (submitLoading) submitLoading.hidden = !loading;
    }

    function showMessage(el: HTMLElement | null, msg: string) {
      if (!el) return;
      el.textContent = msg;
      el.hidden = false;
    }

    function hideMessage(el: HTMLElement | null) {
      if (!el) return;
      el.textContent = "";
      el.hidden = true;
    }
  })();
</script>

<style is:global>
  /* ─── Addresses page ─────────────────────────────────────────────────── */
  .addresses-page {
    display: flex;
    flex-direction: column;
    gap: var(--space-6);
  }

  /* [hidden] override — lásd: rendelesek.astro v0.9.7 fix komment */
  .addresses-page__loading[hidden],
  .addresses-page__empty[hidden],
  .addresses-page__error[hidden],
  .addresses-page__container[hidden],
  .address-modal[hidden] {
    display: none !important;
  }

  .addresses-page__header {
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
  }

  .addresses-page__title {
    font-family: var(--mona-serif);
    font-size: 36px;
    line-height: 1.1;
    color: var(--mona-text);
    margin: 0;
  }

  .addresses-page__subtitle {
    font-family: var(--mona-sans);
    font-size: 14px;
    color: var(--mona-text-2);
    margin: 0;
  }

  /* ─── Loading / empty / error ─────────────────────────────────────────── */
  .addresses-page__loading {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-3);
    padding: var(--space-8) 0;
    color: var(--mona-text-3);
    font-family: var(--mona-sans);
    font-size: 13px;
  }

  .addresses-page__spinner {
    width: 24px;
    height: 24px;
    border: 1.5px solid var(--mona-border);
    border-top-color: var(--mona-warm);
    border-radius: 50%;
    animation: addresses-spin 0.7s linear infinite;
  }

  @keyframes addresses-spin {
    to { transform: rotate(360deg); }
  }

  .addresses-page__empty {
    text-align: center;
    padding: var(--space-8) var(--space-4);
    border: 0.5px dashed var(--mona-border);
  }

  .addresses-page__empty-icon {
    color: var(--mona-text-3);
    margin-bottom: var(--space-4);
    display: flex;
    justify-content: center;
  }

  .addresses-page__empty h2 {
    font-family: var(--mona-serif);
    font-size: 22px;
    color: var(--mona-text);
    margin: 0 0 var(--space-2);
  }

  .addresses-page__empty p {
    font-family: var(--mona-sans);
    font-size: 13px;
    color: var(--mona-text-2);
    margin: 0 0 var(--space-5);
  }

  .addresses-page__error {
    text-align: center;
    padding: var(--space-6);
    background: rgb(212 80 80 / 0.08);
    border-left: 2px solid var(--mona-sale, #c84545);
    color: var(--mona-sale, #c84545);
