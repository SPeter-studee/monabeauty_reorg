---
// IDEIGLENES — 3 verifikációs / CTA banner variáns összehasonlítás a tényleges
// profil layoutban. Döntés után ezt a fájlt töröld.
import ProfileLayout from "@/layouts/ProfileLayout.astro";
---

<ProfileLayout currentSection="profile" title="Banner preview (IDEIGLENES)">
  <div class="banner-preview">
    <header class="banner-preview__header">
      <h1 class="banner-preview__title">Verifikációs banner — 3 variáns</h1>
      <p class="banner-preview__subtitle">
        Ugyanaz a tartalom, más elrendezés. Mobile-on egymás alatt.
      </p>
    </header>

    <div class="banner-preview__grid" role="list">
      <!-- Opció 1: kompakt sáv, bal border akcent (jelenlegi profil irány) -->
      <section class="banner-preview__col" role="listitem" aria-labelledby="opt1">
        <h2 id="opt1" class="banner-preview__label">Opció 1</h2>
        <p class="banner-preview__hint">Kompakt, bal arany csík, fehéres kártya</p>
        <div class="bp-v1">
          <div class="bp-v1__icon" aria-hidden="true">
            <svg viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <path d="M4 7h16v10H4z"/>
              <path d="M4 7l8 7 8-7"/>
            </svg>
          </div>
          <div class="bp-v1__content">
            <strong class="bp-v1__title">Email cím még nem verifikálva</strong>
            <p class="bp-v1__text">
              Verifikáld az email címedet, és <strong>-10% kedvezményt</strong> kapsz az első rendelésedre.
            </p>
          </div>
          <button type="button" class="bp-v1__btn" disabled>
            Küldj verifikációs linket
          </button>
        </div>
      </section>

      <!-- Opció 2: pletyka / inline eyebrow, kevesebb „doboz” -->
      <section class="banner-preview__col" role="listitem" aria-labelledby="opt2">
        <h2 id="opt2" class="banner-preview__label">Opció 2</h2>
        <p class="banner-preview__hint">Szöveges eyebrow + vékony aláhúzás, kevesebb padding</p>
        <div class="bp-v2">
          <p class="bp-v2__eyebrow">Fontos</p>
          <p class="bp-v2__line">
            <span class="bp-v2__strong">Email cím még nem verifikálva.</span>
            Verifikáld, és <strong>-10% kedvezményt</strong> kapsz az első rendelésedre.
          </p>
          <button type="button" class="bp-v2__btn" disabled>
            Küldj verifikációs linket
          </button>
        </div>
      </section>

      <!-- Opció 3: teljes szélességű meleg háttérsáv (Glossier-soft) -->
      <section class="banner-preview__col" role="listitem" aria-labelledby="opt3">
        <h2 id="opt3" class="banner-preview__label">Opció 3</h2>
        <p class="banner-preview__hint">Meleg homogén háttér, erősebb contrast a gombbal</p>
        <div class="bp-v3">
          <div class="bp-v3__inner">
            <div class="bp-v3__icon" aria-hidden="true">
              <svg viewBox="0 0 24 24" width="22" height="22" fill="none" stroke="var(--mona-warm)" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                <path d="M4 7h16v10H4z"/>
                <path d="M4 7l8 7 8-7"/>
              </svg>
            </div>
            <div>
              <strong class="bp-v3__title">Email cím még nem verifikálva</strong>
              <p class="bp-v3__text">
                Verifikáld az email címedet, és <strong>-10% kedvezményt</strong> kapsz az első rendelésedre.
              </p>
            </div>
            <button type="button" class="bp-v3__btn" disabled>
              Küldj verifikációs linket
            </button>
          </div>
        </div>
      </section>
    </div>

    <p class="banner-preview__footer-note">
      IDEIGLENES oldal — választás után törölhető (<code>/profil/banner-preview</code>).
    </p>
  </div>
</ProfileLayout>

<style>
  .banner-preview {
    display: flex;
    flex-direction: column;
    gap: var(--space-6);
  }

  .banner-preview__header {
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
  }

  .banner-preview__title {
    font-family: var(--mona-serif);
    font-size: clamp(26px, 4vw, 34px);
    line-height: 1.15;
    color: var(--mona-text);
    margin: 0;
  }

  .banner-preview__subtitle {
    font-family: var(--mona-sans);
    font-size: 14px;
    color: var(--mona-text-2);
    margin: 0;
  }

  .banner-preview__grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: var(--space-5);
    align-items: start;
  }

  @media (max-width: 960px) {
    .banner-preview__grid {
      grid-template-columns: 1fr;
    }
  }

  .banner-preview__col {
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
    min-width: 0;
  }

  .banner-preview__label {
    font-family: var(--mona-sans);
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--mona-text-3);
    margin: 0;
  }

  .banner-preview__hint {
    font-family: var(--mona-sans);
    font-size: 12px;
    color: var(--mona-text-3);
    margin: calc(var(--space-2) * -1) 0 0;
    line-height: 1.4;
  }

  .banner-preview__footer-note {
    font-family: var(--mona-sans);
    font-size: 12px;
    color: var(--mona-text-3);
    margin: 0;
    padding-top: var(--space-4);
    border-top: 0.5px solid var(--mona-border);
  }

  .banner-preview__footer-note code {
    font-size: 11px;
    word-break: break-all;
  }

  /* ─── Variáns 1 ─────────────────────────────────────────────────────── */
  .bp-v1 {
    display: flex;
    flex-wrap: wrap;
    align-items: flex-start;
    gap: var(--space-3);
    padding: var(--space-4);
    border: 0.5px solid var(--mona-border);
    border-left: 3px solid var(--mona-warm);
    background: var(--mona-elevated);
  }

  .bp-v1__icon {
    flex-shrink: 0;
    color: var(--mona-warm);
    margin-top: 2px;
  }

  .bp-v1__content {
    flex: 1;
    min-width: min(100%, 160px);
  }

  .bp-v1__title {
    display: block;
    font-family: var(--mona-sans);
    font-size: 13px;
    font-weight: 600;
    color: var(--mona-text);
    margin-bottom: var(--space-1);
  }

  .bp-v1__text {
    font-family: var(--mona-sans);
    font-size: 13px;
    color: var(--mona-text-2);
    margin: 0;
    line-height: 1.5;
  }

  .bp-v1__btn {
    flex: 1 1 100%;
    align-self: stretch;
    padding: 10px var(--space-3);
    font-family: var(--mona-sans);
    font-size: 13px;
    font-weight: 500;
    border: 0.5px solid var(--mona-border);
    background: var(--mona-bg);
    color: var(--mona-text-2);
    cursor: not-allowed;
  }

  @media (min-width: 400px) {
    .bp-v1__btn {
      flex: 0 0 auto;
      align-self: center;
    }
  }

  /* ─── Variáns 2 ─────────────────────────────────────────────────────── */
  .bp-v2 {
    padding: var(--space-3) 0 var(--space-2);
    border-bottom: 0.5px solid var(--mona-border);
  }

  .bp-v2__eyebrow {
    font-family: var(--mona-sans);
    font-size: 10px;
    font-weight: 700;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--mona-warm);
    margin: 0 0 var(--space-2);
    padding-bottom: 2px;
    border-bottom: 2px solid var(--mona-warm);
    display: inline-block;
  }

  .bp-v2__line {
    font-family: var(--mona-sans);
    font-size: 13px;
    color: var(--mona-text-2);
    line-height: 1.55;
    margin: 0 0 var(--space-3);
  }

  .bp-v2__strong {
    display: block;
    font-weight: 600;
    color: var(--mona-text);
    margin-bottom: var(--space-1);
  }

  .bp-v2__btn {
    padding: 8px 14px;
    font-family: var(--mona-sans);
    font-size: 12px;
    font-weight: 500;
    border: 0.5px dashed var(--mona-border);
    background: transparent;
    color: var(--mona-text-3);
    cursor: not-allowed;
  }

  /* ─── Variáns 3 ─────────────────────────────────────────────────────── */
  .bp-v3 {
    background: linear-gradient(
      135deg,
      rgb(245 241 232 / 0.95),
      rgb(235 229 219 / 0.85)
    );
    border: 0.5px solid var(--mona-border);
    border-radius: 2px;
    padding: var(--space-4);
  }

  .bp-v3__inner {
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
  }

  @media (min-width: 420px) {
    .bp-v3__inner {
      flex-direction: row;
      flex-wrap: wrap;
      align-items: center;
    }

    .bp-v3__btn {
      margin-left: auto;
    }
  }

  .bp-v3__icon {
    flex-shrink: 0;
  }

  .bp-v3__title {
    display: block;
    font-family: var(--mona-sans);
    font-size: 14px;
    font-weight: 600;
    color: var(--mona-text);
    margin-bottom: var(--space-1);
  }

  .bp-v3__text {
    font-family: var(--mona-sans);
    font-size: 13px;
    color: var(--mona-text-2);
    margin: 0;
    line-height: 1.5;
    max-width: 42ch;
  }

  .bp-v3__btn {
    flex-shrink: 0;
    padding: 10px 18px;
    font-family: var(--mona-sans);
    font-size: 13px;
    font-weight: 600;
    border: none;
    background: var(--mona-warm);
    color: #fff;
    cursor: not-allowed;
    opacity: 0.65;
  }
</style>
